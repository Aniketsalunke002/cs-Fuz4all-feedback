#include <iostream>

#include <vector>
#include <algorithm>
#include <iterator>


using namespace std;

int main() 
{
   vector<int> v1(3);
   vector<int> v2(10);
   copy(v1.begin(), v1.end(), v2.begin());
   copy(v1.begin(), v1.end(), ostream_iterator<int>(cout, ", "));
   cout << endl;
   
   copy(v2.begin(), v2.begin() + 2, inserter(v1, v1.begin()));
   copy(v1.begin(), v1.end(), ostream_iterator<int>(cout, ", "));
   cout << endl;
   return 0;
}
