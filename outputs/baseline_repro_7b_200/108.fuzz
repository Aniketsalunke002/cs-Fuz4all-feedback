#include <iostream>
int main(void) {
  using namespace std;
  const int k = 42;
  static_assert(k==42, "[error]: This program will not compile!");
  return 0;
}
 
#include <iostream>
#include <exception>
using namespace std;

class exception : runtime_error {
  using runtime_error::runtime_error;
} __attribute__((noreturn));

void fun(void) {
  throw exception("exception");
}

int main(void) {
  fun();
}
