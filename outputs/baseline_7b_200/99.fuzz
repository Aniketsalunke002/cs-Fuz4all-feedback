#include <iostream>
using namespace std;
struct Point {
    int x;
    int y;
    Point operator + (Point);
    void Print();
}
void Point::Print() {
    cout << '(' << this->x << ", " << this->y << ')' << endl;
}
Point operator + (Point a, Point b) {
    return Point { a.x + b.x, a.y + b.y };
}
