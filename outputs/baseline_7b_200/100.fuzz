#include <iostream>
using namespace std;
int main() {
    bool a = true;
    bool b = false;
    if (a) {
        cout << "a is true, ";
        if (b) {
            cout << "b is true\n";
        } else {
            cout << "b is false\n";
        }
    } else {
        cout << "a is false\n";
    }
}

 
