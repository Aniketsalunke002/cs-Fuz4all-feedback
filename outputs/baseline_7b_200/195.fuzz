#include <iostream>
#include <string>

using namespace std;

class Student
{
    string name;
    int age;

  public:
    Student(const string &s, int a) : name(s), age(a) {}
    const string &getName() const { return name; }
    int getAge() { return age; }
};

Student *func()
{
    Student *s = new Student("Aaron", 21);
    return s;
}

int main()
{
    Student *pS = func();
    cout << "pName = " + pS->getName() << endl;
    return 0;
}