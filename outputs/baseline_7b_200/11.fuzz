#include <iostream>
using namespace std;
int main()
{
    string a("Hello world");
    cout << "Before: " << a << endl;  
     
    for (int count = 1; count <= 5; count++) 
        a[count] = 'x';  
                       
    cout << "After: " << a << endl;  
     
    return 0;
}
 
