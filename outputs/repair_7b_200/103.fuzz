#include <iostream>
int main() {
    int z = 0;
    int x = 1;
    int tmp = 0;
    int y = 1;
    int res = 0;
    for (int i = 1; i <= 5; i = i + 2) {
        y = x + z;
        z = y - x;
        tmp = x;
        x = y;
        y += tmp;
        std::cout << i << ':' << x << '=' << y << std::endl;
    }
    return 0;
}
