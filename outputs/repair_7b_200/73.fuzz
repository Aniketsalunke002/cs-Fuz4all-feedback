#include <iostream>
int main() {
    class Some {
        private:
            int x, y;
        
        public:
            Some() {
                x = 10;
                y = 20;
            }
    };
    
    Some s;
    s.x = 30; 
    std::cout << s.x << " " << s.y;
}
 
