#include <iostream>

 
#include <iostream>
using namespace std;
class Base{
public:
    void method (int i){
        cout<<i<<endl;
    }
};

Base * getMe(){
    static  Base b;
    return &b;
};

void f (){
for (int i=0;i<1000;i++)
    getMe()->method(i);
};

int main()
{
    f();
}

