#include <iostream>
int main() {
    int a=0;
    int b=1;
    for (int i=1; i<=10; i=i+2) {
        if (b % 2==0)
        {
            b=a+b;
        }
        else {
            b= a;
            a= a+b;
            b= b+a;
        }
        std::cout << i << ':' << a << '+' << b << '=' << a + b << std::endl;
    }
}
