#include <iostream>
struct MyStruct
{
    int x;
};
int test(MyStruct &tmp)
{
    tmp.x = 42;
    return 42;
}
int main()
{
    MyStruct y;

    test(y);
    test(&(y));
    test(const_cast<MyStruct &>(y));
}
 
