#include <iostream>
int main() {
    int a = 0;
    int b = 1;
    for(int i = 1; i <= 5; i = i + 2) {
        a = a + b;
        b = b + a;
        std::cout << i << ':' << b << '=' << a << std::endl;
    }
    return 0;
}
/*
