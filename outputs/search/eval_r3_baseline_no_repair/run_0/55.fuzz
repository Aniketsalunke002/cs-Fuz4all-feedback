    p2.reset(new T);
    p2.reset(new T);
    p2.reset(new T);
    T* o = new T;
    T* o1 = new T;
}

int main()
{
    testfunc(1);
    int a = 1;
    testfunc(a);
    testfunc2(1);
    int b = 1;
    testfunc2(a);
    int c = 1;
