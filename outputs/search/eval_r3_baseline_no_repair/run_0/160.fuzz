#include <iostream>
int main(int argc, char **argv) {
    int sum = 0;
    for (int k=0;k<20;k++) {
        std::cout << "input: ";
        for (int i=0;;i++) {
            std::cout << i << " ";
            int c = calc(i);
            std::cout << c << " ";
            for (int j=0;j<c;j++) sum += i;
            if (i > 9) break;
        }
        std::cout << "\nsum=" << sum << "\n";
    }
    return 0;
}
