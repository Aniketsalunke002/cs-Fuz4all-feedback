#include <iostream>
int getint();
int f(int i);
int main(int argc, char **argv) {
    int i = i + 1;
    printf("%d\n", f(argc));
     
    i = 7;
     
    printf("%d\n", f(argc));
}
 
#include <iostream>
int getint();
int f(int i);
int main(int argc, char **argv) {
    int i = i + 1;
    printf("%d\n", f(argc));
    if(argc > 0)
        printf("%d\n", argc);
    else
        return argc;
}
