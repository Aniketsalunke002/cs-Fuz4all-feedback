#include <iostream>
int calc(int a1);
int main(int argc, char **argv) {
  int sum = 0;
  std::cout << "input: ";
  for (int i=0;;i++) {
    std::cout << i << " ";
    for (int j=1;j<=i;j++) {
      sum += calc(j);
    }
    if (i > 8) break;
  }
  std::cout << "sum=" << sum << "\n";
  return 0;
}
 
