#include <iostream>
int main()
{
    short x = 4;
    float f = 13;
    f /= x;
    std::cout << f << std::endl;
    std::cout << "Done" << std::endl;
    return 0;
}
 
#include <iostream>
int main()
{
    std::cout << "HelloWorld" << std::endl;
    for (int i = 0; i < 10; ++i)
    {
        std::cout << "Iteration " << i << std::endl;
    }
    std::cout << "Done" << std::endl;
    return 0;
}
 
#include <iostream>
int main()
{
    std::cout << "Hello world" << std::endl;
    unsigned int i = 0;
    while (i < 10)
    {
        std::cout << "Iteration " << i << std::endl;
        ++i;
    }
    std::cout << "Done" << std::endl;
    return 0;
}