#include <iostream>
static const int val1 = 2, val2 = 16, val3 = 1024, val4 = 9<<1;
#if 0
enum {VAL1, VAL2}
#endif
static const int mut1 (int x) {
    return x*2;
}
static const int mut2 (int x) {
    return 2*x*x;
}
static const int mut3 (int x) {
    return 2*x*x+2*3;
}
static const int mut4 (int x) {
    return 2*x*x+2*3+4;
}
int calc(int a1) {
    int c = 1;
    for (int i = 0; i <= a1; i++ ) c += i;
    return c;
}
int main(int argc, char **argv) {
    int a = 1;
    std::cout << "a=" << a << "\n";
    for (int i=0;;i++) {
        a *= 2;
        if (i > 6) {
            mut2(i);
            mut3(i);
            mut4(i);
            break;
        } else if (i % 2 == 0 || i % 4 == 0) {
            mut1(i);
        } else {
            mut3(i);
        }
        a *= i;
        std::cout << "a=" << a << "\n";
    }
    std::cout << "a=" << a << "\n";
    std::cout << "input: ";
    for (int i=0;;;i++) {
        std::cout << i << " ";
        if (i > 6) {
            mut2(i);
            break;
        } else if (i%2 == 0) {
            mut1(i);
        } else {
            mut3(i);
        }
        sum += calc(i);
    }
    std::cout << "sum=" << sum << "\n";
    return 0;
}
