#include <map>
#include <vector>
#include <stdio.h>
struct A {
  int x = 0;
};

int getint() {
   
  int x = -1;
  char c = -1;
  std::cin >> x;
  std::cin >> c;
  std::cin.ignore(1000, '\n');
  return x;
}

struct B {
    A my;
};

int f(int i) {
    std::map<B, B> x;
    A y;
    B b;

    y.x = 4;
    b.my = y;
    x[b] = b;
    printf("%d\n", b.my.x);
    return 0;
}
 
 

