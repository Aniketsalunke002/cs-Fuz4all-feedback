#include <iostream>
int main(int argc,char **argv) {
  unsigned int size;
  unsigned int count;
  std::cin >> size;
  std::cin >> count;
   
  char arr[size];
  for (int i = 0; i < count; i++) {
    arr[i] = 1;
  }
  for (int i = 0; i < size; i++) {
    std::cout << arr[i];
  }
  return 0;
}
 
