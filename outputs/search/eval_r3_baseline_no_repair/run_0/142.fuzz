#include <iostream>
long calc(int a1);
long main(int argc, char **argv) {
  long sum = 0;
  std::cout << "input: ";
  for (int i=0;;i++) {
    std::cout << i << " ";
    sum += calc(i);
    if (i > 8) break;
  }
  std::cout << "sum=" << sum << "\n";
  return 0;
}
 
#include <iostream>
long calc(int a1);
long main(int argc, char **argv) {
  std::cout << "input: ";
  int i = 0;
  while (i <= 8) {
    std::cout << i << " ";
    i++;
  }
  std::cout << "sum=" << i << "\n";
  return 0;
}
