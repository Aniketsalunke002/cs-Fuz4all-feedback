#include <iostream>
int main(int, char **argv) {
    int i = 0, j = 0, k = 0, l = 0;
    int a, b;
    if (i) {
        a = 5;
    }
    if (j) {
        b = 5;
    }
    ++k;
    if (!k) {
        if (l) {
            a = b;
        } else {
            b = a;
        }
    }
    printf("%d %d\n", a, b);
    return 0;
}
 
