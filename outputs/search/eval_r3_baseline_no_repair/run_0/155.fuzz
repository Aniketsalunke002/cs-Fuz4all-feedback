#include <iostream>
int calc(int a1) {
    int c = 1;
    for (int i = 0; i <= a1; i++ ) c += i;
    return c;
}
int main(int argc, char **argv) {
    int sum = 0;
    std::cout << "input: ";
    for (int i=0;;i++) {
        std::cout << i << " ";
        sum += calc(i);
        if (i > 8) break;
    }
    std::cout << "sum=" << sum << "\n";
    return 0;
}
 
