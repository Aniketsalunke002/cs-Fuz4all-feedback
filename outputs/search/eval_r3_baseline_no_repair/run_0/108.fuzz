#include <iostream>
int f(int a) {
  return a;
}
int main(int argc, char **argv) {
  int b;
  b = f(1);
  exit(0);
}
 

#include <iostream>
int count(int a) {
  return __builtin_popcount(a);
}
int main(int argc, char **argv) {
  int b;
  b = count(255);
  exit(0);
}

#include <iostream>
int odd(int a) {
  return a & 1;
}

unsigned int mask(unsigned int a) {
  return __builtin_popcount(a & 0xFFFF) + 1;  
}
int main(int argc, char **argv) {
  for(int i = 0; i < 15; ++i)
    std::cout << mask(i) << std::endl;
  exit(0);
}

int main(int argc, char **argv) {
  int a, b;
  b = 0;
  a = 409;
  for(int i = 4; i < 16; i++)
    b |= (1 << i);  
  if(odd(a)) {
    std::cout << a << " is odd\n";
  } else {
    std::cout << a << " is even\n";
  }
  exit(0);
}
