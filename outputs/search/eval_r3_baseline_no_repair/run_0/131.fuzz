#include <iostream>
int getint();
int main(int argc, char **argv) {
  int elements = 3;
  for (int ii = 0;;) {
    static int original = -1;
    int old = elements;
    if (original < 0) original = elements;
    if (elements > 0)
      elements += getint();
    else 
      elements = 0;
    std::cout << original << " -> " << old << " (" << getint() << ")\n";
    std::cout << elements << "\n";
    if (elements == old) {
      std::cout << "Last call of edit: " << original << "\n";
      break;
    }
    if (original == 1) original = -2;
  }
  return 0;
}
