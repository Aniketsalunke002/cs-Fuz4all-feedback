#include <iostream>
int main(int argc, char **argv) {
  int counter = 1, step = 6;
  while (counter < 100) {
    for (int i = step; i > 0;) {
      std::cout << i;
      i -= step;
    }
    std::cout << std::endl;
    counter = counter + step;
  }
  exit(0);
}
 
