#include <iostream>
#include <string>
int main(int argc, char **argv) {
  const int max = 1000;
  int current = 2;
  while (true) {  
                  
    bool is_not_prime = false;
    for (int i = 0; i < current; i++) {
      if (current % (2 + i) == 0) {
        is_not_prime = true;
        break;
      }
    }
    if (is_not_prime) {
       
      current++;
    } else {
       
      std::cout << current << std::endl;
      break;
    }
  }
  exit(0);
}
