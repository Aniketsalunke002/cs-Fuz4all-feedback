#include <iostream>
static const int val1 = 1, val2 = 2, val3 = 1024, val4 = 1<<2;
const int mut1 (int x) {
    return x*2;
}
int calc(int a1) {
    int c = 1;
    for (int i = 0; i <= a1; i++ ) c += i;
    return c;
}
int main(int argc, char **argv) {
    int sum = 0;
    std::cout << "input: ";
    for (int i=0;;i++) {
        std::cout << i << " ";
        if (i > 6) {
            mut1(i);  
            break;
        } else if (i&1) {
            val1 = val1 + val2;  
        } else {
            val3=val3*val2;  
        }
        sum += calc(i);
    }
    std::cout << "sum=" << sum << "\n";
    return 0;
}
