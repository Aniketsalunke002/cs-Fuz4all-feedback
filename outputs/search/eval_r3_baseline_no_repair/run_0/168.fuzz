#include <iostream>
#include <cassert>

 

using namespace std;
int a[1 << 24];
int main(int argc, char **argv) {
    int i, j = 0xfff, k = 0xd1;
    memset(a, 0, sizeof a);

    for(i=0; i<1<<20; i++) a[i] = i;
    for (i=0; i<1<<10; i++) {
        if(a[j]==4711) cout << "found at "<<i<<endl;
        j = (k += 2) & (1<<24 - 1);
    }
    return 0;
}

