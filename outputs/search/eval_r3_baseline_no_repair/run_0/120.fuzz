#include <iostream>
template <typename T> inline void get_elements(T& elem, int count) { while (count--) std::cin >> elem; }
template <typename T> inline void create_and_save(T& elements, int count);
 
void create_and_save(short& elements, int count) {
  std::cout << count << " " << (count - 1) << " ";
   
  unsigned long sum = 0;
  for (int i = 0; i < count; ++i) {
    short elem;
    get_elements(elem, 1);
    std::cin > elem;
    sum += elem;
  }
  short average = sum/count;
  std::cout << (int) sum << " " << (int) average << " ";
   
  elements = sum;
  get_elements(elements, 1);
  std::cin >> elements;
  elements = average;
  get_elements(elements, 1);
  std::cin >> elements;;
}
 
