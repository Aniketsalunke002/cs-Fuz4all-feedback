#include <iostream>
int getint();
int main(int argc, char **argv) {
  int elements = 3;
  for (;;) {
    int elements = 0;
    if (elements < 0) elements = 0;
    if (elements > 0)
      elements += getint();
    else 
      elements = 0;
    std::cout << elements << "\n";
    if (elements == 1) elements = -2;
    if (elements == 3) break;
  }
  return 0;
}
