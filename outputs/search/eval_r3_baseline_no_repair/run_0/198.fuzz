#include <iostream>
int main(int argc, char **argv) {
  int counter = 1, step = 6;
  if (counter > 100) {
    return 0; 
  } 
  while (counter <= 100) {
    int i = 1;
    if (i > step) {
      std::cout << 0;
      i = 1;
    }
    while (i<= step) {
      std::cout << i / step;
      i = i + 1;
    }
    std::cout << std::endl;
    counter = counter + 1;
  }
  exit(0);
}
