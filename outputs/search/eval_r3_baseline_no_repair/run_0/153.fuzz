#include <iostream>
int sum(int a1) {
    int c = 1;
    for(int i = 0; i!= a1; i++) c = c + i;
  return c;
}
int main(int argc, char **argv) {
    int sum = 0;
    std::cout << "input: ";
    for (int i=0;;i++) {
        std::cout << i << " ";
        sum += sum(i);
        if (i > 8) break;
    }
    std::cout << "sum=" << sum << "\n";
    return 0;
}
