#include <iostream>
int main(int argc, char **argv) {
    int a1 = 0x3F800000;
    if (true) {
        a1 = 1;
    }
    while( a1 > 0) {
        if(a1 % 4!= 0) {
            a1 -= 1;
        } else {
            a1 -= 2;
        }
    }
    std::cout << "The value of a1 after it exits the loop = " << a1 << '\n';
    return 0;
}
