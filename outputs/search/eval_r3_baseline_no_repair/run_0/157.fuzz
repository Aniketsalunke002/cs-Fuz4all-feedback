#include <iostream>
int main(int argc, char **argv) {
    int sum = 0;
    std::cout << "input: ";
    for (int i=0; i < 1000; i++ ) {
        std::cout << i << " ";
        if (sum > 30000) {
            sum -= 49;
            std::cout << "+43\n";
        } else if (sum > 20000) {
            sum -= 42;
        std::cout << "+42\n";
        } else if (sum > 10000) sum -= 33;
        else if (sum > 5000) sum -= 1;
        else sum -= 5;
    }
    std::cout << "sum=" << sum << "\n";
    return 0;
}
 
#include <iostream>
int calc(int a1) { 
    int c = 1;
    for (int i = 0; i <= a1; i++ ) c += i;
    return c;
}
int main(int argc, char **argv) {
    {
        int sum = 0;
        std::cout << "input: ";
        for (int i=0;;i++) {
            std::cout << i << " ";
            sum += calc(i);
            if (i > 8) break;
        }
        std::cout << "sum=" << sum << "\n";
    }
    {
        int sum = 0;
        std::cout << "input: ";
        for (int i=0; i < 1000; i++ ) {
            std::cout << i << " ";
            if (sum > 30000) {
                sum -= 49;
                std::cout << "+43\n";
            } else if (sum > 20000) {
                sum -= 42;
                std::cout << "+42\n";
            } else if (sum > 10000) sum -= 33;
            else if (sum > 5000) sum -= 1;
            else sum -= 5;
        }
        std::cout << "sum=" << sum << "\n";
    }
    return 0;
}
 
#include <iostream>
int calc(int a1) {
    int c = 1;
    for (int i = 0; i <= a1; i++ ) c += i;
    return c;
}
int main(int argc, char **argv) {
    for (int i=0; i < 1000; i++ ) {
        int sum = calc(i);

        std::cout << "in: "
                  << i << " "
                  << "sum before while:" << sum << "\n";

        while (sum > 10) {
            sum -= 5;
            std::cout << "+5: " << sum << "\n";
        }
        std::cout << "in: "
                  << i << " "
                  << "sum=" << sum << "\n";
    }
    return 0;
}
 
