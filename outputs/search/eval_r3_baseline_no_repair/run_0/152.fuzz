#include <iostream>
int main (int argc, char **argv) {
  int sum = 0;
  for (int i=0;;i++) {
    sum = sum + (i * i);
    if (i > 8) break;
    if (i == 7) {   
      std::cout << "We're getting here, but we shouldn't!\n";
    }
    std::cout << i << "\n";
  }
  std::cout << "Sum of the squares of the first 9 integers is: " << sum << "\n";
  return 0;
}
 
#include <iostream>
#include <exception>
using namespace std;
class my_exception : public exception { };
void my_fun() {
  throw my_exception();
}
int main() {
  int i=0;
  try {
    try {
      my_fun();
    } catch (my_exception &) {
      throw;
    }
    
    throw my_exception();
  } catch (const my_exception &) {
    std::cout << "Exception: " << i << "\n";
  }
  return 0;
}
