#include <iostream>
int main(int argc, char* argv[])
{
    short n_bytes, i1, i2;
    short* x1, *x2;
    x1 = (short*) malloc(n_bytes*sizeof(short));
    for (i1=0; i1<n_bytes; i1++)
    {
        x1[i1] = i1;
    }
    x2 = (short*) malloc(38*sizeof(short));
    for (i1=0; i1<(38*sizeof(short)); i1++)
    {
        x2[i1] = 16+i1;
    }
    std::cout << "Done" << std::endl;
    return 0;
}
