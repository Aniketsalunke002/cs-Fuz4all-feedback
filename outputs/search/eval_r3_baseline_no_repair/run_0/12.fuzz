#include <iostream>
int main(int argc, char* argv[])
{
    char * ptr = new char [80];
    char c1,i;
    for (c1='A', i=0; i<80; c1++, i++)
    {
        ptr[i] = c1;
    }
    for (i=0; i<80; i++)
    {
        std::cout << ptr[i];
    }
    return 0;
}
 
#include <iostream>
#include <string.h>
int main(int argc, char* argv[])
{
    char s[]="abcdabcdabcdabcd";
    char *ptr;
    char *p_temp;
    std::string res="";
    ptr=s;
    int ctr;
    std::cout<<"Pointer on array :\n";
    for(ctr=0 ; ctr<strlen(s); ctr++)
    {
        std::cout<<ptr[(ctr*5)]<<"\t";
    }
    std::cout<<"\n";
    ptr=(char*)calloc(strlen(s),sizeof(char));
    if(ptr==NULL);
    std::cout<<"allocating memory for dynamic array \n";
    printf("Memory address of pointer on alloced array: %p\n",ptr);
    p_temp=ptr;
    ctr=0;
    while(( *ptr++ = s[ctr])!=NULL)
    {
        ctr++;
    }
    std::cout<<"\nMemory Address when array is de-allocated: %p\n";
    res = p_temp;
    return 0;
}
 
#include <iostream>
int main(int argc, char* argv[])
{
    char *s;
    char a1 [] = {'A', 'B', 'C', 'D', 'E', 'F'};
    char a2 [] = {'a', 'b', 'c', 'd', 'e', 'f'};
    s = new char [7];
    s = a1;
    strcpy (s, a2);
    std::cout << s << std::endl;
    delete[] s;
    return 0;
}
 
