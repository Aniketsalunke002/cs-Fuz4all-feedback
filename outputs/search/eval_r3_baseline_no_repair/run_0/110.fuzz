#include <iostream>
#include <math.h>
#include <stdio.h>
long getint() {
  long res = 0;
  int ch = getchar();
  while (ch =='')
    ch = getchar();
  bool f = false;
  while (ch >= '0' && ch <= '9') {
    if (f)
      res *= 10;
    res += ch - 48;
    f = true;
    ch = getchar();
  }
  return res;
}
int f(int i);
int main(int argc, char **argv) {
  long n = getint();
  for (int i = 0; i < n; i++) {
    printf("%d: %d\n", f(argv[2 + i*3]), getint());
  }
  exit(0);
}

