#include <iostream>
int main()
{
    short x = 0;
    short y = 100;
    short z;
    short n_bytes;
    y = 4098;
    n_bytes=x/y;
    x=240;
    z = x/y;
    std::cout << "Done" << std::endl;
    return 0;
}
 
