#include <iostream>
int main() {
    char s[] = {"Hello World!"};
    s[12]='?';
    std::cout <<  s;
    return 0;
}
 
#include <iostream>
#include <cassert>
int main() {
    char buf[12];
    char* end;
    std::cin >> buf;
    long double x=0;
    while (*buf) {
        x = x*10 + (*buf++ - '0');
    }
    int a = (int)x;
    assert (a + 12 == 24);
    std::cout << a;
    return 0;
}

