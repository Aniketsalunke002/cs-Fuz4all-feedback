#include <iostream>
int main(int argc, char* argv[])
{
    short n_bytes, i1, i2;
    short* x1, *x2;
    std::cout << "sizeof(x1)==" << sizeof(x1) << std::endl;
    std::cin >> n_bytes;
    x1 = new short[n_bytes];
    for (i1=0; i1<n_bytes; i1++)
    {
        x1[i1] = i1+5;
    }
    std::cout << "sizeof(x1)==" << sizeof(x1) << std::endl;
    std::cin >> i1;
    delete[] x1;
    std::cout << "Done" << std::endl;
    return 0;
}
