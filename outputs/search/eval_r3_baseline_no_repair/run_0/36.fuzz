#include <iostream>
int main()
{
    short x = 0;
    short y = 100;
    short z;
    short n_bytes, n_remainder;
    y = 4098;
    n_bytes = x / y;
    n_remainder = x % y;
    x = 240;
    z = x / y;
    std::cout << "Before x=" << x << " and after x=" << y << std::endl;
    return 0;
}
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
