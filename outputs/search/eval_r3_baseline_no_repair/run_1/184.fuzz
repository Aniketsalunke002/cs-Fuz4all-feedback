#include <iostream>
using namespace std;
int main() {
 struct Node {
   int data;
   struct Node *next;
 };
 void printList(struct Node *h) {
   struct Node *temp = h;
   while(temp->next!=h) {
      cout << temp->data <<" ";
      temp=temp->next;
   }
   cout << endl;
 }
 void insert(struct Node **h, int x) {  
   struct Node* t;
   t = (Node*) malloc(sizeof(struct Node));
   t->data = x;
   t->next = *h;
   *h = t;
 }
 int del(struct Node **h) {  
    
   if ((*h)!= NULL) {
     struct Node *t;
     t = *h;
     *h = (*h)->next;
     free(t);
     return t->data;
   }
   return -1;
 }
 struct Node* reverse(struct Node *h0) {  
   struct Node *h1=NULL;
   while(h0) {
     insert(&(h1),h0->data);
     h0=h0->next;
   }
   return h1;
 }
 struct Node* make(int x) {
   struct Node *h=(Node*)malloc(sizeof(struct Node));
   h->data=x;
   h->next=h;
   return h;
 }
 
 struct Node* insertAfter(struct Node *h,int x) {  
   if (h==NULL) return NULL;
   struct Node *t;
   h->next=make(x);
   t = h->next;
   t->next=h;
   return h->next;
 }
 struct Node *deleteNode(struct Node *h)
 {
    struct Node *t;
    if(h==NULL || h->next == h) return NULL;
    else
    {
         
        t = h->next;
        while(t->next!= h)
        {
            t=t->next;
        }
         
        h->next = t->next;
        free(t);
        return h;
    }
 }
 
 struct Node* insertAtPosition(struct Node *h,int pos,int x) {
   struct Node *t, *t4;
    
   int len = 0;
   t = h;
   while(t!=h) {
     ++len;
     t=t->next;
   }
   if (pos>len) return NULL;
   t=h;
   while (pos-- > 0)
     t=t->next;
   t4 = t->next;
   t->next=make(x);
   ((t->next)->next)=t4;
   return h;
 }
 void freeList(struct Node *h)
 {
   while(h!= NULL)
   {
       struct Node *t;
       t = h;
       h = h->next;
       free(t);
   }
 }
 
 int main(){
    struct Node *h = NULL;
    h=make(1);
    
    h->next = make(2);
    h->next->next = make(3);
    
    cout<<"Original Linked List:\n";
    printList(h);
    
    insertAtPosition(h,1,0);
    
    cout<<"Linked List after insertion at position 1:\n";
    printList(h);
    
    h = reverse(h);
    
    cout<<"Linked List after reversal:\n";
    printList(h);
    
     
    h = deleteNode(h);
    cout<<"Linked List after deleting 1st element:\n";
    printList(h);
    
    h = deleteNode(h);
    cout<<"Linked List after deleting 2nd element:\n";
    printList(h);
    
    h = deleteNode(h);
    cout<<"Linked List after deleting 3rd element:\n";
    printList(h);
    
     