#include <iostream>
using namespace std;

int main()
{
	double a;
	cin >> a;
	cout << (double)(2*a) << endl;
	return 0;
}
 
#include <iostream>
using namespace std;

int main()
{
	double a, b;
	cin >> a >> b;
	if ((a!= 0) && (b!= 0))
		cout << (double)(a / b) << endl;	
	else 
		cout << "N\n";
	return 0;
}
