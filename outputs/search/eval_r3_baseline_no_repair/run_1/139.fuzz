#include <iostream>
using namespace std;
int main()
{
	int sum=0;
	for(int i=1;i<21;i++)
	    sum+=i;
	cout<<sum;
	return 0;
}
 
#include <iostream>
using namespace std;
int main()
{
	int n,i,sum=0,num;
	cout<<"Enter the number:";
	cin>>n;
	for(i=1;i<=n;i++)
	{
	    cin>>num;
	    sum+=num;
	}
	cout<<sum;
	return 0;
}
#include <iostream>
using namespace std;
int main()
{
    int n,sum=0;
    cout<<"Enter the number:";
    cin>>n;
    if(n>0)
    {
        for(int i=1;i<=n;i++)
            sum+=i;
        cout<<sum;
    }
    else
        cout<<"Invalid number";
    return 0;
}
