#include <iostream>
class Complex {
  int _a, _b;
 public:
  Complex(int a, int b) :_a(a), _b(b) {}
  Complex() : _a(0), _b(0) {}
  Complex(const Complex &complex) {
    _a = complex._a;
    _b = complex._b;
  }
  void operator=(const Complex &complex) {
    if (this!= &complex) {
      _a = complex._a;
      _b= complex._b;
    }
  }
  int *ptr() {
    return &_a;
  }
  static int sptr() {
    return 10;
  }
};
static int sptr() {
  return 10;
}
int main() {
  Complex c1(1, 2);
  Complex c2(c1);
   Complex *c3 = &c1;
  printf("%d %d %d\n", c1.ptr()[0], c2.ptr()[0], c3->ptr()[0]);
  printf("%d\n", sptr());
  return 0;
}
