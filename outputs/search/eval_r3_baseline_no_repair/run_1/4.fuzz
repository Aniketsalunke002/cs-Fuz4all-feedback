template<typename T>
const T& max(const T& a, const T& b) {
    return b < a? a : b;
}

template <typename T1, typename T2, typename C = std::less<T1> >
void test(const T1& a, const T2& b, const C& comp = C())
{
    if (comp(a,b)) { std::cout << "max(" << a << ", " << b << ") = " << b << '\n';} else { std::cout << "max(" << a << ", " << b << ") = " << a << '\n';}
}

void test(const std::string& a, const std::string& b, const bool & ignore = false)
{
    std::cout << "The length of " << a << " : " << a.length() << std::endl;
    std::cout << "The length of " << b << " : " << b.length() << std::endl;
    std::cout << "The equality: " << a == b << ", should be: " <<!ignore << std::endl;
}

void test(const std::string& a, const std::string& b, const char & ignore = '.'){
    if (a.find(ignore) == std::string::npos && b.find(ignore) == std::string::npos) { std::cout << "The equality: " << a == b << ", should be: " << false << std::endl; } else
                                                                                { std::cout << "The equality: " << a == b << ", should be: " << true << std::endl;}
}

