class MyString {
public:
    MyString(const char & c) {};
    MyString(const MyString &) {std::cout << "Copy constructor: MyString(const MyString &)" << '\n';};
    MyString(const std::string & s) {std::cout << "Copy constructor: MyString(const std::string &)" << '\n';std::cout << *this;};
    ~MyString() {std::cout << "~MyString()" << '\n';};
    MyString & operator++() {std::cout << "MyString::operator++(int)" << '\n'; std::cout << *this;return *this;};
    void PrintString(const char * msg, const MyString & str) { std::cout << msg << str << '\n'; }
};

struct MyBigString
{
    int length;
    char * buff;
    ~MyBigString()
    {
        delete buff;
        buff = nullptr;
    }
};

