#include <iostream>
using namespace std;
#include <iomanip>
int main()
{
	cout << fixed << showpoint << setprecision(2);
	cout << 2.34*7 << "( 2.34 * 7 )" << '\n';
	cout << 2.34/7 << "( 2.34 / 7 )" << '\n';
	cout << sqrt(2) << "( sqrt( 2 )" << '\n';
	return 0;
}
 
 
#include <iostream>
#include <cmath>
using namespace std;
#include <iomanip>
float avg(int x,int y)
{
	return (x+y)/2;
}
float avg(float x,float y)
{
	return (x+y)/2;
}
float add(int x, float y)
{
	return (float)x+(float)y;
}
float sub(int x, float y)
{
	return (float)x-(float)y;
}
int main()
{
	int x,y;
	float z;
	cin >> x >> y;
	cout<<avg(x,y)<<endl<<add(x, avg(x,y))<<endl<<sub(x, avg(x,y));
	cin >> z;
	cout<<avg(z,avg(x,y));
	int arr[5]{1,2,3,4,5};
		for(int i=0;i<5;i++)
	{
		cout<<arr[i]<<'\t';
	}
	
	return 0;
}