}
   
   
   
   
   
   
 
#include <iostream>
using namespace std;
int main ()
{
	short int num1 = 5, num2 = 4, num3 = 0;
	cout << "A = " << num1 << "  B = " << num2 << "  C = " << num3 << endl;
	num2 = num1 + num2 + 3;
	cout << "A = " << num1 << "  B = " << num2 << "  C = " << num3 << endl;
	num3 = num1 - num2 - 2;
	num1++;
	num3 = 25 - num3;
	cout << num1 << " + " << num2 << " = " << num3;
	return 0;
}
 
 
#include <iostream>
using namespace std;
int main ()
{
	short int num1 = 5, num2 = 4, num3 = 0;
	cout << "A = " << num1 << "  B = " << num2 << "  C = " << num3 << endl;
	num2 = num1 + num2 + 3;
	cout << "A = " << num1 << "  B = " << num2 << "  C = " << num3 << endl;
	num3 = num3 - num2 - num1 + 2;
	num1++;
	num3 = 25 - num3;
	cout << num1 << " + " << num2 << " = " << num3;
	return 0;
}

 
