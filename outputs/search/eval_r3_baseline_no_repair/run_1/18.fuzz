#include <iostream>
using namespace std;
int main()
{
	int grade = 95;
	int bonus = 0;
	if((grade >= 90) && (grade!= 100)) bonus = 50;
	if((grade >= 85) && (grade < 90)) bonus = 40;
	if((grade >= 70) && (grade <85)) bonus = 30;
	if((grade >= 65) && (grade < 70)) bonus = 25;
	if(bonus > 0) cout << bonus << endl;
	else cout << "no Bonus" << endl;
	if((grade = 60)) cout << "grade passed." << endl;
	return 0;
}
 
