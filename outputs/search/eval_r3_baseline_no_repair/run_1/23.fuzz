#include <iostream>
using namespace std;
int main()
{	unsigned int a = 2;  
	int b = -2 ;  
	a = a+1;
	b = b+1;
	cout << "a=" << a << endl;
	cout << "b=" << b << endl;
	a = a+2;
	b = b+2;
	cout << "a=" << a << endl;
	cout << "b=" << b << endl;
	a++;
	b--;
	cout << "a=" << a << endl;
	cout << "b=" << b << endl;
	return 0;
}
