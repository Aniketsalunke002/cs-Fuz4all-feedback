#include <iostream>
class C {
 public:
  C();
  ~C();
  int count;
};
C::C() : count(0) {
  count++;
}
C::~C() {
  count--;
}
int main() {
  C c1;
  C c2;
  C c3(c1);
  std::cout << c1.count << c2.count << c3.count << '\n';
  return 0;
}
 
