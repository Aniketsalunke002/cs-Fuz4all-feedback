#include <iostream>
using namespace std;
const double PI = 3.14159;
int main()
{
	cout<<"Hello, World! I am a mutated program! My mutation method was to modify the PI constant!\n";
	cout<<endl<<PI<<'\t'<<2*PI<<endl<<1/PI<<endl;
   cout<<(PI!= 3*PI)<<endl;  
	return 0; 
}
 
#include <iostream>
using namespace std;
int main(int argc,char*argv[])
{
