#include <iostream>

using namespace std;

int main()
{
    int counter = 1;
    while (counter > 0)
    {
        int a;
        cin >> a;
        if (a > 0)
            counter++;
    }

    cout << "The counter is " << counter << endl;
    return 0;
}

#include <iostream>
using namespace std;

int main()
{
    int i = 10;
    while (i <= 20)
    {
        if (i % 2 == 0)
        {
            cout << i << " ";
        }
        i++;
    }
}

#include <iostream>
using namespace std;

int main()
{
    int rows = 20, cols = 20, spaces = 4;
    for (int i = 0; i < rows; i++)
    {
        for (int j = 0; j < cols; j++)
        {
            if ((i == 0 || j == 0 || i == rows - 1 || j == cols - 1) && (i % 2 == 0 || j % 2 == 0))
                cout << "*";
            else
            {
                if (i % 2 == 0 && j % 2 == 0)
                    cout << "a";
                else if (i % 2!= 0 && j % 2!= 0)
                    cout << "b";
                else if (i % 2 == 0 && j % 2!= 0)
                    cout << "c";
            }
        }
    }
    return 0;
}