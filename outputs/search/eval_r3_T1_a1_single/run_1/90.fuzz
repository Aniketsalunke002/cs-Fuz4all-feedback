	void forkRandomChild();
	 
	 
	stringstream ss;
	int i = 0;
	while (i++ < 10000000) {
		string input;
		double temp;
		ss << "hello" << " " << "world" << endl;
		input = ss.str();
		ss.clear();
		input = readInputString(cout);
	}
		forkRandomChild();
	}
	void forkRandomChild()
	{
		int pid,status;
		pid = fork();
		if(-1 == pid)
		{
		cout << "failed fork" << endl;
		return;
		}
		else if(0 == pid)
		{
			cout << "I am child " << getpid()<<  " and my parent is " << getppid();
			exit(0);
		}
		else if(pid > 0)
		{
			cout << "I am parent " << getpid() <<  " and I created process " << pid;
		}
		
		
		
		wait(&status);
	}
	extern string readInputString(istream&);
	extern void readInputDouble(istream&,double&);
	extern void createRandom(double&);
	string readInputString(istream& is)
	{
		char temp;
		string input;
		temp = is.get();
		while (isdigit(temp) || temp == '-') {
			
			input += temp;
			temp = is.get();
		}
		if (1!= is.eof()) {
			is.putback(temp);
		}
		return input;
	}
