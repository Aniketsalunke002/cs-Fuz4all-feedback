#include <iostream>
using namespace std;
class Point {
	public:
		Point(int,int);
		virtual ~Point();
		int x;
		int y;
};
Point::Point(int val1, int val2):x(val1),y(val2)
{
}
Point::~Point()
{
}
	class MutatedPoint : public Point
{
public:
	MutatedPoint(int,int);
	void printPoint();
	virtual ~MutatedPoint();
	private:
		int x;
		int y;
};
 

MutatedPoint::MutatedPoint(int _x,int _y):Point(_x,_y)
{
}

void MutatedPoint::printPoint()
{
	cout << " x = " << x << " y = " << y << endl;
}
MutatedPoint::~MutatedPoint()
{
}

int main()
{
	MutatedPoint mPoint(50,48);
	mPoint.x += 10;
	mPoint.printPoint();
	return 0;
}
 
