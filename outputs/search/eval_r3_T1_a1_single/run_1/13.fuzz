#include <iostream>
#include <vector>

using std::cout;
using std::endl;

int main()
{
    auto numbers = std::vector { 1, 2, 3 };

    for(const auto &number : numbers)
        cout << number << endl;

    cout << std::endl;

    for(auto number : numbers)
        cout << number << endl;


    return 0;
}