#include <iostream>
using namespace std;
class Point {
public:
	Point(int,int,int,int);
	virtual ~Point();
	int x;
	int y;
	int z;
	int w;
};
Point::Point(int val1,int val2,int val3,int val4):x(val1),y(val2),z(val3),w(val4)
{
}
Point::~Point()
{
}
class MutatedPoint : public Point
{
public:
	MutatedPoint(int,int);
	void printPoint();
	virtual ~MutatedPoint();
};
MutatedPoint::MutatedPoint(int val1,int val2):Point(val1,val2,1,2)
{
	z = 12;
}
void MutatedPoint::printPoint()
{
	cout << " x = " << x << " y = " << y << " z = " << z << " w = " << w << endl;
}
MutatedPoint::~MutatedPoint()
{
}
