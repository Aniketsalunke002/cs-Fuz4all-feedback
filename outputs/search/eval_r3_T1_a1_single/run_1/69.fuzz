#include <iostream>
using namespace std;
static int side;
static int i;
int main()
{
    cout<<"Enter the side of rectangle";
    cin>>side;
    for( i= 1; i<= side; i++)
    {
        for(int j=1; j<= side; j++){
            cout<< "* ";
        }
        cout<<endl;
    }
    return 0;
}
