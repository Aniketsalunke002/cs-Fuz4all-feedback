#include <iostream>

using namespace std;
class Point {
public:
	Point(int,int,int,int);
	virtual ~Point();
	int& getx();
	int& gety();
	int& getz();
	int& getw();
	int&& stealx();
	int&& stealy();
	int&& stealz();
	int&& stealw();
	int x;
	int y;
	int z;
	int w;
};
Point::Point(int val1,int val2,int val3,int val4):x(val1),y(val2),z(val3),w(val4)
{
}
Point::~Point()
{
}
int& Point::getx()
{
	return x;
}
int& Point::gety()
{
	return y;
}
int& Point::getz()
{
	return z;
}
int& Point::getw()
{
	return w;
}
int&& Point::stealx()
{
	return std::move(x);
}
int&& Point::stealy()
{
	return std::move(y);
}
int&& Point::stealz()
{
	return std::move(z);
}
int&& Point::stealw()
{
	return std::move(w);
}
void fuzz(Point& obj)
{
	int x = obj.stealx();
	int y = obj.stealy();
	int z = obj.stealz();
	int w = obj.stealw();
}