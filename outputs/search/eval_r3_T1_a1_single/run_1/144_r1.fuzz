#include <iostream>

#include <fstream>
using namespace std;
void main()
{
	ifstream f("point.dat");
    int x, y;
    if(!f.good())
    {
        return;
    }
    f >> x >> y;
    cout << '(' << x << ',' << y << ')' << endl;
    f.close();
}
