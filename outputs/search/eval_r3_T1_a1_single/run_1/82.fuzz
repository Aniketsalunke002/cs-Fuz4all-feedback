#include <iostream>
using namespace std;
int main()
{
    int count[10];
    cout << "Enter values in the array ";
    for (int i=0; i!=10; i++)
    {
        cin >> count[i];
    }
    cout << "The new values are ";
    for (int i=0; i!=10; i++)
    {
       count[i]=count[i]-10; 
       cout << count[i] << " ";
    }
    
}