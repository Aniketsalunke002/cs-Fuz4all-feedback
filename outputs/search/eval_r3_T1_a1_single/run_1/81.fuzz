#include <iostream>
using namespace std;
struct Point
{
    Point(int,int);
    int x;
    int y;
};
Point::Point(int val1,int val2)
{
    x = val1;
    y = val2;
}
int main()
{
    Point myPoint(3,4);
    myPoint.x = 10;
    cout << myPoint.x <<endl<<endl;
}
 
