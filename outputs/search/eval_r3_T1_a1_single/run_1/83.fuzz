#include <iostream>
using namespace std;
struct Point
{
    Point(int,int);
    int x;
    int y;
};
Point::Point(int val1,int val2)
{
    x = val1;
    y = val2;
}
class MutatedPoint :public Point
{
    public:
        MutatedPoint(int,int);
        void printPoint();
};
MutatedPoint::MutatedPoint(int val1,int val2) :Point(val1,val2)
{

}
void MutatedPoint::printPoint()
{
    cout << x << " " << y << endl;
}
int main()
{
    MutatedPoint mPoint(50,48);
    mPoint.printPoint();
}
 
 
int main()
{
    string input;
    cin >> input;
    int i=0;
    int temp = -1;
    while(input[i]!= '\0')
    {
        cout << input[i] << " ";
        temp = input[i];
        i++;
    }
    cout << endl;
    i = 0;
    while(i!= temp)
    {
        cout << input[i] << " ";
        i++;
    }
}