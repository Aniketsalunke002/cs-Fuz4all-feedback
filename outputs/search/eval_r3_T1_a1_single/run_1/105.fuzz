#include <iostream>
#include <string.h>
using namespace std;
int main()
{
	string name = "Waqas ";
	cout << name << endl ;
	cout << name.length() << endl ;
	name[3] = 'q';
	name[4] = 'q';
	name[5] = 'q';
	name[6] = '\0';
	cout << name << endl ;
	return 0;
	
}
int main()
{
	int grade ;
	while(cin >> grade) {
      
		if(grade > 100) cout << "You have exceeded the range" << endl ;
		else if(grade < 0) cout << "Grade can not be negative" << endl ;
		else if(grade > 90) {
			cout << "You have a perfect grade " << grade << endl ;
		}
		else if(grade > 80) {
			cout << "You have an average grade " << grade << endl ;
		}
		else if(grade > 70) {
			cout << "You have a pass grade " << grade << endl ;
		}
		else cout << "You have a fail grade " << grade << endl ;
		 
    break ;
  }
  return 0;
}
