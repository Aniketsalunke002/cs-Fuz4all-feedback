#include <iostream>
using namespace std;
int main()
{
    int x=5, y=9;
    x++;
    cout<<"Value after x++";
    cout<<x;
    y*=2;
    cout<<"\nValue after y*=2";
    cout<<y;
    
    return 0;
}
 
void incrementing(int x)
{
    x++;
}

 
#include <iostream>
using namespace std;
int main()
{
    int x=5, y=9;
    incrementing(x);
    y=y*2;
    cout<<y;
    return 0;
}

