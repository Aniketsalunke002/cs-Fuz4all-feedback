#include <iostream>
using namespace std;

void print_scoreboard()
{
    cout << "Scoreboard:" << endl;
    for (int i=0; i<10; i++)
    {
        cout << "<Player " <<i << ">" << "  Score: " << 42 << "  Name: " << "12345" << endl;
        usleep(1000000);  
    }
}
int main()
{
    print_scoreboard();
}

