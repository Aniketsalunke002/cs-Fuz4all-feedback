#include <iostream>
using namespace std;
struct Point
{
    Point(int,int);
    int x;
    int y;
};
Point::Point(int val1,int val2)
{
    x = val1;
    y = val2;
}
class MutatedPoint : public Point
{
    public:
        MutatedPoint(int,int);
        void printPoint();
};
void MutatedPoint::printPoint()
{
    cout << x << " " << y << endl;
}
MutatedPoint::MutatedPoint(int val1, int val2) : Point(val1, val2)
{
}
int main()
{
    MutatedPoint mPoint(50, 48);
    mPoint.printPoint();
}
 
 
#include <iostream>
using namespace std;
struct Point
{
    Point(int,int);
    int x;
    int y;
};
Point::Point(int val1,int val2)
{
    x = val1;
    y = val2;
}
class MutatedPoint : public Point
{
    public:
        MutatedPoint(int,int);
        void printPoint();
        friend void printPoint(MutatedPoint &);

};
void MutatedPoint::printPoint()
{
    cout << x << " " << y << endl;
}
void printPoint(MutatedPoint &n)
{
    cout << n.x << " " << n.y << endl;
}
MutatedPoint::MutatedPoint(int val1, int val2) : Point(val1, val2)
{
}
int main()
{
    MutatedPoint mPoint(50, 48);
    mPoint.printPoint();
    printPoint(mPoint);
}
 
 
#include <iostream>
using namespace std;
struct Point
{
    Point(int,int);
    int x;
    int y;
};
Point::Point(int val1,int val2)
{
    x = val1;
    y = val2;
}
class MutatedPoint : public Point
{
    public:
        MutatedPoint(int,int);
        void printPoint();
        friend void printPoint(MutatedPoint &);
        int getY()
        {
            return y;
        }
};
void MutatedPoint::printPoint()
{
    cout << x << " " << y << endl;
}
void printPoint(MutatedPoint &n)
{
    cout << n.x << " " << n.y << endl;
}
mutatedPoint::MutatedPoint(int val1, int val2) : Point(val1, val2)
{
}
int main()
{
    MutatedPoint mPoint(50, 48);
    mPoint.printPoint();
    printPoint(mPoint);
    cout << mPoint.getY() << endl;
}
 
