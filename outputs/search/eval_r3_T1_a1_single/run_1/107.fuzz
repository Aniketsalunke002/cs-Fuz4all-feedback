#include <iostream>
using namespace std;
class Point {
public:
	Point(void);
	Point(int,int,int,int);
	~Point(void);
	void setPoint(int,int,int,int);
	int getX(void);
	int getY(void);
	int getZ(void);
	int getW(void);
private:
	int myx;
	int myy;
	int myz;
	int myw;
};
Point::Point(void):myx(0),myy(0),myz(0),myw(0)
{
}
Point::Point(int val1,int val2,int val3,int val4):myx(val1),myy(val2),myz(val3),myw(val4)
{
}
Point::~Point(void)
{
}
void Point::setPoint(int val1,int val2,int val3,int val4)
{
	myx = val1;
	myy = val2;
	myz = val3;
	myw = val4;
}
int Point::getX(void)
{
	return myx;
}
int Point::getY(void)
{
	return myy;
}
int Point::getZ(void)
{
	return myz;
}
int Point::getW(void)
{
	return myw;
}
int main()
{
	Point p2(4,10,10);
	p2.setPoint(10,1,8,3);
	cout << p2.getX() << " ";
	cout << p2.getY() << " ";
	cout << p2.getZ() << " ";
	cout << p2.getW() << " ";
	return 0;
}
 
