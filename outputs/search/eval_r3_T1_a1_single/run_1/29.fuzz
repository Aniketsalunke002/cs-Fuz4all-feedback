#include <iostream>
int main(int argc, char **argv)
{
	std::cout << "Hello world!\n";
	return 0;
}
 
template<typename T>
class TemplatedFoo
{
public:
	TemplatedFoo() : a(1), b(0)
	{
		 
		 
		 
		typedef short FLOAT;
		FLOAT c = 3.245;
		FLOAT d = 454.2;
	}
	void PrintStuff() const
	{
		std::cout << a;
		std::cout << b;
	}
	T a;
	T b;
};

 
