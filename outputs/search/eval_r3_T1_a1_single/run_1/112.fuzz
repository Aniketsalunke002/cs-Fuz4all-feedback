#include <iostream>
using namespace std;
#include <math.h>
double myPI = 3.1415;
double x2,y2,z2;
cin>>x2>>y2>>z2;
double t2 = (x2+y2+z2)/2;
t2 = sqrt(t2);
t2 = t2 - (x2*x2+y2*y2+z2*z2);
cout<<myPI*t2;
return 0;
}
 
#include <iostream>
using namespace std;
#include <math.h>
double myPI = 3.1415;
double x3,y3,z3;
cin>>x3>>y3>>z3;
double t3 = (x3+y3+z3)/2;
t3 = sqrt(t3);
t3 = t3 - (x3*x3+y3*y3+z3*z3);
cout<<myPI*t3*t3*t3/3;
return 0;
}


