#include <iostream>
using namespace std;
#include <math.h>
double myPI = 3.1415;
int main()
{
double x1,y1,z1,g;
cin>>x1>>y1>>z1>>g;
double t = (x1+y1+z1)/2;
t = sqrt(t);
t = t - (x1*x1+y1*y1+z1*z1);
g = g*0.5;
x1 += g*(y1+z1-x1);
y1 += g*(x1+z1-y1);
z1 += g*(y1+x1-z1);
t = sqrt(x1 * x1 + y1 * y1);
t = t - (x1 * x1 + y1 * y1 + z1_z1);
cout << myPI * t << " " << myPI * t * t * t / 3 << endl;
return 0;
}
 
