#include <iostream>
using namespace std;
template<typename T>
class Templated
{
public:
	Templated(int);
	Templated(T val[]);
	T mult(Templated<T>);
	void printarr()
	{
		for(int i=0; i<10; i++)
		{
			cout << x[i] << endl;
		}
	}
	~Templated()
	{

	}
private:
	T x[10];
	int n;
};
template<typename T>
Templated<T>::Templated(int val1)
{
	n = val1;
}
template<typename T>
Templated<T>::Templated(T val[])
{
	for(int i=0; i<n; i++)
		x[i] = val[i];
}
template<typename T>
T Templated<T>::mult(Templated<T> obj)
{
	for(int i=0; i<n; i++)
		x[i] = x[i] * obj.x[i];
	return x;
}
