#include <iostream>


using std::cout;

int main(int argc, char **argv)
{
	cout << "Hello world" << std::endl;
	struct A {
		int a, b;
		A() :a(1), b(2) {}
	} a;
	cout << a.a << std::endl;
	a.a = 0;
	cout << a.a << std::endl;
	a.b = 0;
	cout << a.b << std::endl;
	std::pair<int, int> p(0, 0);
	cout << p.first << " " << p.second << std::endl;
	p.first = 1;
	cout << p.first << " " << p.second << std::endl;
	p.second = 1;
	cout << p.first << " " << p.second << std::endl;
	return 0;
}