#include <iostream>
int main ()
{
    std::cout << "Hello World"<< std::endl;
    int a=444;
    int b=22;
    int *p_b=&b;
    auto *p_a=&a;  
    std::cout << p_a << std::endl;
     
    a++;*p_a=(*p_a)+1;
    std::cout << "the value of a is " <<  a << std::endl;
    std::cout << "the value of b is " <<  *p_b+b << std::endl;
    b++;
    std::cout << "the value of a is " <<  a << std::endl;
    std::cout << "the value of b is " <<  *p_b+b << std::endl;
    (*p_a)--;
    std::cout << "the value of a is " <<  a << std::endl;
    std::cout << "the value of b is " <<  *p_b+b << std::endl;
    return 0;
}
