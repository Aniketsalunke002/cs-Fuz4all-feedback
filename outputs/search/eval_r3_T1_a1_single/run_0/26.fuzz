#include <iostream>
#include <vector>
int main() {
	int i;
	i = 0;
	std::vector<char> v(i + 1);
	if (i > 0) {
		v[i + 1] = '0';
		std::cout << v[i];
	}
	{
		char x= v[0];
		std::cout << x;
	}
}
 
 
#include <iostream>

int main() {
	std::string x;
	x = "Hello world, this is an amazing day!";
	std::cout << x[0] << " " << x[1];
	return 0;
}
 
 
 
