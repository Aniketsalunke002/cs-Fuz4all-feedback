#include <iostream>
int main ()
{
    int a = 5;
    std::cout << "the value of the varible a " << a << std::endl;
    a = 15;
    std::cout << "the value of the varible a " << a << std::endl;
    return 0;
}
 
#include <iostream>
int main ()
{
    std::string s;
    std::cout << "Enter a line ";
    std::getline(std::cin,s);
    std::string temp ="";
    int number_word = 1;
    for(int i = s.size(); i > 0; i--)
    {
        if(s[i-1] =='' || i== s.size())
        {
            s[i-1] = 0;
            temp = s;
            if(number_word%2 == 0)
                std::cout<< temp<< " ";
            else
                std::cout<< temp<<'';
            number_word += 1;
            std::cout<<std::endl;
        }
    }
    return 0;
}

 
#include<iostream>
int main ()
{
    int a;
    std::cin>> a;
    for(int i = 1; i < 8; i ++)
    {
        for(int j = 1; j < 8; j ++)
        {
            if((i == j) && (i == 1) && (i == 2) && (i == 4) && (i == 8 ))
            cout<< "1";
            else if( ((i & j) == 0) && ((i & j)!= 0) )
                cout<< "0";
            else
                cout<< "1";
        }
        cout<< endl;
    }
}

 
#include <iostream>
#include <string>
#include <cmath>
int main ()
{
    for(int j = 0; j < 60000; j++)
    {
        int a = 20;
        int counter = 0;
        int r = 2;
        double pi = 0;
        for(int i = 0; i < 360; i++, a++)
        {
            if((2 < pow(a,2)) && (pow(a,2) < 2*r*r + 2*a - 2))
            {
                r += 0.01;
                counter++;
            }
            else
            {
                if(360 <=i)
                {
                    pi = counter / 360;
                    std::cout << a*pi <<' '<< a<< std::endl ;
                }
                break;
            }
        }
    }
    return 0;
}
