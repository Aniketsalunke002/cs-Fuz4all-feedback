#include <iostream>
int main ()
{
    int a=444;
    std::cout << "the value of the integer is " << a << std::endl;
    int b=4;
    std::cout << "the value of the integer is " << b << std::endl;
     
    int c=a;
    std::cout << "the value of the reference is " << c << std::endl;
     
    c=999;
    std::cout << "the new value of the reference " << c << std::endl;
     
    b=6;
    std::cout << "the new value of the integer " << b << std::endl;
    return 0;
}

 
#include <iostream>
int main ()
{
    int a=1;
    std::cout << "the value of the integer is " << a << std::endl;
     
    const int& b=a;
    std::cout << "the value of the reference is " << b << std::endl;
     
    int temp=999;
    b=temp;
    std::cout << "the new value of the reference " << b << std::endl;
    a=5;
    std::cout << "the value of the  integer is " << a << std::endl;
    return 0;
}
#include <iostream>
int main ()
{
    int a=9999;
    std::cout << "the value of integer is " << a << std::endl;
     
 
     
     
    int *c=&a;
    std::cout << "the value of the pointer is " << *(c) << std::endl;
    *(c)=48;
    std::cout << "the new value of the pointer " << *c << std::endl;
    a=657566;
    std::cout << "the value of integer is " << a<< std::endl;
     
    return *c;
    

}

