#include <iostream>

#include <iostream>
int main() {
  return 0;
}

// Extern function called from the main function.
extern int puts(const char *);
int main() {
  puts("Hello, World!\n");
  return 0;
}

// Check if the compiler preserves the #ifdef/endif directives.
#include <iostream>
#ifdef __cplusplus
int main() {
  std::cout << "Hello, World!\n";
  return 0;
}
#else
puts("Hello, World!\n");
#endif

// Check if #include works with std::streambuf and std::vector.
#include <iomanip>
#include <iostream>
#include <streambuf>
#include <vector>
int main () {
  std::vector<int> vi = {1, 2, 3, 4};
  std::cout << std::hex << std::uppercase;
  for (const int i : vi) std::cout << i;
  return 0;
}