#include <iostream>
int main()
{
    int a{444};
    std::cout << "the value of the integer is " << a << std::endl;
    int b{4};
    int* c{&b};
    std::cout << "the value of the integer is " << *c << std::endl;
    std::cout << "the value of the reference is " << &a << std::endl;
    return 0;
}
 
#include <iostream>
int main()
{
    int a{444};
    std::cout << "the value of the integer is " << a << std::endl;
    std::cout << "the value of the integer is " << a << std::endl;
    int b{4};
    int* c{&b};
    std::cout << "the value of the integer is " << *c << std::endl;
    std::cout << "the value of the reference is " << &a << std::endl;
    return 0;
}

int main() {

  1;
  int a = 1;
  int& b = a; int &c = a;
  a = 2; ++b;

  int* d = &c;
  *d = 2;  

  std::cout << "a: " << a << " b: " << b << " c: " << c << " d: " << d << std::endl;

  return 0;

}
