#include <iostream>

int main ()
{
    int a=444;
    int *b=&a;
    std::cout << "the value of the integer is " << a << std::endl;
    std::cout << "setting value of the integer..." << std::endl;
    a=333;
    *b=222;
    std::cout << "the value of the integer is now " << a << std::endl;
    return 0;
}
