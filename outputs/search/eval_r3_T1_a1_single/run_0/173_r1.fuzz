#include <iostream>

int main() {
  int arr[10] = {};
  for (int i = 0; i < 10; ++i)
    arr[i] = i;
  for (int i = 0, j = 0, k = 1; i < 10; ++i, j+=2, k+=3)
    std::cout << ((i%2 == 0)? arr[i] : arr[j]) - k;
  return 0;
}
