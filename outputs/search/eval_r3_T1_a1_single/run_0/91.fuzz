#include <iostream>
int main ()
{
    std::cout << "\n";
    int & a = 5;
	a = 20;
	std::cout << "The value of the variable a is " << a << "\n";
	int & b = 5;
    std::cout << "The value of the variable b is " << b << "\n";
	std::cout << "\n";
    int a1{5};  
    int b1{5};
    std::cout << "The values of the variables a1 and b1 are " << a1 << " and " << b1 << "\n";
    a1 = 20;
    b1=10;
    std::cout << "The values of the variables a1 and b1 are " << a1 << " and " << b1 << "\n";
    return 0;
}
 

#include <cmath> 
#include <iostream>
#include <iomanip>
#include <vector>

int main(){
    std::vector<double> x;
    int size{int(std::pow(3,2) + 1)};
	int length{0};
	for (int i{0}; i < size; i++){
		std::cout << i << "th element: ";
		std::cin >> x[i];
	}
	std::cout << "\nsize = " << size << "\n";
	for (int i{0}; i < size; i++){
		for (int j{i + 1}; j < size; j++){
			if (x[i]<x[j]){
				double temp = x[i];
				x[i] = x[j];
				x[j] = temp;
			}
		}
	}
	for (int i{0}; i < size; i++){
		for (int j{i + 1}; j < size; j++){
			if (x[i]<x[j]){
				break;
			}
		}
	}
	for (int i{length}; i < size; i++){
		if (x[i]>x[i - 1]){
			 length = j;
		}
	}
	if (length == 0){
		std::cout << "No segments found!!!!\n";
		length = 0;
	}
	std::cout << "The length of the biggest segment is " << length << "\n";

	
	std::cout << std::setprecision(2) << std::fixed << std::setw(12);
	for (int i{0}; i < size; ++i){
		std::cout << std::setprecision(2) << std::fixed << std::setw(12) << x[i];
	}
	
    std::cout << "\n---------------\n";
    return 0;
}

