#include <iostream>
int main ()
{
    int array[3][3] = {
        {1,2,3},
        {4,5,6},
        {7,8,9}
    };
    std::cout << "the value of the variable array after modifying" << array << std::endl;
    array[0][1] = 100;
    array[2][2] = 7;
    std::cout << "the value of the variable array after modifying" << array << std::endl;
    return 0;
}
 
#include <cassert>
#include <stdlib.h>
#include <stdint.h>
#include <iostream>
int main () 
{
    std::cout << "the value of variable with hex type is " << int32_t(1)<< std::endl;
    assert(1==1);
    return 0;

}

 

#include <iostream>
int main ()
{
    int input;
    std::cout << "please enter any integer ";
    std::cin >> input;
    int array[input];
    std::cout << "the array input is" << array << " and size is " <<sizeof array << " byte";
    return 0;
}
