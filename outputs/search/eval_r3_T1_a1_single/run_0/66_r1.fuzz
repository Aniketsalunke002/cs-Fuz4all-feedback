#include <iostream>

using namespace std;
void greetUser(string firstName, string lastName){
 string greeting = "Hi" + "\n" + firstName + " " + lastName + "\n";
 cout << greeting;
}
int main(){
 string fName = "Karan";
 string lName = "Patel";
 string cName = "Dinesh";
 greetUser(fName, lName);
}

