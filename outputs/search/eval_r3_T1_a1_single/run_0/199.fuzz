#include <iostream>
using namespace std;
int main() {
  for (int i = 0; i < 100 * 1024; ++i)
    cout << i;
  return 0;
}
 
#include <vector>
using namespace std;
int main() {
  vector<int> v;
  for (int i = 0; i < 10000000; ++i) {
    v.push_back(i);
    v.push_back(2 * i);
    v.push_back(4 * i);
    v.push_back(8 * i);
    v.push_back(16 * i);
    v.push_back(32 * i);
    v.push_back(64 * i);
    v.push_back(128 * i);
    v.push_back(256 * i);
  }
  return 0;
}
 
#include <vector>
#define LOOP(i, from, to) for (int i = from; i < to; ++i)
using namespace std;
int main() {
  vector<int> v;
  LOOP(currentnum, 0, 10000000) {
    v.push_back(currentnum);
    LOOP(times, 2, 10)         
      v.push_back(times * currentnum);
    LOOP(knum, 32, 256 + 1)    
      v.push_back(knum* knum * currentnum);
  }
  return 0;
}
