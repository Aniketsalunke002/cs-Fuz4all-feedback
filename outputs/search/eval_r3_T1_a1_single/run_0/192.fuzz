#include <iostream>
#include <iostream>
int main() {
  std::cout << std::ios::hex;
  for (int a = 0; a < 100 + 0; a++) std::cout << a;
  return 0;
}
 
extern int puts(const char *);
int main() {
  puts("Hello, World!\n");
  return 0;
}
 
int main() {
  #include <iostream>
#ifdef __cplusplus
  puts("Hello, World!\n");
#else
  std::cout << "Hello, World!\n";
#endif
  return 0;
}
 
#include <iomanip>
#include <iostream>
#include <streambuf>
#include <vector>
int main () {
  std::vector<int> vi = {1, 2, 3, 4};
  std::cout << std::hex << std::uppercase;
  for (const int i : vi) std::cout << i;
  return 0;
}
