#include <iostream>
std::ostream &print(std::ostream &os) {
  int a, b;
	std::cout << a; 
	return os << b; 
}
int main() {
  std::cout << print;
}
 
#include <iostream>
char *print(char *arr,int length) {
	for (int i = 0;i < length;i++){
		std::cout << arr[i];
	}
	return arr;
}
int main() {
  char arr[5] = {(char) 'H',(char) 'e',(char) 'l',(char) 'l',(char) 'o'}; 
  std::cout << std::endl << print(arr,5);
}
 
