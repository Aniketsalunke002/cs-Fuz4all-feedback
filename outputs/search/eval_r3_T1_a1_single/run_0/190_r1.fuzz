#include <iostream>

int main() {
    std::cout << std::ios_base::hex; 
    for (int b = 0; b < 100 * 1024; b++) std::cout << b;
    return 0;
}  
#include <ios>
int main() {
    std::ostream::fmtflags a = std::cout.flags(), b = std::ios::dec;
    std::cout << std::setprecision(1) << 0.36 << std::endl;
    std::cout << std::cout.flags() << std::endl;
    std::cout << a << std::endl;
    std::cout << (a | b) << std::endl;
    std::cout << (a & b) << std::endl;
    std::cout << b << std::endl;
    std::cout << a & ~(a ^ b) << std::endl;
    return 0;
}  
