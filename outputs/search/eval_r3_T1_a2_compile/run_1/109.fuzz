#include <iostream>
using namespace std;
int main ()
{
int n;
    cin>>n;
    if(n<2)
    cout<<1<<endl;
    else
    cout<<(n-1)*(n-1)<<endl;
    return 0;
}
 
#include <iostream>
using namespace std;
int main ()
{
    int n;
    cin>>n;
    for (int i=1;i<=n;i++) {
        for (int j=1;j<=n;j++) {
            cout<<i<<" x "<<j<<" = "<<i*j<<',';
        }
        cout<<endl;
    }
    return 0;
}
 
#include <iostream>
using namespace std;
int main ()
{
    for (int i=1;i<=100;i++)
    {
if(i%3==0 && i%5==0)
    cout<<"FizzBuzz!"<<endl;
else if(i%3==0)
    cout<<"Fizz!"<<endl;
else if(i%5==0)
    cout<<"Buzz!"<<endl;
else
    cout<<i<<endl;
}
    return 0;
}
 
#include <iostream>
using namespace std;
int main ()
{
    int n;
    cin>>n;
    for (int i=1;i<=n;i++)
    {
        cout<<i<<endl;
    }
    return 0;
}
