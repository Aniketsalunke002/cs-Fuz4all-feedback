#include <iostream>
void f()
{
    double x=(int)(15)+1;
    char c = 'A';
    std::cout << c;
    std::cout << x << " ";
    
    int a = 0;
    while (x < 30) {
        ++x;
        std::cout << " ";
    }
    while (x>=5) {
        x = (int)(x-1);
        std::cout << x;
    }
}

int main() {
    f();
}