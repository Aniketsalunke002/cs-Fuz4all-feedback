#include <iostream>
struct Person
{
    std::string name;  
    int age;  
    double height;  
};
struct Student
{
    char id[7];  
    char name[10];  
    char department[6];  
};
int main()
{
    std::cout << "Enter the array size: \n";
    int n;
    std::cin >> n;

    Person * p = new Person[n];

    for (int i=0; i< n; i++)
    {
        p[i].name = "Aaron";
        p[i].age = 42;
        p[i].height = 1.80;
    }

    Student * s = new Student[n];

    for (int i=0; i< n; i++)
    {
        s[i].id = "123456";
        s[i].name = "Aaron";
        s[i].department = "CS";
    }
    for (int i=0; i<n; i++)
    {
        std::cout << "ID: " << s[i].id <<  " | Name: " << s[i].name <<  " | Department: " << s[i].department << "\n";

        std::cout << p[i].name << " is " << p[i].age << " years old " << p[i].height << " inches tall.\n";
    }
}