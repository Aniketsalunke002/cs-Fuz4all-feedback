template<typename T> void getSum(const T& x){
    cout<<accumulate(x.begin(),x.end(),0)<<endl;
}
int main()
{
    getSum(cards("ABC0"));
    getSum(cards("0BC"));
    getSum(cards("A0B"));
    getSum(cards("A0BC0D0EF1G2H3I"));
}
