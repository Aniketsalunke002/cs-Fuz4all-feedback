#include <iostream>
#include <vector>
#include <algorithm>
#include <iterator>
void print_list(std::vector<int>& l)
{
    std::vector<int>::iterator it;
    std::copy(l.begin(),l.end(),std::ostream_iterator<int>(std::cout," "));
    std::cout << std::endl;
}
int main(void)
{
    std::vector<int> l1;
    l1.push_back(1);
    l1.push_back(2);
    l1.push_back(4);
    l1.push_back(5);
    l1.push_back(6);
    l1.push_back(77);
    l1.push_back(110);
    l1.push_back(123);
    l1.push_back(800);
    print_list(l1);
}
