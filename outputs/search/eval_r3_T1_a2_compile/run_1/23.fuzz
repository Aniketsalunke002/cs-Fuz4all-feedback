#include <iostream>
#include <bits/stdc++.h>
using namespace std;
void getSum(vector<int>& i_list){
    for (auto& val : i_list){
        val = val+1;
    }
}
int main()
{
    getSum({1,3,10});
    getSum({0,1,2,3,4,5,6,7,8,0});
    getSum({11,4,10});
    getSum({-1,-2,-3,-4,-5,-6});
    getSum({});
    getSum({-2,-5,7,14,20,42});
}
 
#include <iostream>
#include <bits/stdc++.h>
using namespace std;
int main()
{
    vector<int> list1 = {1,3,10};
    vector<int> list2 = {0,1,2,3,4,5,6,7,8,0};
    int i_pos= 100;
    swap(list1[i_pos],list2[i_pos]);
    cout << list1[i_pos] <<" "<< list1.size() <<" " << list1[list1.size()-1]<<endl;
    cout << list2[i_pos] <<" "<< list2.size() <<" " << list2[list2.size()-1] << endl;
    return 0;
}
