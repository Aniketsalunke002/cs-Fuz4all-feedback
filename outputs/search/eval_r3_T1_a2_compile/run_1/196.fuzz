#include <iostream>
using namespace std;
int main(int argc, char **argv) {
   if(argc!= 3) cout << "Please enter the parameters!" << endl;
   int a = atoi(argv[1]);
   int b = atoi(argv[2]);
   cout << (a + b) << endl;
   cout << (a - b) << endl;
   cout << (a * b) << endl;
   cout << (a / b) << endl;
   return 0;
}
