#include <iostream>

using namespace std;
class Ponto{
public:
int x;
int y;
Ponto(int x1, int y1):
x{x1}, y{y1} { }
Ponto(int x1, int y1, int z1):
x{x1}, y{y1}, z {z1} { }
void printCoordinates()
{ cout << x << " " << y; }
};
int main(int argc, char **argv)
{ Ponto p1(2,3);
  Ponto p2(4,5,30);

  p1.printCoordinates();
  cout << endl;
  p2.printCoordinates();
  return 0;
}
// Compiler accepts the above code and shows the output as:
// 2 3
// 4 5