#include <iostream>


void print_list(list<int>& l)
{
    for(list<int>::iterator i = l.begin();i!= l.end;++i)
        std::cout << *i << ", ";
    std::cout << std::endl;
}

void append_list(list<int>& l,int x)
{
    l.push_back(x);
}


int main(void)
{
    list<int> l1;
    append_list(l1,1);
    append_list(l1,2);
    append_list(l1,4);
    append_list(l1,5);
    append_list(l1,6);
    append_list(l1,77);
    append_list(l1,110);
    append_list(l1,123);
    print_list(l1);
}
