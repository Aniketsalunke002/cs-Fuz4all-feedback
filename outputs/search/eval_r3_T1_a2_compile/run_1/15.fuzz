#include <iostream>
#include <vector>
std::list<int> list_with_unique_elements(const std::vector<int> &in)
{
    std::list<int> out;
    for(std::vector<int>::const_iterator i = in.begin(); i!= in.end(); ++i)
    {
        if(out.empty())
            out.push_back(*i);
        else if(out.back()!= *i)  
            out.push_back(*i);
    }
    return out;
}
int main(void)
{
    std::vector<int> l;
    l.push_back(1);
    l.push_back(2);
    l.push_back(5);
    l.push_back(2);
    l.push_back(6);
    l.push_back(77);
    l.push_back(110);
    l.push_back(123);
    std::cout << "original list:" << std::endl;
    print_list(l);
    std::list<int> l2 = list_with_unique_elements(l);

    std::cout << "list with unique elements:" << std::endl;
    print_list(l2);
}