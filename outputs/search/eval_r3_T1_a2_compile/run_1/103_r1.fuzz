#include <iostream>

#include <stdlib.h>
#include <vector>
 
 
using namespace std;
int main ()
{
  vector<int> test;
  test.push_back(5);
  test.push_back(4);
  test.push_back(3);
  test.push_back(2);
 
  sort(test.begin(),test.end());
 
  for (int i=0;i<test.size();i++) {
    cout<<test[i]<<',';
  }
  cout<<endl;
 return 0;
}