#include <iostream>
using namespace std;
int main(){
   int c=0;
   if(5 > 3){
        cout << "y";
   }
   if(5 > 3){
        cout << "z";  
   }
   if(5 > 3){       
        c = 2;   
   }else if(5 == 3){
        c = 3;
   }else if(5 > 3){
        c = 1;
   }    
   if(c == 2){
        cout << "c";
   }
   cout << " ";
   if(c == 3){
        cout << "d";
   }
   cout << " ";
   if(c == 1){
        cout << "e";
   }
   cout << "\n";
   c++;
   return 0;
}
