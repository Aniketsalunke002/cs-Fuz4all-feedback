#include <iostream>
using namespace std;
int main(){
    int x = 5;
    cout << x*24 << "\n";
    x = 5*x;
    cout << ++x + 15 << "\n";
    x += 7;
    cout << 3 + 2 + x << "\n";
    x = 7*x;
    cout << x << "\n";
    return 0;
}
 
#include <iostream>
using namespace std;
int main(){
    int result;
    int x = 5;
    cout << x*24 << "\n";
    result = x*5;
    x += 7;
    cout << 3 + 2 + x << "\n";
    result = 7*result;
    cout << result << "\n";
    return 0;
}
 
