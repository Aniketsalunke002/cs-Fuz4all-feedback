#include <iostream>
using namespace std;
int main ()
{
   int data[6][4]={
      {1,2,3,4},
      {2,3,4,5},
      {3,4,5,6},
      {5,5,6,7},
      {6,7,8,9},
      {10, 11, 12, 13}};
   for (int i=0;i<6;i++)
   {
       cout<<data[i][0]<< ", ";
   }
   cout<<endl;
    
   int i=2;
   while (i<4)
   {
       for (int j=0;j<6;j++)
       {
           cout<<data[j][i]<<",";
       }
       cout<<endl;
       i++;
   }
}
