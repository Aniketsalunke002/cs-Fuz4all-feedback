#include <iostream>
#include <string>
using namespace std;
int main(){
    string name;
    name = "<NAME>";
    cout << "My Name is " << name << "\n";
    name = name + " Gang";
    cout << "My name" << name << "\n";
    cin >> name;
    cout << "Your name is " << name;
    return 0;
}
