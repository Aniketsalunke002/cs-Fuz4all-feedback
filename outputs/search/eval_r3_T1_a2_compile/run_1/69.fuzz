#include <iostream>
#include <string.h>
#include <cctype>
bool IsPalindrome(char* word)
{
    int index1=0;
    int index2=strlen(word)-1;
    while (index1<index2)
    {
        if(word[index1]==0 && word[index2]== 0)
            return true;
        if(tolower(word[index1])!=tolower(word[index2]))
            return false;
        index1++;
        index2--;
    }
    return true;
}
int main()
{
   std::cout<<IsPalindrome("adada");
}
 
#include <stdio.h>  

struct Element {
    int num;
    char s[10];
};

 
char *getChar(Element *el)
{
    return *el->s;
}
int GetInt(Element *el)
{
    return atoi(*el->s);
}
 
void doIt(int elements, Element *el, Element *elResult, void *(*func)(Element *)) {
  Element *ptr;
  int i;
  for (i=0; i<elements; i++) {
    elResult[i].s[0] = 0;
    elResult[i].num = ((*func)(el+i));
  }
}