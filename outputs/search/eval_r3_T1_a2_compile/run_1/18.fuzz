#include <iostream>
void getSum(const std::initializer_list<int>& i_list){
    std::cout << "result " << std::accumulate(i_list.begin(),i_list.end(),0) << std::endl;
}
int main()
{
    getSum({1,3,10});
    getSum({0,1,2,3,4,5,6,7,8,0});
    getSum({-1,-2,-3,-4,-5,-6});
    getSum({});
    getSum({});
    getSum({-2,-5,7,14,20,42});
}
