#include <iostream>
#include <list>
#include <cstdlib>
int main(void)
{
    std::list<int> l1;
    append_list(l1,1);
    l1.push_back(2);
    append_list(l1,3);
    append_list(l1,4);
    l1.push_back(5);
    append_list(l1,6);
    l1.resize(5);
    append_list(l1,77);
    l1.remove(77);
    append_list(l1,110);
    append_list(l1,123);
    l1.insert(l1.begin()+4,0);
    bool ok=true;
    for(std::list<int>::iterator i = l1.begin();i!= l1.end();++i)
    {
        printf("%d, ",*i);
        if(ok) ok=(*i==i+1);
    }
    if(ok) printf("Correct!!!\n");
    else printf("Wrong\n");
}

