#include <iostream>
#include <list>
void print_list(std::list<int>& l)
{
    for(std::list<int>::reverse_iterator i = l.rbegin();i!= l.rend();++i)
        std::cout << *i << " ";
    std::cout << std::endl;
}
void append_list(std::list<int>& l,int x)
{
    l.push_back(x);
}
int main(void)
{
    std::list<int> l1;
    append_list(l1,1);
    append_list(l1,2);
    append_list(l1,4);
    append_list(l1,5);
    append_list(l1,6);
    append_list(l1,77);
    append_list(l1,110);
    append_list(l1,123);
    append_list(l1,800);
    print_list(l1);
}
