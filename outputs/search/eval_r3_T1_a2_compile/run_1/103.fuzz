#include <iostream>
using namespace std;
int main() {
  int num1=200;
  int num2=2;
  int num3=2;
  cout<<"sum of "<< num1 <<" + "<<num2<< " + "<< num3 <<  " = "<<(num1+num2+num3)<< endl; 
}
 
  
  
#include <iostream>
#include <stdlib.h>
using namespace std;

int main ()
{
  int len=4;
  int test[len];
  test[0]=5; test[1]=4; test[2]=3; test[3]=2;
   
  sort(test+0,test+len); 
  for (int i=0;i<len;i++) {
    cout<<test[i]<<',';
  }
  cout<<endl;

  return 0;
}
