#include <iostream>

using namespace std;
int main(){
    int a;
    int result;
    int x = 5;
    cout << x*24 << "\n";
    result = 5*a;
    cout << result + 15 << "\n";
    x += 7;
    cout << 3 + 2 + x << "\n";
    result = 7*result;
    cout << result << "\n";
    return 0;
}

