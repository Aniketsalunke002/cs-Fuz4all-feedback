#include <iostream>
using namespace std;
int main (){

    int num=25;
    
    num+=1;
    num-=9;
    int number = num;
    while(num<10){
        number-=2;
        if(number < 0){
            number = -1;
            cout<<num << endl;}
        num+=1;
 }
}
 
#include <iostream>
using namespace std;
int main ()
{
    char array[10]="Hello Word";
    for(int i=0;i<9;i++){
        if(array[i]=='h'){
            array[i]='w';
        }
    }
    
    for(int i=0;i<10;i++){
          cout<<array[i] <<endl;
    }
    
    return 0;
    
}
 
#include <iostream>
using namespace std;
int main ()
{
    char array[10]="Hello Word";
    int i=10;  
    while(i>2){
      if(array[i-1]=='l')
        array[i-1]='z';
    i-=1;
        
    }
    for(int i=0;i<10;i++){
          cout<<array[i] <<endl;
    }
    
    return 0;
    
}
 
 
 
 
