        }
    public:
        friend std::ostream& operator << (std::ostream& os,const iterator& it){
            os << *it;
            return os;
        }
        template<class U>
        friend bool operator!= (const iterator& it,const iterator& other) {
            return it.i!= other.i;
        }
        Iterator& operator++(){
            ++i;
            return *this;
        }
        T operator*() const{
            return *i;
        }
    };
    iterator begin() {
        return iterator(l.begin());
    }
    iterator end() {
        return iterator(l.end());
    }
private:
    std::list <T> l;
};
