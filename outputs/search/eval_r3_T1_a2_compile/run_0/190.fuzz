#include <iostream>
#include <string>
using std::cout; using std::endl;
using std::string;

class A{
public:
    void printA () {
        cout << "class A" << endl;
    }
};

class B{
public:
    virtual void printB () = 0;
};

void printD (double){
    cout << "double" << endl;
}

class C:public A, public B
{
public:
    void printC () {
        cout << "class C" << endl;
    }

    void printB () {
        cout << "class B" << endl;
    }
};
void printString (string s){
    cout << &s << endl;
}

void printArray (int *pa, int n){
    for (int i = 0; i < n; i ++) {
        std::cout << *(pa + i) << endl;
    }
}

int main () {
    C c1;
    c1.printA();
    c1.printB();
    c1.printC();
    B b1;
    b1.printB();
    printD(1);
    printD(1.0f);
    printString("world");
    printArray(a1, 4);
}
 
     
     
     
     
     
