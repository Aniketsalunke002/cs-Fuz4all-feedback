#include <iostream>

using namespace std;
int main(){
     int n;
      cout<< "Enter the n : \n ";
      cin>> n;
      if( n >= 20){
           cout<<endl<< "YES\n";
       }
       else {
           cout<<"NO \n";
       }
   return 0;
}
