#include <iostream>
 using namespace std;
 int main()
 {
 int a[10];
 int b[20];
 int c[30];
 for (int& element : a) { element = 5; }
 for (int* p=a; p<a+10; p++) { *p=77; }
 for (int* p=a; p<a+10; p++) { cout << *p; }
 cout << endl;
 for (int (c[10]) : a) { c[10]=1; }
 for (int (&element) = a[0]; element==77; b[0]=1 ) { element = 2; }
 for (auto element : b) cout << element;
 cout << endl;
 for (int* p=(int*)&a[0]; p< (int*)&a[10]; p++) { *p=3; }
 for (int* p=(int*)&a[0]; p< (int*)&a[10]; p++) { cout << *p<< " "; }
 cout << endl;
 return 0;
}
