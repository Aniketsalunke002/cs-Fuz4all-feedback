#include <iostream>
using namespace std;
int main() {
    for ( int i=1; i<=10; i++) {
    cout << i;
    }
    for ( int i=1; i<=20; i++) {
    cout << i;
    }
    for ( int i=20; i<=40; i++) {
    cout << i;
    }
    return 0;
}
 
#include <iostream>
using namespace std;
int main()
{
   char grade;
   cout << "Enter your character grade: ";
   cin>> grade;
   switch( grade )
   {
      case 'A': cout << "Your grade is A++";
             break;
      case 'B': cout << "Your grade is B";
             break;
      case 'C': cout << "Your grade is C";
             break;
      case 'D': cout << "Your grade is D";
             break;
      case 'F': cout << "Your grade is F";
             break;
      default: cout << "A"
              << " is the lowest grade.";
   }
   return 0;
}
  
#include <iostream>
using namespace std;
int main()
{
    int x = 0;
    while (x < 100) {
        cout<< "while "<< x+2 << endl;
        x++;
    }
    return 0;
}
