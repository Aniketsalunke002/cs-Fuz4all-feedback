#include <iostream>
#include <vector>
int main() {
    std::vector<int> a{1,2,3,4,5,6,4,4,5,123};
    std::sort(a.begin(), a.end());
    std::copy(a.begin(), a.end(), std::ostream_iterator<int>(std::cout, " "));
    std::cout << " " << (int)a.size() << " " << a.at(0) << " " << a.at(3) << std::endl;
}
