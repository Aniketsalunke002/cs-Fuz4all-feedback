#include <iostream>

#include <fstream>
std::string output;
void hello(const char* file_name) {
  std::string number_of_bytes;
  std::ifstream s(file_name, std::ios::in | std::ios::binary | std:: ios::ate);
  number_of_bytes = s.tellg();
  s.seekg(0, s.beg);

  output = s.rdbuf();
  std::cout << output << std::endl;
  s.close();
}