#include <iostream>
using namespace std;
int x(4), y(3), z(5);
int main() {
    x  = ++y + z; 
    y /= 2; 
    z -= 3; 
    ++x;
    cout << "The value of x is " << x << endl;
    cout << "The value of y is " << y << endl;
    cout << "The value of z is " << z << endl;
    return 0;
}
 
#include <iostream>
using namespace std;
int main(){

    constexpr int s = 1025-1-1+1+' ';
    char str[s];
    std::cin.getline(str, s);
    std::cout << str << '\n';

}
