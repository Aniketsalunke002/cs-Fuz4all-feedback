#include <iostream>
#include <limits>
using namespace std;
int main() {
  cout << numeric_limits<int>::max() << endl;
  return 0;
}
 
#include <iostream>
using namespace std;
int main() {
  int v { 0 };
  cout << "Enter any value:" << endl;
  cin >> v;
  cout << "You entered: " << v << endl;
  return 0;
}
 
#include <iostream>
using namespace std;
int main() {
  float v1 { 0 };
  float v2 { 0 };
  cout << "Enter first value:" << endl;
  cin >> v1;
  cout << "Enter second value:" << endl;
  cin >> v2;
  cout << "The sum of v1 and v2 is: " << v1+v2 << endl;
  return 0;
}
