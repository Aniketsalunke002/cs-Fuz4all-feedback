#include <iostream>
#ifdef LINUX
void run() {
	std::cout << "Linux code" << std::endl;
}
#endif
#ifdef MAC
#include <dlfcn.h>
void run() {
	std::cout << "Mac code" << std::endl;
	dlclose(dlopen("mac_libraries.dylib", RTLD_NOW));
}
#endif
int main() {
	run();
}
