#include <iostream>
using namespace std;
int main() {
  int x{1};
  x = x + 3;
  x = x - -3;
  cout << x << endl;
  cout << ++x << endl;
  cout << --x << endl;
  cout << x++ << endl;
  cout << x-- << endl;
   
  int foo{5};
  for (int i = 0; i < 3; i++) {
    x++;
    ++foo;
     
    if (foo + 3 % 2) {
      cout << i << endl;
    }
  }
  return 0;
}