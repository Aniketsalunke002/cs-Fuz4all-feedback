#include <iostream>

int main() {
    int mult{};
    for (int i = 1; i <= 30; i += 3) {
        for (int j = 1; j <= 20; j += 2) {
            mult = i * j;
            mult = mult + i * j;
            mult = mult * i * j;
            std::cout << "The product is " << mult << std::endl;
        }
        std::cout << "A new line" << std::endl;
    }
    int ans[5] = {10, 20.5, 70, 50, 30};
    int j;
    int a = 10;
    j = 15;
    float d = 3.56f;
    while (a <= 15) {
        ++a;
        if (j >= 50) {
            j -= 50;
        }
    }
    int k;
    char c[50]{0.1, 12, 34, 2.1, 12.3, 'w', 20};
    int d[5]{1, 8.99, 22};
      
    return 0;
}