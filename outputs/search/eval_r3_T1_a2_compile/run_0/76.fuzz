#include <iostream>
using namespace std;
int main()
{
  int tab[10]={0,1,1,0,1,1,0,1,1,1};
  for(int i=0; i<10; i++)
  {
    if(tab[i] == 0)
      tab[i] = 1;
    else
      tab[i] = 0;
  }
      for(int i=0; i<10; i++)
      {
            cout << "tab["<<i<<"] = "<< tab[i]<<endl;

      }
    return 0;
}
