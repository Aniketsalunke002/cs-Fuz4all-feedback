#include <iostream>

using namespace std;
class A {
public:
  int x;
  void f();
  int func(int a, int b);
};
A g() {
  struct A x;
  x.x = 4;
  return x;
}
int func(int a, int b) {
  int *p1 = &a, *p2 = &b;
  int *p = p1 < p2? p1 : p2;
  p = p1 > p2? p1 : p2;
  return *p;
}
int main() {
  struct A x;
  cout << x.x;
  return 0;
}