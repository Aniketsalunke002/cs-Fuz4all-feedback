#include <iostream>

using namespace std;
int main () {
    int a = 10;
    int b = 20;
     
    int *r1 = new int;
    *r1 = 17;
    cout << *r1 << endl;
    *r1 = 20;
    cout << *r1 << endl;
     
    int *r1 = new int(10);
    cout << *r1 << endl;
     
    delete r1;
    r1 = 0;
}
