#include <iostream>

using namespace std;
int main() {
    int max = 0;
    for (int i = 2; i <= 100; i++) {
        int s = i * 10;
        if (max < s) {
            max = s;
        }
    }
    cout << "Max is " << max << endl;
    return 0;
}
