#include <iostream>
using namespace std;
int main()
{
  int tab[10]={1,2,5,6,0,9,4,3,8,7};
  cout << "Original Array ";
    for(int i=0; i<10; i++)
      cout << tab[i] <<" ";
    cout << endl ;
  for(int i=0; i<10; i++)
  {
    if(tab[i]!= 0 && tab[i] %2 ==0)
      tab[i]++;
  }
  cout << "Mutated Array ";
    for(int i=0; i<10; i++)
      cout << tab[i] <<" ";
    cout << endl ;
    return 0;
}
 
