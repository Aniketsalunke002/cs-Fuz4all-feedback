#include <iostream>
using namespace std;
int main()
{
  int a[3][2]  = {{4, 3},{-2,4}};
  int b[2][3]  = {{5,4,9},{4,0,7}};
  int c[3][3]={0,0,0,0,0,0,0,0,0};
  int k = 3, l = 2, m=2, n=3;
  for(int x=0; x<k; x++)
  {
    for(int y=0; y<l; y++)
    {
      for(int i=0; i<m; i++)
      {
        for(int j=0; j<m; j++)
        {
          c[x][y]+=a[x][i]*b[i][j];
        }
      }
    }
  }
  cout << "Matrix A ";
    for(int x=0; x<k; x++)
    {
      for(int y=0; y<l; y++)
      {
        cout << "\t" << a[x][y];
      }
      cout<<"\t";
    }
    cout << "\nMatrix B ";
    for(int x=0; x<k; x++)
    {
      for(int y=0; y<l; y++)
      {
        cout << "\t" << b[x][y];
      }
      cout<<"\t";
    }
  cout << "\nResultant matrix ";
    for(int x=0; x<k; x++)
    {
      for(int y=0; y<l; y++)
      {
        cout << "\t"<< c[x][y];
      }
      cout<<"\t";
    }
    return 0;
}
 
