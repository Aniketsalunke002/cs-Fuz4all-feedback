#include <iostream>
using std::cout; using std::endl;
int main () {
    char c1, c2;
    short s1, s2;
    int i1, i2, i3;
    float f1, f2;
    int a1[7];
    float* pf1=&a1[0];
    a1[5]=1.3;
    a1[6]=2.5;
    a1[1]=6.8;
    cout<<*pf1<<endl;
    cout<<*(pf1+3)<<endl;
    cout<<(pf1+3)->c<<endl;
    cout<<a1[0]<<endl;
}
 
 
 
 
