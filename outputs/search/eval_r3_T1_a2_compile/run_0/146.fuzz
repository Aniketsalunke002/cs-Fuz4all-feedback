\subsection{Exercise 6 (Program)}
\href{https: 

\begin{lstlisting}[language=C++]
#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
char s1[500000], s2[500000];
void sortStrings(std::vector<std::string> &s) {
    std::sort(s.begin(), s.end(), 
                [](const std::string &a, const std::string &b) {
        return a.size() < b.size();
        });
}
int main() {
    int n, count;
    cin >> n;
    std::vector<std::string> v;
    for (int i = 0; i < n; i++) {
        cin >> s1 >> s2;
        if (v.size()==count) {
            count++;
            v.push_back("");
        }
        v[i] += (s1 + " " + s2);
    }
    sortStrings(v);
    for (int i = 0; i < v.size(); i++)
        cout << v[i] << endl;
return 0