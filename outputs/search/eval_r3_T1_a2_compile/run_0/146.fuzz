\begin{lstlisting}[language=C++]
#include <string>
using namespace std;
class Dog {
    public:
    string Name;
    string HairType;
    string Tricks;
};
int main() {
        Dog myDog;
        myDog.Name = "Doggy";
        myDog.HairType = "Long Bob";
        myDog.Tricks = "Waggles";
        cout << "My " << myDog.Name << "'s hair is " << myDog.HairType << ".";
        cout << " Huh, he usually " << myDog.Tricks << ".";
        return 0;
    }
\end{lstlisting}

