#include <iostream>

using namespace std;
#include <string>

int main() {
	string a;
	int b = 100;
	const char* c = "I am not happy.";
	cout << "What\'s your name and what is your age? ";
	cin >> a >> b;
	cout << a << ", are You " << b << " years old? Do you look happy " << c;
	return 0;
}
 

\end{lstlisting}

