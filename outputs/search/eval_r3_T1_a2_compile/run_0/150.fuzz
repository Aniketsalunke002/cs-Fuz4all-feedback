#include <iostream>
using namespace std;
int main() {
    int num{100};
    num = num - 10 + 2;
    cout << "Number is " << num << endl;
    return 0;
}
 

 

#include <iostream>
using namespace std;
int main() {
    int num{100};
    num = - num + num++ + 3 - num-- + 2;
    cout << "Number is " << num << endl;
    return 0;
}
