#include <iostream>
using namespace std;
const int NUM{5};
int main() {
    for (int i = 1; i <= NUM; i++) {
        if (i % 2 == 0) {
            sum /= 2;
        } 
        printf("\nThe value of the previous generation is %d", sum);
    }
}
 
#include <iostream>
using namespace std;
int main() {
    int n, sum {0}, mean;
    std::cout << "Please enter \n(1) the value of N (1-200)" << std::endl;
    std:: cout << "and"  << std::endl;
    std:: cout << "(2) the value of the mean" << std::endl;
    std:: cin >> n;
    std:: cout << "\nPlease enter the values that will be taken into account:" << std::endl;
    for (int i=0; i < n ; i++) {    
        int aux;
        std:: cin >> aux;
        if (aux > 200) {
            break;
        }
        sum += aux;
    }
    mean = sum / n;
    std:: cout << "The list of values are" << std:: endl;
    std:: cout << sum;
    std:: cout << "The mean is" << mean << std:: endl;
}

 
#include <iostream>
using namespace std;
int sum(int n)
{
    int sum {0};
    for (int i = n; i > 0; i--) {
        sum += i;
    }
    return sum;
}
int max(int a, int b)
{
    if (a>b) {
        return a;
    } else {
        return b;
    }
}
int main() {
    int n;
    std:: cout << "Please choose the number of elements:" << std:: endl;
    std:: cin >> n;
    std:: cout << "\nThe sum of all the elements is" << sum(n) << std:: endl;
    std:: cout << "The maximum value of the two integers is" << max(50, -50) << std:: endl;
}
 
 
using namespace std;
int main() {
    int a, b;
    int max {2147483647}, min {-2147483648};
    std:: cout << "Please enter a and b:" << std:: endl;
    std:: cin >> a >> b;
    std:: cout << "The value of a is" << a << "and the value of b is" << b << std:: endl;
    if(a+b > max || a+b < min) {
        cout << "We cannot carry out this operation";
    } else {
        cout << "The result of the sum is" << a + b << endl;
    }
}
 
