#include <iostream>
using std::cout;
using std::endl;
int main () {
    int i = 0;
    while (i < 10) {
        i++;
    }
    cout << i << endl;
}
#include <iostream>
using std::cout;
using std::endl;
int main () {
    double pi = 3.14;
    for (int i = 0; i < 10; i++) {
        cout << "i = " << i << endl;
    }
}
