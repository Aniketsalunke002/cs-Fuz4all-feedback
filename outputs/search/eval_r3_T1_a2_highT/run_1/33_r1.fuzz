#include <iostream>

#include <cmath>
#include <string>
#include <complex>

using namespace std;

complex ComplexAddition(complex x, complex y)
{
	return x + y;
}

complex ComplexRoot(complex a, double n){
	return exp(n*I*arg(a))/2;
}

int main()
{
	for(int i = 0; i < 20; i++)
		cout << ComplexRoot(ComplexAddition(ComplexAddition(ComplexAddition(ComplexAddition(ComplexAddition(ComplexAddition(complex{0,1},complex{0,1}),complex{0,1}),complex{0,1}),complex{0,1}),complex{0,1}),complex{0,1}),-1.0),1)/(double)pow(2,i);
	return 0;
}