#include <iostream>

#include <algorithm>
#include <iterator>
#include <numeric>
#include <random>
#include <vector>
#include <string>
using namespace std;
int main(){
    int nums[] = {4, 3, 1, 0, 7};
    std::vector<int> vec(1000,7);
    std::iota(vec.begin(), vec.end(), 0);
    cout << "Total: " << accumulate(vec.begin(), vec.end(), 0) << std::endl;
    for(int i = 0; i < 100; ++i) {
        unsigned seed = chrono::system_clock::now().time_since_epoch().count();
        shuffle(vec.begin(), vec.end(), default_random_engine(seed));
    }
    cout << "shuffled:" << endl;
    copy(vec.begin(), vec.end(),ostream_iterator<int> (cout, "\n"));
    return 0;
}