#include <iostream>

using namespace std;

class FooClass {
public:
    FooClass() {}
    void foofunc(string foo) {
        foo = foo + ": foo";
    }
    friend string foofuncfunc(string bar);
};
string foofuncfunc(string bar) {
    return bar + "!";
}
int main(int argc, char* argv[]) {
    string bar("1");
    cout << foofuncfunc(bar);
    return 0;
}