#include <iostream>

# include <cstdio>
int main() {
	int mut=0;
	int winner=1;
	std::cout << "Press ENTER to start, any other key to quit.";
    switch(getchar()) {
    case '\n':
        break;
    case 'Q':
        std::cout << "Exiting..." << std::endl;
        return 0;
    case '\x1b':
        std::cout << "Exiting..." << std::endl;
        return 0;
    case '\t':
    		putchar('\x08');
    case '\b':
    default:
        std::cout << "Invalid input." << std::endl;
        break;
    }
	for(;;) {
		bool won=false;
		std::cin >> mut;
		winner=(winner*2)+mut;
		if(winner==1) {
			std::cout << mut << ": [1][ ] is live!" << std::endl;
			winner^=1;
			won=true;
			winner^=mut;
			std::cout << winner << ": [ ] is dead" << std::endl;
		}else if((winner%2)==1) {
			std::cout << mut << ": [0][1] is live!" << std::endl;
			std::cout << (winner>>1) << ": [1][ ] is dead" << std::endl;
		}else {
			std::cout << mut << ": [1][1] is live!" << std::endl;
			std::cout << (winner>>1) << ": [1][1] is live!" << std::endl;
			std::cout << ((winner>>1)>>1) << ": [0][1] is dead" << std::endl;
			std::cout << ((winner>>1)>>1) << ": [0][0] is live!" << std::endl;
			std::cout << (winner>>1) << ": [0][0] is live!" << std::endl;
		}
		if(won) winner^=mut;
		if((winner%4)==0) {
			winner^=2;
			std::cout << winner <<