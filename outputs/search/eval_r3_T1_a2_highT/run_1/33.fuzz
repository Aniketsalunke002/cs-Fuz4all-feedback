#include <iostream>
#include <cmath>
#include <complex>
#include <math.h>
#include <string>

struct Complex{
	double r;
	double i;
};

Complex ComplexAddition(Complex x,Complex y)
{
	Complex z;
	z.r = x.r + y.r;
	z.i = x.i + y.i;
	return z;
}

Complex ComplexExponentiation(Complex x, double n)
{
	Complex y;
	y = x;
	for(int i = 0; i < n-1; i++) 
		y = ComplexAddition(y,x);
	return y;
}

Complex ComplexRoot(Complex a, double n)
{
	Complex x;
	if(n == 0 && a.r == 0){
		x.r = 0;
		x.i = 0;
		return x;
	}
	if(n!= 0)
		x = pow(a,complex((-0.5),(n*M_PI)/2));
	else
		x.r = sqrt(a.r * a.r + a.i * a.i);
	x.i = M_PI/2 * (a.i / x.r) * pow(x.r, (-0.50));
	return x;
}

int main() {
	std::cout << ComplexRoot(ComplexAddition(ComplexAddition(ComplexAddition(ComplexAddition(ComplexAddition(ComplexAddition(ComplexExponentiation({0,1},1),ComplexExponentiation({0,1},1)),ComplexExponentiation({0,1},1)),ComplexExponentiation({0,1},1)),ComplexExponentiation({0,1},1)),ComplexExponentiation({0,1},1)),ComplexExponentiation({0,1},1)),ComplexExponentiation({0,1},1)),1);
	return 0;
}
