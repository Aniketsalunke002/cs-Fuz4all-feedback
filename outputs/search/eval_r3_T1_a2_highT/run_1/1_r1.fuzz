#include <iostream>

#include <queue>

using namespace std;

template <typename T>
class QueueWithMin : public queue<T> {
public:
  void push (T x)
  {
    if (this->empty() || x <= this->front ())
      this->queue<T>::push(x);
    else
    {
      this->queue<T>::push (this->front ());
      this->queue<T>::pop ();
      this->queue<T>::push (x);
    }
  }

  T top()
  {
    return this->front();
  }
  void pop()
  {
    this->queue<T>::pop();
  }
};