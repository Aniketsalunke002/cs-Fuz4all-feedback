#include <iostream>

using namespace std;
int main()
{
    int numa = 5;
    int numb = 6;
    int numc = 6;
    int numd = 6;
    
    if (numc < numb) {
        ++numc;
    } else if (numc == numb) {
        numd = numb + 1;      
    } else if (numb == numc){
        numb = numb + 5;
    }

    std::cout << numa << " " << numb << " " << numc << " " << numd << std::endl;
    return 0;
}