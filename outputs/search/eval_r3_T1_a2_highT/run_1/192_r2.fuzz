#include <iostream>

using namespace std;
int main()
{
	int input;
	cin >> input;
	if (input >= 0 && input <= 100) {
		input = 3 * -input;
		cout << "Value is : " << input << "\n"
		     << endl;
	} else {
		cout << "You may use it.\n";
	}
}
