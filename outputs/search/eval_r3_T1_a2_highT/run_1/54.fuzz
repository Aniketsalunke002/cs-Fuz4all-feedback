#include <iostream>
int main() {
	int mut=0;
	int winner=1;
	std::cout << "Press ENTER to start, any other key to quit.";
	switch(std::cin.peek()) {
	case '\n':
		break;
	case 'Q':
		std::cout << "Exiting..." << std::endl;
		return 0;
	case '\x1b':
		std::cout << "Exiting..." << std::endl;
		return 0;
	case '\t':
		std::cin.get();
	case '\b':
	default:
		std::cout << "Invalid input." << std::endl;
		break;
	}
	for(;;) {
		std::cin >> mut;
		std::cin.get();
		winner^=mut;
		if(winner!=1) {
			std::cout << (winner>>1) << ": [1][ ] is dead" << std::endl;
			winner=1;
		}else std::cout << mut << ": [1][ ] is live!" << std::endl;
	}
}