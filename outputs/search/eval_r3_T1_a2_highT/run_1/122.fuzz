#include <iostream>
using namespace std;
struct C {
    char a[27];
    void set_a(char s[]) {
        *a = *s;
    }
};
int main() {
    C s;
    s.set_a("1357");
    int i=0;
    int* p=&i;
     
    char buf[sizeof(i) + 1];
    for(int j=0;;j++) {
        if(buf[j] == '\0') break;
        if((int)*s.a++ == (int)*p++) {
            buf[j]=*s.a;
            return 1;
        }
    }
    return 0;
}
 
