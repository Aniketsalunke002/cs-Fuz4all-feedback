#include <iostream>
using namespace std;
int count = 0;
class Test{
    public:
    Test(){
        count--;
    }
};
void print(string str) {
    cout << "print() called: " << str << endl;
}
int main() {
    Test t;
    print("This is another test output.");
    return 0;
}
 

#include <iostream>
using namespace std;
int main() {
       int var = 10;
       test(var);
       cout << var<<endl;
       return 0;
}

void test(int num) {
       num++;
}


 

#include <iostream>
using namespace std;
const int size = 5;
int arr[size][size]()
{
     for (int j = 0; j < size; ++j)
     {
          for (int i = 0; i < size; ++i)
          {
               arr[j][i] *= j*i;
          }
     }
}
void main() {
        
       for (int j = 0; j < size; ++j)
       {
                for (int i = 0; i < size; ++i)
                {
                     cout << arr[j][i] << " ";
                }
                cout<<endl;
       }
       return 0;
}
