using namespace std;
class board
{
    public:
        char map[3][3]={'1','2','3','0','0','1','2','3','0'};
};
template <class B>
void display(B b)
{
    cout<<"\n";
    cout<<b.map[0][0]<<" | "<<b.map[0][1]<<" | "<<b.map[0][2]<<endl<<endl;
    cout<<"---"<<endl;
    cout<<"|"<<b.map[1][0]<<"|"<<b.map[1][1]<<"|"<<b.map[1][2]<<endl<<endl;
    cout<<"---"<<endl;
    cout<<"|"<<b.map[2][0]<<"|"<<b.map[2][1]<<"|"<<b.map[2][2]<<endl<<endl;
    cout<<"\n";
}
template <class B>
int empty_spots(B b)
{
    int count = 0;
    if(b.map[0][0]=='0')count++;
    if(b.map[0][1]=='0')count++;
    if(b.map[0][2]=='0')count++;
    if(b.map[1][0]=='0')count++;
    if(b.map[1][1]=='0')count++;
    if(b.map[1][2]=='0')count++;
    if(b.map[2][0]=='0')count++;
    if(b.map[2][1]=='0')count++;
    if(b.map[2][2]=='0')count++;
    return count;
}
