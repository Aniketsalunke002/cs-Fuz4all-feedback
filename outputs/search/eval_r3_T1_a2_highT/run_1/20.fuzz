#include <random>
#include <random>
#include <iostream>
#include <cstdlib>
using namespace std;
int get_random(int a, int b) {
    int rand_ = 0;
    static std::default_random_engine eng;
    static std::uniform_int_distribution<> distr(a, b);
    for (;;) {
        rand_ = distr(eng);
        if(rand_ >= a && rand_ <= b) return rand_;
    }
}
int main() {
    int x=283;
    cout<<"The random value is "<<get_random(1,283)<<endl;
    return 0;
}

 
