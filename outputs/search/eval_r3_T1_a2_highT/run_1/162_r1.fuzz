#include <iostream>

#include <algorithm>
#include <vector>
using namespace std;

int main() 
{
    int main()
    {
        int nums[] = {4, 3, 1, 0, 7};
        std::sort(std::begin(nums), std::end(nums));
        std::cout<<nums[0]<<std::endl;
        return 0;
    }
    main();
}
