#include <iostream>


int main() {
  int x = 0, y = 0, new_x = 0;
  std::cin >> x >> y;  // cin is now std::cin
  std::cout << x << '\n';
  if (x % 2!= 0) {
    new_x = (x - y) * 10000 + pow(1987, x) % 100;
  } else {
    new_x = x * y * 9876 + pow(1987, y) % 1000 % 100;
  }
  std::cout << new_x << '\n';
  return 0;
}