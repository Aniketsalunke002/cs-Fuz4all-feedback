#include <iostream>

#include <cmath>
int main() {
	std::cout << pow(-3,pow(2,-2)) << std::endl;
	std::cout << pow(-2,pow(4,-1)) << std::endl;
	std::cout << 2 << "\t" << -2 << std::endl;
	std::cout << 8 << "\t" << -8 << std::endl;
	return 0;
}
