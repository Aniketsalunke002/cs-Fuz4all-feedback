#include <iostream>
using namespace std;

 
void bubbleSort(int arr[], int numElements)
{
    for(int i = 0; i < numElements; ++i)
        for(int j = 0; j < (numElements - 1); ++j)
        {
            if(arr[j] > arr[j+1])
            {
                int temp;
                temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
   
}



 
