#include <iostream>
using namespace std;
class List
{
public:
    int values[100];
    int head = 0;
    int tail = 0;
    int size()
    {
        return tail - head;
    }
    void printList()
    {
        while (head!= tail)
        {
            cout << values[head] << endl;
            head++;
        }
    }
    void insert(int val)
    {
        if (size() == 0)
        {
            tail = head + 1;
            head = tail;
            values[head] = val;
        }
        else if (tail == head + 100)
        {
            int* newArr = new int[200];
            for (int i = 0; i < tail - head; i++)
            {
                newArr[i] = values[i];
            }
            head = 0;
            delete[] values;
            values = newArr;
            tail = head + tail - head;
            values[head + (tail - head)] = val;
        }
        else if (tail - head == 1)
        {
            head = head + 1;
            values[tail] = val;
            tail = head + tail - head;
        }
        else
        {
            values[tail] = val;
            tail = tail + 1;
        }
    }
    void remove()
    {
        if (tail - head == 0)
        {
            throw "out of bounds";
        }
        int val = values[head];
        head++;
        return val;
    }
};
int main()
{
    List list;

    list.insert(1);
    list.insert(2);
    list.insert(3);
    list.remove();
    list.printList();
    return 0;
}
 
 
 
 
 
 
 
 
