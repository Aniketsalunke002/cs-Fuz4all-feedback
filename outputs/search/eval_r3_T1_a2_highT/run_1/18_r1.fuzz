#include <iostream>


int main(){
    int x=0, y=0, new_x=0;
    std::cin>>x>>y;
    std::cout<<x<<std::endl;
    if(x%2!=0){
        new_x=((x-y)*10000)+(pow(1987,x))%100;
    }
    else{
        new_x=(x*y*9876)+(pow(1987,y)%1000)%100;
    }
    std::cout<<new_x<<std::endl;
}
// This will produce the ouput as follow:
// 0
// 0
// 8457
