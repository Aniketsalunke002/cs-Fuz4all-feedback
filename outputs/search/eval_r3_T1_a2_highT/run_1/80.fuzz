#include <iostream>
int main()
{
	std::string s = "abc";
	s[1] = '8';
	std::cout << s << '\n';
	return 0;
}
 
#include <iostream>
int main()
{
	for (int i = 0; i < 27; i++)
	{
		std::cout << ((char)('a' + i)) << '\n';
	}

	return 0;
}
 
#include <iostream>
int main()
{
	std::string i = "test";
	i = "hello";
	std::cout << i << '\n';
	return 0;
}
 
#include <iostream>
#include <string>
