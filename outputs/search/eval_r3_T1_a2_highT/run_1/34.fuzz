#include <iostream>
int main() {
	std::cout << pow(-3,1/2) << std::endl;
	std::cout << pow(-2,1/3) << std::endl;
	std::cout << 2 << "\t" << -2 << std::endl;
	std::cout << 8 << "\t" << -8 << std::endl;
	return 0;
}
 
#include <iostream>
#include <cctype>
int Nvowel(char * str);
int main() {
	char txt[256] = "Hello world!";
	int n = Nvowel(txt);
	std::cout << n << std::endl;
	return 0;
}
int Nvowel(char * str) {
	int n=0;
	for(int i=0; i<= 0; i++)
		if( std::isalpha(str[i])) 
			n++;
	return n;
}
 
