#include <iostream>
int main() {
	int counter=0;
	int winner=1;
	std::cout << "Press ENTER to start, any other key to quit.";
	while(std::toupper(std::cin.peek())!='Q') {
		std::cin >> counter;
		if(counter==0) {
			counter=3;
		}
		else if(counter==1) {
			counter=3+(winner%2);
		}
		else {
			counter=(counter-1)%3+1;
		}
		winner^=1;
		std::cout << counter << std::endl;
	}
	std::cout << "Exiting..." << std::endl;
	return 0;
}