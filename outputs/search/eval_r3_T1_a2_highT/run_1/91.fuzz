#include <iostream>
#include <vector>
#include <set>
#include <algorithm>
#include <cstdlib>
#include <cstring>
class Gene;
std::set<Gene *> Genes;
std::vector<Gene *> Generation;
class Gene{
public:
	Gene(bool c0,bool c1,int a_x, int a_y,int g,int i,int b){
		c[0] = c0;
		c[1] = c1;
		a = a_x;
		b = a_y;
		generation = g;
		id = i;
		fitnessScore = b;
	}
	bool operator ==(Gene &b){
		if(c[0] == b.c[0]&& c[1] = b.c[1]&& a == b.a&& b.b== b.a&&generation == b.generation&&id==b.id&&fitnessScore==b.fitnessScore){
			return true;
		}
		return false;
	}
	Gene mutated(){
		Gene *a1;
		a1 = new Gene(c[0],c[1], a,b,generation,id,fitnessScore);
		int r = (std::rand()%2);
		int r1 = (std::rand()%2);
		char ch = "b";
		int a,b;
		if(r){
			ch = "a";
		}
		a1->id = id;
		a1->c[0] = r;
		a1->c[1] = r1;
		a = (r? b: a);
		b = (r? a: b);
		a1->a = a;
		a1->b = b;
		*((char*)&ch) = (char)(r==1);
		*((char*)&ch+1) = (char)(r1==1);
		*((char*)&ch+2) = (char)(c[0] == 0);
		*((char*)&ch+3) = (char)(c[1] == 1);
		a1->fitnessScore = a + b;
		Genes.insert(a1);
		return *a1;
	}
	static int getFitness(Gene a1){
		return a1.fitnessScore;
	}
	void operator =(Gene &a