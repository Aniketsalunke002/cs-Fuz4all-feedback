#include <iostream>

using namespace std;
int main(int argc, char* argv[]) {
    string s("hello\ntoday\nhow are you");
    cout << '\n' << s << " " << s[2] << s.substr(4, 3) << "\n\n" << s[2+2] << s[2+2+2] << s.substr(2, 3) << s[4+1 - 1 - 1 + 1];
    return 0;
}

