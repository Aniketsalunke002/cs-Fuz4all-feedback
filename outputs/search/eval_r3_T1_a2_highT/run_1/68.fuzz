#include <iostream>
int main() {
	int mut_var{1};
	do {
		std::cin >> mut_var;
		if (!std::cin.fail()) {
			std::cout << mut_var;
		}
	} while (mut_var!=-1);
	std::cout << '\n';
	return 0;
}
 
#include <iostream>
#include <array>
int main() {
	using table = std::array <char, 32> ;
	int size = 32;
	table mut_table= {};
	for (int i=0; i<size; i++) {
		mut_table[i]= '0'+i;
		std::cout << mut_table[i] ;
	}
	std::cout << '\n';
	return 0;
}
