#include <iostream>

using namespace std;
class List
{
  public:
    int values[100];
    int head = 0;
    int tail = 0;
    int size()
    {
        return tail - head;
    }
    void printList()
    {
        while (head!= tail)
        {
            cout << values[head] << endl;
            head++;
        }
    }
    void insert(int val)
    {
        if (size() == 0)
        {
            tail = head + 1;
            head = tail;
            values[head] = val;
        }
        else if (tail == head + 100)
        {
            int* newArr = new int[200];
            for (int i = 0; i < tail - head; i++)
            {
                newArr[i] = values[i];
            }
            head = 0;
            delete[] values;
            values = newArr;
            tail = head + tail - head;
            values[head + (tail - head)] = val;
        }
        else if (tail - head == 1)
        {
            head = head + 1;
            values[head] = val;
            tail = head + tail - head;
        }
        else
        {
            values[tail] = val;
            tail++;
        }
    }
    void remove()
    {
        if (tail - head == 0)
        {
            throw "out of bounds";