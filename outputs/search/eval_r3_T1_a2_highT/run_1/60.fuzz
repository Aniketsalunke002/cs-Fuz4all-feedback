#include <iostream>
int main() {
	int mut_var=0;
	do {
		printf("%d: [0] [%d] is live!\n", __LINE__, mut_var);
		printf("Enter 2 things separated by commas or a number for mutability:\n");
		printf("1) Print to screen\n2) Read stdin\n3) Mutate var (mutate only if it's > 0!)\n");
		char dummy;
		std::cin >> dummy;
		if (!std::cin) {
			std::cerr << "Got error: '" << std::cin.rdstate() << "'" << std::endl;
			break;
		} else {
			if (dummy=='1') {
				printf("1: Print to stdout\n");
				std::cout << mut_var << "\n";
			}
			if (dummy=='2') {
				printf("2: Read from stdin\n");
				std::cin >> mut_var;
			}
			if (dummy=='3') {
				printf("3: Perform mutation\n");
				if (mut_var > 0) {
					std::cout << mut_var << "\n";
					mut_var++;
				}
			}
		}
	} while(1);

	return 0;
}
