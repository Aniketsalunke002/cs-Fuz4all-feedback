#include <iostream>
int main() {
	int x, y;
	do {
		std::cout << "Please enter a number: ";
		std::cin >> x;
		std::cin.clear();
		if(x!= -1) {
			switch(x & 3) {
			case 0:
			case 1:
				std::cin.ignore(std::numeric_limits<std::streamsize>::max(), '\n');
				std::cout << "Please enter another number: ";
				std::cin >> y;
				std::cin.clear();
				std::cout << "The result is " << ((x&1)? y : ~y) << std::endl;
				break;
			case 2:
				std::cout << ((y = ~y, y)? "YES" : "NO") << std::endl;
				break;
			}
		}
	} while(x!= -1);
	return 0;
}