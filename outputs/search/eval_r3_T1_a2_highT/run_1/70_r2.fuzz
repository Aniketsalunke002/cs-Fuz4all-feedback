#include <iostream>

int main() {
	int a;
	bool b;
	cin >> a;
	if (cin.eof()) {
		b = 0;
	} else {
		b = 1;
	}
	if (!cin) {
		std::cout << -1;
	} else {
		std::cout << a;
	}
	if (b == 1) {
		cin >> a;
	}
	while (cin) {
		if (b == 1) {
			cin >> a;
		}
		std::cout << a << std::endl;
	}
	if (a == -1) {
		return 0;
	}
	return 1;
}