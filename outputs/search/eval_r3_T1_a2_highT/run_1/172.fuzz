#include <iostream>
using namespace std;
int main() 
{
    double num = 0.9;
    num = num * 1000000;
    cout << num << endl;
    return 0;
}
 
#include <iostream>
#include<vector>
using namespace std;
int main()
{
    vector <double>vec;
    vec.push_back(1.1);
    vec.push_back(2.2);
    vec.push_back(3.3);
    vec.push_back(4.4);

    for(auto it=vec.begin();it!=vec.end();++it)
    {
        cout<<"the value in this position: "<<*it<<endl;
    }
    return 0;
}

 
#include <iostream>
#include <vector>
using namespace std;
int main()
{
    float ar[] = {2.3, 22.2, 5.5};
    vector<float> vec(ar, ar + sizeof(ar)/sizeof(float));
    return 0;
}