#include <iostream>
using namespace std;
int main()
{
	char input;
	cin >> input;
	if input == 'a' || input == 'e' || input == 'i' || input == 'o' || input == 'u' || input == 'y' {
		cout << "You may use it.\n";
	} else {
		cout << "You may not use it.\n";
	}
} 
