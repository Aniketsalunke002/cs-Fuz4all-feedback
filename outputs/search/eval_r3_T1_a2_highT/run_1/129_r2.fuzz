#include <iostream>

using namespace std;
const int size = 5;
int count = 0;
int arr[size][size]()
{
     for (int j = 0; j < size; ++j)
     {
          for (int i = 0; i < size; ++i)
          {
               arr[j][i] *= j*i;
          }
     }
}
void main() {
        
     for (int j = 0; j < size; ++j)
     {
              for (int i = 0; i < size; ++i)
              {
                   cout << arr[j][i] << " ";
              }
              cout<<endl;
     }
     return 0;
}
