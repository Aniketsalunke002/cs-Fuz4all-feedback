#include <iostream>

#include <queue>

using namespace std;

template <typename T>
class QueueWithMin : public queue<T>
{
public:
    void push(T x)
    {
        if(empty() || x <= top())
            queue<T>::push(x);

        else
        {
            queue<T>::push(top());
            queue<T>::pop();
            queue<T>::push(x);
        }
    }

    T top()
    {
        return queue<T>::front();
    }

    void pop()
    {
        queue<T>::pop();
    }
};