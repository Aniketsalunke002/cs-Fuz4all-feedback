#include <iostream>
#include <vector>
#include <set>
#include <algorithm>
class Genome;
std::set<Genome *> Genomes;
class Organism
{
public:
	float fitness;
	Organism() {}
	Organism(float f) {
		fitness = f;
	}
};
class Genome
{
public:
	void mutate() {
		std::cout << "Mutating..." << '\n';
	}
	virtual ~Genome() {   }
	static void addGenome(Genome *p) {
		Genomes.insert(p);
	}
	static void delGenome(Genome *p) {
		Genomes.erase(p);
	}
private:
	char pad[10000];
};
class Tiger: public Genome
{
public:
	void mutate() {
		std::cout << "Clobbered...." << '\n';
	}
	~Tiger() {   }
	static void addGenome(Genome *p) {
		Genomes.insert(dynamic_cast<Tiger *>(p));
		std::cout << "A Tiger gen." << '\n';
	}
	static void delGenome(Genome *) {
		std::cout << "Tiger gen erased!" << '\n';
	}
private:
	char pad1[10000];
};
