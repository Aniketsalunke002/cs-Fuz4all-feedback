#include <iostream>
int main() {
	for(;;) {
		std::cout << "Press ENTER to play, any other key to quit.";
		switch(std::toupper(getchar())) {
		case '\n':
			break;
		case 'Q':
			std::cout << "Exiting..." << std::endl;
			return 0;
		case '\x1b':
			std::cout << "Exiting..." << std::endl;
			return 0;
		case '\t':
			;
		case '\b':
		default:
			std::cout << "Invalid input." << std::endl;
			break;
		}
	}
	return 0;
}
