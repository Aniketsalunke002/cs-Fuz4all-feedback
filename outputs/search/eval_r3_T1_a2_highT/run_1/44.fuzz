#include <iostream>
int main() {
	int max;
	for(;;) {
		std::cin >> max;
		for(int i = 0; i < max; i++)
			for(int j = 0; j < max; j++) 
				std::cout << ((std::rand()%2) == 0? '#' :'');
		std::cout << std::endl;
	}
	return 0;
}
 
