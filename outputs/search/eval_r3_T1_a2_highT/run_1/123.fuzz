#include <iostream>
using namespace std;
int main() {
    bool a1=(bool) std::string("t") [0];
    cout << a1 << endl;
    bool a2=(bool) std::string("T") [0];
    cout << a2 << endl;

    int i1= (bool) std::string("1") [0];
    cout << i1 << endl;

    char c=(bool) std::string("f") [0];
    cout << c << endl;

     
    
    return 0;
}
 
