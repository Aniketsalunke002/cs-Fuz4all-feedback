#include <iostream>
#include <stack>
using namespace std;
int main() {
    stack<int> ss;
    for(int i = 0; i < 10; i++) {
        ss.push(i);
    }
    while(!ss.empty()) {
        cout<<ss.top()<<" ";
        ss.pop();
    }
}
#include <iostream>
using namespace std;
int main() {
    std::string name = "Zhang";
    cout<<name[0]<<":"<<name.substr(1,2)<<":"<<name[0]+name[1]+name[2];
}
