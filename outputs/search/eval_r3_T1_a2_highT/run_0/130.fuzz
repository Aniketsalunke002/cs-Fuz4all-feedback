#include<iostream>
using namespace std;
class Myclass {
    int a;
public:
    Myclass() {
      a=5;
    }
    Myclass(int x) {
      a=x;
    }
    int getA() {
      return a;
    }
};
int main() {
  Myclass obj1;
  cout<<"Value is: "<<obj1.getA()<<endl;
  Myclass obj2(10);
  cout<<"Value is: "<<obj2.getA()<<endl;  
  return 0;
}
 
