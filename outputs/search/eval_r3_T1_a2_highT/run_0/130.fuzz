#include<iostream>
using namespace std;
int main() {
    string sentence;
    while(getline(cin, sentence))
    {
        cout<<sentence<<endl;
        transform(sentence.begin(), sentence.end(), sentence.begin(), ::toupper);
        cout<<sentence<<endl;
        transform(sentence.begin(), sentence.end(), sentence.begin(), ::tolower);
        cout<<sentence<<endl;
        if(sentence[0] >= 'a' && sentence[0] <= 'z'){
          while (sentence[0] >= 'a' && sentence[0] <= 'z'){
            sentence.pop_back();
          }
          cout<<sentence<<endl;
          while (sentence[0] >= 'A' && sentence[0] <= 'Z'){
            sentence.pop_back();
          }
          cout<<sentence<<endl;
        }
    }
    return 0;
}
 
#include<iostream>
using namespace std;
int main() {
    int x[20],y[20],n,q,i,count;
    cin>>n;
    for (i = 0; i < n; i++)
    {
    cin>>x[i];
    cin>>y[i];
    }
    cin>>q;
    for (i = 0; i < q; i++)
    {
    cin>>count;
    while (count>0)
    {
    int tempx=0,tempy=0;
    for (int a = 0; a < count; a++)
    {
    cin>>tempx;
    cin>>tempy;
    cout<<x[tempx-1]<<" "<<y[tempy-1]<<"\n";
    }
    count=count-count;
    }
    }
    return 0;
}
 
