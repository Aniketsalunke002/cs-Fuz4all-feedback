#include <iostream>
double getDouble(const char *str) {
    char *endptr;
    double val = std::strtod(str, &endptr);
    if (str == endptr) {
        std::cout << "Invalid input: " << val << "\n";
        return -1;
    }
    return val;
}

int main(int argc, char const *argv[]) {
    int val1 = 1 * getDouble(argv[1]);
    int val2 = 2 * getDouble(argv[2]);
    int val3 = 3 * getDouble(argv[3]);
    std::cout << val1 <<'' << val2 <<'' << val3 << std::endl;
    return 0;
}
