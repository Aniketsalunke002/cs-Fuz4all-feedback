#include <iostream>
 void __VERIFIER_assume(int cond) {
  #if __VERIFIER_assume_fail==VERIFIER_ASSUME_FAIL_ABORT
 abort();
  #else
 if(!(cond)) { fprintf(stderr, "ERROR: Failed assumption '%s' at %s:%i\n", #cond, __FILE__, __LINE__);exit(1); }
  #endif
}
int main() {
   short x;
   std::cin >> x;
   __VERIFIER_assume(x >= 0 && x <= 32767);
   x += 3;
   std::cout << x;
}
