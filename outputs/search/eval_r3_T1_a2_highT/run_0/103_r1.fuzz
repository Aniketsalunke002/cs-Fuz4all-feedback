#include <iostream>
#include <unistd.h>
int __attribute__ ((noinline))  main(){
  size_t  size;
  char*  ptr;
  
  size = getpagesize();
  ptr = (char *)malloc(size);
  ptr -= 3;
  
  return 0;
}