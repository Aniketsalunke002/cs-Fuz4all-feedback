#include <iostream>
using namespace std;
class A
{
    public:
    A(int i) : a(i) {}
    virtual int f()
    {
      return a;
    }
    int a;
};
class B : public A
{
    public:
    B(int i) : A(i)
    {
        b = i * 2;
    }
    int f()
    {
      return a * 2;
    }
    int b;
};
int main()
{
  B *pr = new B(10);
  cout << pr->f() << " " << pr->a << " " << pr->b << endl;
  cout << pr->f() << " " << pr->a << " " << pr->b << endl;
  return 0;
}
