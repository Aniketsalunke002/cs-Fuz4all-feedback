#include <iostream>
using namespace std;
class Car {
private:
  int wheels;

public:
  Car(int wheels = 0) {
    this->wheels = wheels;
  }
  int getWheels() {
    return wheels;
  }
};
Car car;
static int wheels = 4;
Car car1(4);
int main() {
  car.getWheels();
  car = Car(3);
  return 0;
}
 
