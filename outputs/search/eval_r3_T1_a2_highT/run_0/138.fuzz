#include <iostream>
using namespace std;
int main() {
    int a;
    float b, c;
    cout<<"Number: ";
    scanf("%d, %f, %f", &a, &b, &c);
    printf("%d + %f + %f = %f\n", a, b, c, a+b+c);
}
#include <iostream>
using namespace std;
int main() {
    int a;
    float b;
    cout<<"Number: ";
    scanf("%d\n%f\n", &a, &b);
    cout<<a<<b<<endl;
}