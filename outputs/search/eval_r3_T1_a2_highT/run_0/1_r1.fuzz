#include <iostream>


#include <algorithm>
#include <string>

void print_vector(const char* name, const std::vector<double>& vs) {
  std::cout << name << std::endl;
  std::copy(vs.begin(), vs.end(), std::ostream_iterator<double>(std::cout, ","));
  std::cout << std::endl;
}

void test(const std::string& name, std::vector<double>& vs) {
  print_vector(name.c_str(), vs);

  vs.push_back(1);
  vs.push_back(1);
  vs.push_back(1);
  vs.push_back(1);
  vs.push_back(1);
  vs.push_back(1);
  print_vector(name.c_str(), vs);
}

void test3(std::vector<int>&& vs) {
  print_vector("vs", vs);

  vs.erase(std::move(vs.begin() + 4), std::move(vs.begin() + 5));
  print_vector("vs", vs);
}

int main() {
  test("test", std::vector<double>());
  std::vector<double> vd;
  vd.push_back(1);
  vd.push_back(1);
  vd.push_back(1);
  vd.push_back(1);
  vd.push_back(1);
  vd.push_back(1);
  test("vd", vd);
  std::vector<double> vvd { 1.1, 2.1, 3.1, 4.1 };
  test("vvd", vvd);
  test("vvv", { 1.1, 2.1, 3.1, 4.1 });
  test3({ 1,