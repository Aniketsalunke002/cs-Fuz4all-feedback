#include <iostream>
#include <cstdlib>
int main()
{
	int a[3][2] = {0}, b[2][2]= {0};
  a[2][1] = 20;
  b[0][0] = a[2][1];
  for (int i = 0; i < 3; i++) {
     std::cout << " [" << b[i][0] << "] = " << b[i][1];
  }
	return EXIT_SUCCESS;
}
 
#include <iostream>
#include <cstdlib>
int main()
{
	int a[2][2]= {0};
  a[1][1] = 20;
  std::cout << "b = [" << a[1][0] << "] = " << a[1][1];
	return EXIT_SUCCESS;
}
