#include <iostream>
int main()
{
  int a[] = {1, 2, 3};
  a[2] = 4;
  for (long i = ((a[(sizeof(a) / sizeof(a[0])) - 1]) - 1); i >= ((a[0]) + 1); i--) {
    if (i < 10) {
      std::cout << i;
    } else {
      std::cout << i << " ";
    }
  }
}
 
#include <iostream>
int main()
{
  int a[] = {2, 4, 9};
  for (long i = ((a[(sizeof(a) / sizeof(a[0])) - 1]) - 1); i >= ((a[0]) + 1); i--) {
    if (i%2==1) {
      std::cout << i; 
    }
  }
}
