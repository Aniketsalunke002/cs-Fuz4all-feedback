#include <iostream>

using namespace std;
class A {
    private:
    int a;
    public:
    A(int i) : a(i) {}
    virtual int f() {
        return a;
    }
};
class B : public A {
    private:
    int b;
    public:
    B(int i) : A(i)
    {
        b = i + 1;
    }
    int f() {
        return a + 1;
    }
};
int main() {
    B *pr = new B(10);
    cout << pr->f() << " " << pr->a << " " << pr->b << endl;
    cout << pr->f() << " " << pr->a << " " << pr->b << endl;
    return 0;
}