#include <iostream>
struct S
{
  int i, j;
  S(int x, int y)
  {
    i = x;
    j = y;
  }
};
int main()
{
  S s(1, 2);
  s.i = 15;
  std::cout << s.i;
  return 0;
}
 
#include <iostream>
int main(int argc, char *argv[])
{
  const int n = 4;
  int x = 0x1234;
  int arr[n] = {0xab, 0xcd, 0xef, 0xc1};
   
  for (int i = 0; i < n; i++)
  {
    if (arr[i] == x)
    {
      std::cout << "Found " << x << '\n';
      break;
    }
    else if (arr[i] < x)
      std::cout << 'l' << '\n';
      else
        std::cout << 'g' << '\n';
  }
}
 
#include <iostream>
#include <string_view>
#include <cstdint>
std::int8_t fibonacci(std::uint8_t prev, std::uint8_t next){
    return (prev+next);
}
std::int8_t sumfib(std::uint8_t a=0, std::uint8_t b=1){
    std::uint8_t sum=b;
    while ( (sum <= 4000000) && fibonacci(a,b)!=0)
    {
        std::uint8_t z=fibonacci(a,b);
        a=b;
        b=z;
        sum=b+a;
    }
    return sum;
}
int main(){
   std::cout<<sumfib()<<std::endl;
   return 0;
}
