#include <iostream>

 
#include <algorithm>
#include <string>
 
void print_vector(const char* name, std::vector<double>& vs) {
	std::cout << name << std::endl;
	std::cout << vs.size() << std::endl;
	std::copy(vs.begin(), vs.end(), std::ostream_iterator<double>(std::cout, ","));
	std::cout << std::endl;
}
 
int main() {
	std::vector<double> vs;
	print_vector("std::vector<double>", vs);
	print_vector("std::vector<double>", { 1, 2, 3 });
	print_vector("std::vector<double>", { 1, 2, 3, 4, 5 });
	print_vector("std::vector<int>", { 1,2,3,4,5,6 });

	std::vector<std::string> vsn;
	print_vector("std::vector<std::string>", vsn);
	print_vector("std::vector<std::string>", { "1", "2", "3" });
	print_vector("std::vector<std::string>", { "1", "2", "3", "4", "5" });
	print_vector("std::vector<std::string> ", { "1","2","3","4","5","6" });

	std::vector<std::string> names{"A","B","C","D","E","F"};
	print_vector("names", names);

	return 0;
}