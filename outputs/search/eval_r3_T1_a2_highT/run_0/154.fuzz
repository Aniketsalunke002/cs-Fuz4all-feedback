#include <iostream>
using namespace std;
int main() {
  int n = 0;
  while (1) {
    cout << "turing n=" << n << endl;
    n++;
    if (n % 4 == 0) {
      cout << "4" << endl;
    } else {
      cout << "3" << endl;
    }
  }
  cout << "hello" << endl;
  cout << n << endl;
}
 
#include <iostream>
using namespace std;
int main() {
  for (int i=0; i<4; i++) {
    for (int j=0; j<4; j++) {
      cout << "2";
    }
    cout << endl;
  }
  for (int i=0; i<4; i++) {
    for (int j=0; j<4; j++) {
      cout << "4";
    }
    cout << endl;
  }
}
