#include <iostream>
int main()
{
  int a=0,b=1;
  long long total=0;
  for (int i=0; i<10000; i++)
  {
    a=a+b;
    b=b+a;
    total=total+a;
  }
  (total % 1000000);
  std::cout<<total;
  return 0;
}
 
#include <array>
#include <algorithm>
#include <iostream>

int main()
{
  std::array<long long, 10000> a;
  for (int i=0; i<10000; i++)
    { a[i]=a[i]+a[i-1]; }
  long long total=0;
  for (int i=9999; i>=-9999; i--)
    { total+=a[max(0, min(9999, std::abs(i)))]; }
  total%=1000000;
  std::cout<<total;
  return 0;
}
