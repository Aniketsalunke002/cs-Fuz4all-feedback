#include <iostream>

#include <algorithm>
#include <string>

void print_vector(const char* name, std::vector<double>& vs) {
	std::cout << name << std::endl;
	std::cout << vs.size() << std::endl;
	std::copy(vs.begin(), vs.end(), std::ostream_iterator<double>(std::cout, ","));
	std::cout << std::endl;
}

void test(const std::string& name, std::vector<double>& vs) {
	vs.push_back(1);
	vs.push_back(1);
	vs.push_back(1);
	vs.push_back(1);
	vs.push_back(1);
	vs.push_back(1);
	print_vector(name.c_str(), vs);
}

 

 
 

 
 

 
void test3(std::vector<int>&& vs) {
	print_vector("vs", vs);  
	vs.erase(std::move(vs.begin() + 4), std::move(vs.begin() + 5));  
	print_vector("vs", vs);
}

int main() {
	test("test", std::vector<double>());
	test("test", { 1, 2, 3 });
	test("test", { 1, 2, 3, 4, 5 });
	std::vector<int> vv { 1, 2, 3, 4, 5 };
	test("vv", vv);
	std::vector<double> vd;
	test("vd", vd);
	test3({ 1,2,3,4,5,6 });

	return 0;
}
