#include <iostream>
 void __VERIFIER_assume(int cond) {
  if(!(cond)) {
     ERROR: goto ERROR;
  }
}
class C {
 int *a;
 public:
 int *operator&() const {
  return a;
 }
 C& operator=(int data[10]) {
  a = data;
  return *this;
 }
 int& operator[](int i) const {
  return a[i];
 }
};
int main() {
 int a[2];
 int b[2][3];
 int c[2][3][4];
 C x;
 x = a;
 __VERIFIER_assert(*(x[0] + 1) == a[0]);
 __VERIFIER_assert(*(x[1] + 1) == a[1]);
 x = b;
 __VERIFIER_assert(*(x[0][0] + 1) == b[0][0]);
 __VERIFIER_assert(*(x[0][1] + 1) == b[0][1]);
 __VERIFIER_assert(*(x[0][2] + 1) == b[0][2]);
 __VERIFIER_assert(*(x[1][0] + 1) == b[1][0]);
 __VERIFIER_assert(*(x[1][1] + 1) == b[1][1]);
 __VERIFIER_assert(*(x[1][2] + 1) == b[1][2]);
 x = c;
 __VERIFIER_assert(*(x[0][0][0] + 1) == c[0][0][0]);
 __VERIFIER_assert(*(x[0][0][1] + 1) == c[0][0][1]);
 __VERIFIER_assert(*(x[0][0][2] + 1) == c[0][0][2]);
 __VERIFIER_assert(*(x[0][0][3] + 1) == c[0][0][3]);
 __VERIFIER_assert(*(x[0][1][0] + 1) == c[0][1][0]);
 __VERIFIER_assert(*(x[0][1][1] + 1) == c[0][1][1]);
 __VERIFIER_assert(*(x[0][1][2] + 1) == c[0][1][2]);
 __VERIFIER_assert(*(x[0][1][3] + 1) == c[0][1][3]);
 __VERIFIER_assert(*(x[0][2][0] + 1) == c[0][2][0]);
 __VERIFIER_assert(*(x[0][2][1] + 1) == c[0][2][1]);
 __VERIFIER_assert(*(x[0][2][2] + 1) == c[0][2][2]);
 __VERIFIER_assert(*(x[0][2][3] + 1) == c[0][2][3]);
 __VERIFIER_assert(*(x[1][0][0] + 1) == c[1][0][0]);
 __VERIFIER_assert(*(x[1][0][1] + 1) == c[1][0][1]);
 __VERIFIER_assert(*(x[1][0][2] + 1) == c[1][0][2]);
 __VERIFIER_assert(*(x[1][0][3] + 1) == c[1][0][3]);
 __VERIFIER_assert(*(x[1][1][0] + 1) == c[1][1][0]);
