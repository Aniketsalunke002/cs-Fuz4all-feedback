#include <iostream>

int main(int argc, char *argv[]) {

  const int n = 4;
  int x = 0x1234;
  int arr[n] = {0xab, 0xcd, 0xef, 0xc1};  
  for (int i = 0; i < n; i++) {
    if (arr[i] == x) {
      std::cout << "Found " << x << '\n';
      break;
    } else if (arr[i] < x)
      std::cout << 'l' << '\n';
    else
      std::cout << 'g';
  }

  return 0;

}

