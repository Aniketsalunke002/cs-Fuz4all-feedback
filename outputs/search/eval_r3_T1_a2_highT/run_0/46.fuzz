#include <iostream>
int main()
{
   int a=0,b=1;
   for (int i=0; i<10000; i++)
   {
      a=a+b;
      std::swap(a,b);
      if (i==4567)
         a=7890;
      if (i==8447)
         a=5579;
   }
   return 0;
}
 
#include <iostream>
template <typename A> class A
{
public:
   void add(int, int) {};
   int& operator[](int x) { return a[x]; }
private:
A<int> a;
};
int main()
{
   int a[100],b[20]; A<int> c;
   for (int i=0; i<100; i++)
   {
      a[i]=0;
      b[i]=1;
      c.add(a[i],b[i]);
   }
   return 0;
}
