#include <bits/stdc++.h>
using namespace std;
void insert(list<int> l, int n)
{
  l.push_back(n);
  cout << l << endl;
}
void reverse(list<int> l)
{
  l.reverse();
  cout << l << endl;
}
int main()
{
  list<int> l1;
  list<int> l2;
  l2.push_front(10);
  insert(l1, 10);
  insert(l1, 20);
  insert(l1, 30);
  l1.splice(l1.end(), l2);
  l1.splice(l1.end(), l2);
  l1.splice(l1.end(), l2);
  reverse(l1);
  return 0;
}
 
#include <bits/stdc++.h>
using namespace std;
int sumEvenNumbers(int n)
{
  int sum = 0;
  int counter = 0;
  while (counter < n) {
    sum += counter;
    counter++;
  }
  return sum;
}
int main()
{
  int n;
  cin >> n;
  cout << "The sum is " << sumEvenNumbers(n) << endl;
  return 0;
}
 
