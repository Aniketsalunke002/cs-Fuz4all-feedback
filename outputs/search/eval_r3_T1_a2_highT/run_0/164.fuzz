#include <iostream>
using namespace std;
int main()
{
  int n = 5;
  int x = 0;
  for (int i = 1; i < 8; i++, n = n + 2) {
    if (i < 5) {
      x = x + 1;
    }
    if (i > 5) {
      x = x + 1;
    }
    if (i == 6) {
      x = x + 1;
    }
    if (i < 7) {
      x = x + 1;
    }
    if (i == n) {
      x = x + 1;
    }
  }
  return 0;
}
 
 
