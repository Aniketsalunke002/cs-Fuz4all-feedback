#include <iostream>
using namespace std;
class A{
	private:
		int iField1=777;
		int iField2=1000;
	public:
		A(){};
		A(A &r){
			iField1=r.iField1-10;
			iField2=r.iField2-3;
			cout<<iField1<<' '<<iField2<<endl;
		};
		A& operator=(A&r){
			iField1=r.iField1;
			iField2=r.iField2+4;
			return *this;
		}
};
