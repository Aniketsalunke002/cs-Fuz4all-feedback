#include <iostream>

#include <functional>
#include <algorithm>
using namespace std;
template <typename T>
class B 
{
public:
    T fField;
    void print() {cout<<fField<<endl;}
};
template <typename T>
class C: public B<T>
{
public:
    void print() {cout<<fField*2<<endl;}
};
int main()
{
    int n=10;
    vector<unique_ptr<B<int>>> b1;
    for(int i=0;i<n;++i)
    {
        auto b(make_unique<B<int>>());
        b->fField=rand();
        b1.push_back(move(b));
    }
    vector<unique_ptr<C<int>>> c1;
    transform(b1.begin(), b1.end(),back_inserter(c1),[](unique_ptr<B<int>>& p)->unique_ptr<C<int>>
    {
        return make_unique<C<int>>(*p);
    });
    for_each(c1.begin(),c1.end(),[](unique_ptr<B<int>>& p)
    {
        p->print();
    });
    return 0;
}