#include <iostream>
class A
{
    public:
        A():val("HOLA")
        {}
        A(const std::string& val_)
        :val(val_)
        {}
        auto& getVal()
        {
            return val;
        }
        void setValue(const std::string& val_)
        {
            val = val_;
        }
    private:
        std::string val;
};
int main(int argc, char *argv[])
{
    A object("QUE TAL");
    std::cout << object.getVal();
    object.setValue("HOLA");
    std::cout << object.getVal();
    return 0;
}


