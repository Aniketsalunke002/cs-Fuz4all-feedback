#include <iostream>

template<typename T>
class A
{
    public:
        A(T t):val(t)
        {}
        auto& getVal()
        {
            return val;
        }
    private:
        T val;
};
void print_A(const A<std::string>& object)
{
    std::cout << object.getVal();
}
int main(int argc, char *argv[])
{
    print_A(A<std::string>("HOLA"));
    return 0;
}

