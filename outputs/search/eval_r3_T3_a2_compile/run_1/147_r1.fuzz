#include <iostream>

#include <vector>
#include <stdlib.h>  
template <typename T>
class Cell {
public: 
  T c;
  T f;
};

template <typename T>
Cell<T> * cells = (Cell<T> *)malloc(sizeof(Cell<T>));

int main(int argc, char * argv[]) {
  int a = rand() % 100; 
  cells<int> -> c = a; 
  cells<int> -> f = 99; 
  std::cout << cells<int> -> c << '\n';
  std::cout << cells<int> -> f << '\n';
}