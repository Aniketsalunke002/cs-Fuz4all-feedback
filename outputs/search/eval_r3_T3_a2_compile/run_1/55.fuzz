#include <iostream>
template<typename... Types>
void print(const Types&... vals);
int main(void)
{
	print(1,'a','b','c','d','e');
	print(2,'a','b','c','d','e');
	print(3,'a','b','c','d','e');
	return 0;
}
 
#include <iostream>
template<typename... Types>
void print(const Types&... vals);
int main(void)
{
	auto str = "Hello";
	auto x = print("1111",444.4,121315, str);  
	return 0;
}
