#include <iostream>


template <class T>
int main() {
	T x = 5;
	T y = x * 5 / 6;
	x = 3 * x + 2 * 6 - x / 5 + y / 9;
	x = x * 5 + y;
	y = x * -1.1429 + 1;
	return x;
}

int main() { return 0; }

int main(int argc, char *argv[]){
	for(int i=0; i<argc; i++)
		std::cout << "Hello World\n";
	return 0;
}

int main() {
	int x, y, z;
	std::cin >> x;
	std::cin >> y;
	std::cin >> z;
	x += z % 3;
	std::cout << x % 8;
	return x;
}

