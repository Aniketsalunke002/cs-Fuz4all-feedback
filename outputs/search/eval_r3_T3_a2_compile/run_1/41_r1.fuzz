#include <iostream>

template<typename T>
void printArray (T* array, size_t size) {
	for (size_t i=0; i<size; i++) {
		std::cout << array[i] << std::endl;
	}
}
int main (void) {
	int arr[]={1,2,3,4,5,6};
	int size=sizeof(arr)/sizeof(arr[0]);
	printArray(arr, sizeof(arr)/sizeof(arr[0]));
	arr[2]=0;
	printArray(arr, sizeof(arr)/sizeof(arr[0]));
	return 0;
}