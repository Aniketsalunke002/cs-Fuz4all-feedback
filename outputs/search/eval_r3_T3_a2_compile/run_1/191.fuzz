#include <iostream>
#include <string>
#include <vector>
int main(int argc, char *argv[])
{
    int x = 1000000;
    std::string str = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    std::cout << "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    for (int i = 1; i<x; i++)
    {
        if (str[i-1]==str[i])str[i-1] = -126;
        std::cout << str[i-1];
    }
    std::cout << std::endl;
    return 0;
}
