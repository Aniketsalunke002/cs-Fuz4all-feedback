#include <iostream>
#include <vector>
class Foo
{
  public:
	Foo() {x = 5;}
	void Mutate() { x += 10; }

  private:
	int  x;
};
void MutateHelper(Foo* x)
{
	x->Mutate();
}
int main()
{
	Foo* x = new Foo();
	int z = MutateHelper(x);
	std::cout << x->x << std::endl;
	return 0;
}
 
#include <vector>
void Append(std::vector<int>& v, int x) {
	for (int i = 0; i < 100; ++i)
	{
		v.push_back(x);
	}
}
std::vector<int> GetVector() {
	std::vector<int> v;
	std::rand();
	Append(v, 100);
	return v;
}

void f() {
	std::rand();
}

std::vector<int> GetVector2() {
	f();
	std::vector<int> v;
	Append(v, 99);
	return v;
}
