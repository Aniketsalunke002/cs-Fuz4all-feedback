#include <iostream>
using namespace std;
class A
{
    private:
    	int iField1;
    	int iField2;
    public:
    	A():iField1(777){iField2=999;}
	A(int b):iField1(b){iField2=1;cout<<"default ctor used"<<endl;}
	A(A &r): iField1(r.iField1),iField2(r.iField2-1){cout<<iField1<<' '<<iField2<<endl;}
	A& operator=(int b)
	{
		iField2=b;
		return *this;
	}
};

A f(A& param)
{
	return param;
}
 
#include <iostream>
using namespace std;
class A
{
    private:
    	int iField1;
    	int iField2;
    public:
    	A():iField1(777){iField2=999;}
	A(int b):iField1(b){iField2=1;cout<<"default ctor used"<<endl;}
	A(A &r): iField1(r.iField1),iField2(r.iField2-1){cout<<iField1<<' '<<iField2<<endl;}
	A& operator=(A&b,int c)
	{
		iField2=b.iField2+c;
	}
};

A f(A& param,int c)
{
	return param=c;
}
 
 
 
 
 
 
 