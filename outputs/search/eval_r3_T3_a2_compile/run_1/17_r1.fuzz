#include <iostream>

using namespace std;
class IntContainer
{
    public:
	IntContainer(int* pI): iField(pI)
	    {  }
	IntContainer(const IntContainer &r): iField(r.iField)
	    {  }
    private:
	int* iField;
};
template <class T>
IntContainer<T> func(T* pT)
{
    return IntContainer<T>(pT);
}
int main()
{
    int iValue=777;
    IntContainer<int> one(&iValue), two(func(&iValue));
    cout << "Size of one:  " << sizeof(one) << endl;
    cout << "Size of two:  " << sizeof(two) << endl;
    return 0;
}
