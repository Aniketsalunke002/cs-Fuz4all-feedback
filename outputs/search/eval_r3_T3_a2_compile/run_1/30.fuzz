#include <iostream>
using namespace std;
class A
{
    private:
        int iField1;
        int iField2;
	A(int i) {iField1= iField2= i;}
    public:
	A(const A &r): iField1(r.iField1-10),iField2(r.iField2-3){cout<<iField1<<' '<<iField2<<endl;}
	A& operator=(const A&r)
	{
		iField1=r.iField1;
		iField2=r.iField2+4;
	}

};
int main()
{
	A one(1000), two(one);
    	one=two;
    	return 0;
}

