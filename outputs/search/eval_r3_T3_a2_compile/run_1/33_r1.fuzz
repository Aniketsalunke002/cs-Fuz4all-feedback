#include <iostream>

using namespace std;

template <typename T>
void show(T x)
{
	cout << x << endl;
}

struct S
{
	int k;
	int p;
};

int main()
{
	S s = {0, 50};
	show(s.k);
	show(s.p);
	s.p++, s.k++;
	show(s.k);
	show(s.p);
	s.k += ++s.p, ++s.k *= 3;
	show(s.k);
	show(s.p);
	s.k += {4, 5, 6}, s.p++;
	show(s.k);
	show(s.p);
}