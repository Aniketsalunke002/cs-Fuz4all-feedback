#include <iostream>
int main (void) {
	int a=4;
	int *aptr=&a;
	std::cout << *aptr << std::endl;
	++(*aptr);
	std::cout << *aptr << std::endl;
	*aptr=8;
	std::cout << *aptr << std::endl;
	return 0;
}
 
#include <iostream>
int main (void) {
	int t=4;
	std::cout << t++ << std::endl;
	std::cout << --t << std::endl;
	++t;
	--t;
	return 0;
}
