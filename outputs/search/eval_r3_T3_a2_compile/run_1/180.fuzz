#include <iostream>
class A
{
    public:
        A(const std::string & val_)
        :val(val_)
        {}
        A(std::string && val_)
        : val(std::move(val_))
        {}
        auto& getVal()
        {
            return val;
        }
        void setValue(const std::string & val_)
        {
            val = val_;
        }
        void setValue(std::string && val_)
        {
            val = std::move(val_);
        }
    private:
        std::string val;
};
int main(int argc, char *argv[])
{
    A object("HOLA");
    std::cout << object.getVal();
    object.setValue("QUE TAL");
    std::cout << object.getVal();
    return 0;
}
 
#include <iostream>
int main(int argc, char *argv[])
{
    int square = 0;
    square = square*2;
	for(int i=0; i<5; i++)
	{
		square = square+1;
		std::cout << square << std::endl;
	}
    return 0;
}
 
#include <iostream>
class A
{
    public:
        A(const std::string & val_)
        :val(val_)
        {}
        A(std::string && val_)
        : val(std::move(val_))
        {}
        A newA()
        {
            return A("NEW A");
        }
        auto& getVal()
        {
            return val;
        }
        void setValue(const std::string & val_)
        {
            val = val_;
        }
        void setValue(std::string && val_)
        {
            val = std::move(val_);
        }
    private:
        std::string val;
};
int main(int argc, char *argv[])
{
    A object("HOLA");
    std::cout << object.getVal();
    std::cout << object.newA().getVal();
    return 0;
}
 
