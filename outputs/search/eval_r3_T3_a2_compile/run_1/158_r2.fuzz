#include <iostream>

#include <type_traits>

void increase(int &i) {
  i += 1;
}

template <typename T>
void increase(T &i) {
  i += 1;
}

int main(int argc, char * argv[]) {
  std::cout << "sizeof(int) = " << sizeof(int) << '\n';
  std::cout << "sizeof(double) = " << sizeof(double) << '\n';
  std::cout << "sizeof(std::string) = " << sizeof(std::string) << '\n';

  int i = 1;
  std::cout << i << '\n';
  increase(i);
  std::cout << i << '\n';

  float f = 1.0;
  std::cout << f << '\n';
  increase(f);
  std::cout << f << '\n';

  std::string s = "test";
  std::cout << s << '\n';
  increase(s);
  std::cout << s << '\n';
}