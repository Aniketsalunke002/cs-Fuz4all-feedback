#include <iostream>
class A
{
    public:
        A():val{"HOLA"}
        {}
        A(const std::string& val_)
        :val{val_}
        {}
        auto& getVal()
        {
            return val;
        }
        void setValue(const std::string& val_)
        {
            val = val_;
        }
    private:
        const std::string val;
};
int main(int argc, char *argv[])
{
    A object("QUE TAL");
    std::cout << object.getVal();
    object.setValue("HOLA");
    std::cout << object.getVal();
    return 0;
}
 
#include <iostream>
template<typename T>
using A = std::pair<int,T>;

using Pair = A<int>;
int main(int argc, char *argv[])
{
   Pair p;
   auto &f = std::get<1>(p);
   f = 10;
   std::cout << "El valor de la primera posición es: " << std::get<0>(p) << std::endl;
   std::cout << "El valor del segundo es:" << std::get<1>(p) << std::endl;

   return 0; 
}