#include <iostream>
#include <cstddef>
using namespace std;

class A
{
    public:
    	int iField;
    	A():iField(777){}
	A(const A &r): iField(r.iField+1){}
	A& operator=(const A&r) {iField=r.iField;}    
    	A(int i)
    	{
    		iField = i;
    	}
};
int main()
{
	A one;
    	A two = A(one);
    	one = two;
    	return 0;
}