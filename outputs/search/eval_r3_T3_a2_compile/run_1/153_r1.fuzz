#include <iostream>

#include <vector>
#include <cstdlib>
#include <ctime>
#define rand() ((time(NULL)*rand()) % 1000000000)
template<typename T>
T rand() {
  return (T)(time(NULL)*rand()) % 1000000000;
}
class C{
  int v_;
public:
  C() {
    v_ = 0;
  }
  explicit C(int i):v_(i) {}
  int value() {
    return v_;
  }
};
int main(int argc, char * argv[]) {
  for (int i = 0; i <= 100; i++) {
    C * p = new C(rand<int>());
    std::cout << p -> value() << '\n';
  }
}