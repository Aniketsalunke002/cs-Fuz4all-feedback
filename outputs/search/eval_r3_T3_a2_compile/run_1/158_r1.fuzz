#include <iostream>


template <typename T>
inline void increase(T& i) {
  i += 1;
}

int main(int argc, char * argv[]) {
  int i = 1;
  std::cout << i << '\n';
  increase(i);
  std::cout << i << '\n';
}

int main(int argc, char * argv[]) {
  int x = 5;
  int y = 5;
  std::cout << "sizeof(x) = " << sizeof(x) << '\n';
  std::cout << "sizeof(y) = " << sizeof(y) << '\n';
}