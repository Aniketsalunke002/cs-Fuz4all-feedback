#include <iostream>

using namespace std;
template <typename T> class A {
	private:
		T iField1;
		T iField2;
	public:
		A(T i) : iField1(i), iField2(i) { }
		A(const A<T>& r) : iField1(r.iField1 - 10), iField2(r.iField2 - 3) { cout << iField1 <<'' << iField2 << endl; }
		A<T>& operator=(const A<T>& r) { iField1 = r.iField1; iField2 = r.iField2 + 4; }
};
int main()
{
	A<int> one(1000), two(one);
	one = two;
	return 0;
}