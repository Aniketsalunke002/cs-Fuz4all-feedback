#include <iostream>

using namespace std;
template<typename T>
class Parent
{
	public:
		Parent(T f)
		{
			m_df=f;
			cout << "Parent constructor called.\n";
		}
		T df() const { return m_df; }
		Parent* clone() const 
		{
		return new Parent(m_df);	
		}
		virtual ~Parent() {};
		
	void virtual print() const 
	{
	cout << "Parent: " << m_df << '\n';
	}
	private:
	T m_df;
};
template<typename T>
