#include <iostream>

#include <string>
int main()
{
  std::string str("Hello World!\n");
  std::string newstr = str + "\n"; 
  for (int i=0; i<str.size(); i++) {
    if (str[i] == '\n') {
      newstr += "A";
    }
  } 
  std::cout << newstr << '\n';
}
