#include <iostream>

int main() {
	int& i = 5;
	++i;
	std::cout<<i<<std::endl;
}
#include <iostream>
#include <iomanip>
#include <string>
int main() {
	int a = 5;
	std::cin>>a;
	std::cout<<std::setfill('0') << std::setw(4) << a <<std::endl;
	std::string b = "Hello";
	if (b.length()!=4) { std::cout<<"Not Hello"<<std::endl; }
}