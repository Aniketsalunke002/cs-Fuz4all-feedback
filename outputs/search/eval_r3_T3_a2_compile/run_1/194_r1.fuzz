#include <iostream>

using namespace std;
template<typename T>
T* str_end(T* s)
{
  while (*s)
    s++;
  return s;
}
int main(int argc, char** argv)
{
  char a[] = "abbbbbaaaabbb";
  char* ptr = a + str_end(a) - 1;
  while (ptr!= a) {
    *ptr = 0;
    cout << ptr << " ";
    ptr--;
  }
  return 0;
}