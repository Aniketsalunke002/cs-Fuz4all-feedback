#include <iostream>
#include <map>
int main(int argc, char *argv[])
{
    int x = 1000000;
    std::string str = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    std::string newStr = str;
    std::map <int, int > newDict;
    for (int i = 0; i<x; i++)
    {
        if(str[i]>='A' && str[i]<='Z')str[i]+=32;
        newDict[str[i]] = (newStr[i]);
    }
    for (auto &it: newDict)
    {
        if(it.second<0)it.second+=32;
    }
     
    for (auto &it: newDict)
    {
        if(it.second<0)it.second+=32;
        std::cout << it.second;
    }
    std::cout << std::endl;
    return 0;
}