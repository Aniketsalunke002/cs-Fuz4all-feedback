#include <iostream>
template<typename T>
class A
{
public:
    A(T && val_)
    :val(val_)
    {}
    T & getVal()
    {
        return val;
    }
    void setValue(T && val_)
    {
        val = val_;
    }
private:
    T val;
};
int main(int argc, char *argv[])
{
    A<int> object{100};
    std::cout << object.getVal();
    object.setValue(200);
    std::cout << object.getVal();
    return 0;
}
