#include <iostream>
class A
{
    public:
        A():val("HOLA")
        {}
        A(const std::string& val_)
        :val(val_)
        {}
        auto& getVal()
        {
            return val;
        }
        void setValue(const std::string& val_)
        {
            val = val_;
        }
    private:
        std::string val;
};
int main(int argc, char *argv[])
{
    A object("QUE TAL");
    std::cout << *object.getValPtr();  
    *object.getValPtr() = "HOLA";  
    std::cout << *object.getValPtr();  
    return 0;
}
 
#include <iostream>
class A
{
    public:
        A(const std::string& val_):val(val_)
        {}
        auto& getVal()
        {
            return val;
        }
    private:
        std::string val;
};
void print_A(const A& object)
{
    std::cout << object.getVal();
}
int main(int argc, char *argv[])
{
    print_A(A("HOLA"));
    return 0;
}
 
#include <iostream>
class UnProtected
{
    public:  
        UnProtected():var("Hello UnProtected")
        {}
        UnProtected(const std::string& val_):var(val_)
        {}
        void print()
        {
            std::cout << var;
        }
    private:
        std::string var;
};
class Protected:public UnProtected
{
    protected:  
        Protected():UnProtected("Hello Protected")
        {}
        Protected(const std::string& val_):UnProtected(val_)
        {}
};
int main(int argc, char *argv[])
{
    UnProtected object("Hello");
    object.print();  
    Protected object2("Hello");
    object2.print();  
    return 0;
}