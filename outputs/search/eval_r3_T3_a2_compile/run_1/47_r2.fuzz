#include <iostream>

template <typename T, typename B>
class A {
	T t;
	public:
		A(const T& t) :t(t) {}
		T get_t(void) {
			return t;
		}
};
template <typename T, typename B>
A <B> foo(T input) {
	A<T,B> t(input);
	A<B,B> b=t;
	return b;
}
int main (void) {
	auto temp = foo<char,int>('z');  
	std::cout << temp.get_t() << std::endl;
	return 0;
}