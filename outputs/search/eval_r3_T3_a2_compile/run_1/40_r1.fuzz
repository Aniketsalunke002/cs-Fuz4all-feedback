#include <iostream>

template <typename T>
void inc(T &n) {
	++n;
}
template <typename T>
void dec(T &n) {
	--n;
}
int main (void) {
	int a=4;
	int *aptr=&a;
	std::cout << *aptr << std::endl;
	inc(*aptr);
	std::cout << *aptr << std::endl;
	dec(*aptr);
	std::cout << *aptr << std::endl;
	return 0;
}
