#include <type_traits>
#include <iostream>
class Object {
public:
	Object() = default;
	~Object() = default; 
	void process() {
		std::cout << "process\n";
	}
};
template <typename... Args>
void generic_function(Args...) {
	if constexpr( requires { typename std::enable_if_t<std::is_base_of_v<Object,Object_type>>; }) {
		std::cout << "1" << std::endl;
	}
	
	if constexpr( requires(Args...) { typename std::enable_if_t<std::is_base_of_v<Object,Object_type>>; } ) {
		std::cout << "2" << std::endl;
	}
	std::cout << "3" << std::endl;
}
int main() {
	generic_function<Object>();
	std::cout << "Hello World\n";
	return 0;
}
