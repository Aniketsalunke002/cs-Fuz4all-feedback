#include <iostream>

#include <string>
using namespace std;
string a("abbbbbaaaabbb");
auto ptr = a.c_str() + a.length();
cout << ptr;
while (ptr!= a.c_str())
{
  *ptr = '\0';
  cout << ptr << " ";
  ptr--;
}
return 0;

