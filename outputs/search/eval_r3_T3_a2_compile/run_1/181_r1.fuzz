#include <iostream>

class A
{
    public:
        A(std::string & val_)
        :val(val_)
        {}
        auto& getVal()
        {
            return val;
        }
        void setValue(std::string & val_)
        {
            val = val_;
        }
    private:
        std::string val;
};
int main(int argc, char *argv[])
{
    A object("HOLA");
    std::cout << object.getVal();
    object.setValue("QUE TAL");
    std::cout << object.getVal();
    return 0;
}