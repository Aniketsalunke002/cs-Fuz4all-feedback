#include <iostream>

using namespace std;
template<typename T>
void print(const T& value)
{
	cout << value << endl;
}
class Date{
	int day;
	int month;
	int year;
public:
	explicit Date(int day_,int month_,int year_):day(day_),month(month_),year(year_){}
	Date(void):day(1),month(1),year(2020){}
	friend bool operator<(const Date& first,const Date& second);
	
	friend ostream& operator<<(ostream& os,const Date& date);
};
template<typename T>
void print(const T& value,const Date& date)
{
	cout << value << date << endl;
}
bool operator<(const Date& first,const Date