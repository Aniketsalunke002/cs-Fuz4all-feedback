#include <iostream>
using namespace std;
class A
{
    public:
        int iField;
};
int main()
{
    int i = 0;
    A one = { i };
    A two;
     
    cout << "Size of one:  " << sizeof(one) <<  ";  contents: " << one.iField << endl; 
     
    cout << "Size of two:  " << sizeof(two) << endl;
     
    return 0;
}
