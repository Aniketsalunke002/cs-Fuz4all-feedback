#include <iostream>
using namespace std;
int check_pass(const string& pa)
{
	cout<<"Please enter password\n";
	string p;
	cin>>p;
	return (p==pa)&&1;
}
int main()
{
	const string pa("password");
	check_pass(pa);
}
