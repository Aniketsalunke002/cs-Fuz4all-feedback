#include <iostream>

#include <complex>
using namespace std;

class complex
{
	int real,img;
public:
	void operator += (complex<int> x)
	{
		real=real+x.real();
		img=img+x.imag();
	}
	complex operator - (complex<int> x)
	{
		complex<int> z;
		z.real=real-x.real();
		z.img=img-x.imag();
		return z;
	}
	void display()
	{
		cout<<"real:"<<real<<" img:"<<img<<endl;
	}
};

int main()
{
	complex c1,c2,result;
	c1.real=5;
	c1.img=5;
	c2.real=10;
	c2.img=10;
	result = c1+c2;
	result -= c2;
	result.display();
	return 0;
}