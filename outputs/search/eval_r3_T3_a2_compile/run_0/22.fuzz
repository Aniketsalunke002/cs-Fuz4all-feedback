#include <iostream>
using namespace std;
#include <bits/stdc++.h>
using namespace std;
int main() {
	vector<int> v = {1,2,3,4,5,6};
	int cnt = 0;
	int temp = 0;
	int k = 0;
	for (int i=0;i<v.size();i++) {
		for (int j=0;j<v.size();j++) {
			int t = v.at(i);
			v.at(i) = v.at(j);
			v.at(j) = t;
		}
	}
	for (int j=0;j<v.size();j++) {
		v.at(j) = v.at(j) - 2;
	}
	for (int i=0;i<v.size();i++) {
		cout << v.at(i);
	}
	return 0;
}
