#include <iostream>
using namespace std;
int main()
{
    char* s1 = new char[96];
    for(int i = 0; i < 96; ++i)
        s1[i] = static_cast<char>('a' + i);
    char* s2 = new char[96];
    for(int i = 0; i < 96; ++i)
        s2[i] = static_cast<char>('A' + i);
    delete [] s1;
    delete [] s2;
    return 0;
}