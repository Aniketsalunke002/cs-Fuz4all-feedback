#include <iostream>
using namespace std;

int main() {
	for (int h = 0; h < 7; h++)
	for (int i = 5; i >= 0; i--)
			cout << i << endl;
	
	int n = 5;
	int k = 0;
	int i = 0;
	int j = 6;
	int a = 2, b = 8, c = -2, d = 5, e = 0; 
	int f = 0;
	int g = -1;
	cout << i++ << endl;
	cout << ++f << endl;
	int c = k++ % 3;
	cout << c++ << endl;
	cout << ++c << endl;
	cout << j--  << endl;
	cout << --f  << endl;
	cout << c-- << endl;
	cout << --c << endl;
	return 0;
}
 
#include <iostream>
using namespace std;
#include "string"

int main() {
	char * b = "test";
	int a = 11;
	string a = "String";
	string * b = new string("String");
	cout << (*b) << endl;
	delete b;
	b = "Test";

	if (!(*b))
		cout << "Not empty" << endl;
	else 
		cout << "Empty" << endl;
	{
 	}
	if (*b == "Test")
		cout << "Test" << endl;
	else 
		cout << "Empty" << endl;
	
	if(a > 10){
		cout<< "Biger" <<endl;
	}
	else {
		cout << "Lesser" << endl;
	}
	switch (*b) {
		case'':
			cout << "Space" << endl;
			break;
		case '0':
			cout << "Zero" << endl;
			break;
		case 'a':
			cout << "Letter" << endl;
			break;
		default:
			cout << "Other char" << endl;
			break;}
	char * d = "a";
	int i = 0;
	int n = 8;
	while(i < n && (*d++))	
		cout << "i= " << i++ << endl;
	d = b + 1;
	while(*d++)
		cout << *d << endl;
	return 0;

}

