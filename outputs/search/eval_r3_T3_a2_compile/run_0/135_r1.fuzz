#include <iostream>

using namespace std;
int check_pass(const string& pa)
{
	cout<<"Please enter password\n";
	string p;
	cin>>p;
	if(p==pa)
	{
		return 1;
	}
	else
		return 0;
}
int main()
{
	const string pa("password");
	check_pass(pa);
	return 0;
}
