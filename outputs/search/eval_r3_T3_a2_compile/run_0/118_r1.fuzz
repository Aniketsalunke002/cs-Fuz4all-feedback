#include <iostream>

using namespace std;
template<typename T>
void swap(T &a, T &b )
{
	T temp = a;
	a = b;
	b = temp;
}
class A
{	int b, c;
	public:
	A(int pa, int pb, int pc) : b(pa), c(pb)
	{};
	void display1()
	{
		cout<<"this is class object"<<endl;
		b = 6;
	}
	friend void swap(A &a, A &b)
	{
		int temp = a.b;
		a.b = b.b;
		b.b = temp;
	}
};
class B : public A
{
public:
	B(int pb, int pc) : A(7, 7, 7), b(pb), c(pc)
	{};
	void display2()
	{
		cout<<"this is object of another class"<<endl;
		b = 5;
	}
};
int main()
{
	A aa(7, 7, 7);
	B bb(8, 9);
	swap(aa,bb);
	aa.display1();
	bb.display2();
	return 0;
}
// Output:
// this is class object
// this is object of another class
// this is class object
// this is object of another class