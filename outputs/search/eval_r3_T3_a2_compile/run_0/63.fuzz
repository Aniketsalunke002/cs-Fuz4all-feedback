#include <iostream>
#include <memory>
template<typename T>
auto get_array(int size)->std::unique_ptr<T*[]>
{
     return std::make_unique<T*[]>(size);
}
int main()
{
     auto arr = get_array<char>(96);
     char *str = "abcdefghijklmnopqrstuvwxyz";
     for(int i = 0; i < 96; ++i)
     {
          arr[i] = &str[i];
          std::cout << arr[i] << " ";
     }
     return 0;
}
 
