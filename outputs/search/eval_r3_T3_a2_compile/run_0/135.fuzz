#include <iostream>
using namespace std;
int check_pass(string pa)
{
	cout<<"Please enter password\n";
	cin>>pa;
	if(pa=="password")
	{
		return 1;
	}
	else
		return 0;
}
int main()
{
	string pa;
	check_pass(pa);
	return 0;
}
 
#include <iostream>
using namespace std;
int sum_of_squares(int a)
{
	return (a+a)*(a+a);
}
int main()
{
	int n;
	cout<<"Enter no\n";
	cin>>n;
	cout<<sum_of_squares(n);
	return 0;
}
