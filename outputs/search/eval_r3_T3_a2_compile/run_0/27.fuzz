#include <iostream>
using namespace std;
int main() {
	{
		char* s0 = new char[96];
		for(int i = 0; i < 96; ++i)
			s0[i] = static_cast<char>('a' + i);
		delete[] s0;
	}
	cout << "Goodbye!\n";
	return 0;
}
