#include <iostream>
using namespace std;
int main()
{
    string s1 = "0123456789";
    s1[23] = 'A';
    s1.erase(s1.end()-1);
    cout << s1 << endl;
    return 0;
}

 
#include <iostream>
using namespace std;
int main() {
    char buffer[256];
    for(int i = 0; i < 255; ++i)
        buffer[i] = 'A' + i;
    cout << buffer << endl;
    return 0;
}
