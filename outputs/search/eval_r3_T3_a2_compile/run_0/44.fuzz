#include <iostream>
using namespace std;
#include <vector>
#include <algorithm>
int main()
{
    std::vector<char> vec;
    for(int i = 0; i < 10; ++i)
        vec.push_back(static_cast<char>((i % 26) + 'a'));
    std::vector<char>::iterator it = std::find(vec.begin(), vec.end(), 'j');
    vec.erase(it);
    std::vector<char>::const_reverse_iterator rev_it = vec.rbegin();
    std::for_each(rev_it, vec.rend(), [&](char ch){
        print(ch);
    });
    return 0;
}
