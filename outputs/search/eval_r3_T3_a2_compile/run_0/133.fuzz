#include <iostream>
using namespace std;
void check_pass(string pa)
{
	cout<<"Please enter password\n";
	cin>>pa;
	if(pa!="password")
	{
		cout<<"Incorrect Password!!!";
	}
	else
	{
		cout<<"Access Granted\n";
	}
}
int main()
{
	string pa;
	check_pass(pa);
	return 0;
}
 
