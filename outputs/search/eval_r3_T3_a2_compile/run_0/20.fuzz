#include <iostream>
using namespace std;
#include <bits/stdc++.h>
using namespace std;
int main() {
	int cnt = 0;
	string s = "";
	char x = 'A';
	for(int i=0;i<100;i++) {
		s = s + (x++);
	}
	for(auto x : s) {
		if ((x % 2) == 0) {
			x = x + 2;
			cnt++;
		}
		if ((cnt == 2)) {
			x = x - 2;
			cnt = cnt + 5;
		}
		if ((cnt == 4)) {
			x = x - 2;
			cnt = cnt - 2;
		}
		cout << x;
	}
	return 0;
}
