#include <iostream>
using namespace std;
using ::std::size_t;
template<typename T>
T* get_array_1(size_t size)
{
    return new T[size]();
}

int main()
{
    char* s1 = get_array_1<char>(96);
    char* s2 = get_array_1<char>(96);
    for(size_t i = 0; i < 96; ++i)
        s2[i] = s1[i];
    return 0;
}
 
#include <iostream>
using namespace std;
using ::std::size_t;

template<typename T, size_t N>
T* get_array_1(T (&arr)[N])
{
    return arr;
}
int main()
{
    char s1[96];
    char s2[96];

    get_array_1(s1);
    get_array_1(s2);

    for(size_t i = 0; i < 96; ++i)
    {
        s2[i] = s1[0];
    }
    return 0;
}
