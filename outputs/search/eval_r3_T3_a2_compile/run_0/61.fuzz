#include <iostream>
using namespace std;
class Foo
{
     public: 
     char *str;
     Foo(char *str){
          this->str = str;
     }
     ~Foo(){
          cout << "destroy Foo" << endl;
     }
     char * get_str()
     {
          return str;
     }
};
Foo get_foo()
{
     static char str[] = "abcdefghijklmnopqrstuvwxyz";
     return Foo(str);
}
int main()
{
     Foo foo = get_foo();
      
     return 0;
}
