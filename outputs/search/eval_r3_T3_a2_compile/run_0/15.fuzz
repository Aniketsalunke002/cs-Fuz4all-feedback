#include <iostream>
using namespace std;
#include <bits/stdc++.h>
using namespace std;
int main() {
	vector<int> v = {2,3,4,5,6,7};
	int n = 5;
	int k = 0;
	for (int i=0;i<n;i++) {
		if (k%2==0) {
			for (int j=0;j<v.size();j++) {
				v.at(j) += 2;
				cout << v.at(j) << endl;
			}
		}
		else {
			for (int j=v.size()-1;j>=0;j--) {
				v.at(j) += 2;
				cout << v.at(j) << endl;
			}
		}
		k++;
	}
	return 0;
}
