#include <iostream>
using namespace std;
class complex
{
	int real,img;
public:
	void getvalues(int x,int y){
		real = x;
		img = y;
	}
	void print(){
		cout<<"(" <<real <<", "<< img <<")";
	}
	complex minus(complex x){
		complex temp;
		temp.real = real - x.real;
		temp.img = img - x.img;
		return temp;
	}
	friend complex operator+(complex n1,complex n2){
		complex temp;
		temp.real = n1.real + n2.real;
		temp.img = n1.img + n2.img;
		return temp;
	}
};
int main ()
{
	complex c1, c2;
	c1.getvalues(5,5);
	c2.getvalues(10,10);
	c1.print();
	c2.print();
	cout<<"+:";
	(c1+c2).print();
    return 0;
}

