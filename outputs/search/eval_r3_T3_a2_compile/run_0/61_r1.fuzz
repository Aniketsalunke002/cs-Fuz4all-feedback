#include <iostream>

using namespace std;

template <typename T>
class Foo{
public:
    T *str;
    Foo(T *str){
        this->str = str;
    }
    ~Foo(){
        cout << "destroy Foo" << endl;
    }
    T * get_str()
    {
        return str;
    }
};

Foo<char> get_foo()
{
    static char str1 [] = "abcdefghijklmnopqrstuvwxyz";
    return Foo<char>(str1);
}

int main()
{
    Foo<char> foo = get_foo();
    
    return 0;
}

