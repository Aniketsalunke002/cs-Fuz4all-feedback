#include <iostream>
using namespace std;
class complex
{
	int real,img;
public:
	void operator += (complex x)
	{
		real=real+x.real;
		img=img+x.img;
	}
	complex operator - (complex x)
	{
		complex z;
		z.real = real-x.real;
		z.img = img-x.img;
		return z;
	}
};
int main()
{
	complex c1,c2,result;
	c1.real=5;
	c1.img=5;
	c2.real=10;
	c2.img=10;
	result = c1+c2;
	result -= c2;
	result.display();
	return 0;
}
