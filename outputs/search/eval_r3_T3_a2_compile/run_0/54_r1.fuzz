#include <iostream>

using namespace std;
template <typename T>
class array_t
{
public:
    T* first; int size; int last;
    array_t(int size): first(new T[size]), size(size), last(size) {}
    void fill(T value) { for(int i = 0; i < size; ++i) first[i] = value; }
    array_t<T>& operator=(const T value)
    {
        fill(value);
        return *this;
    }
};
int main()
{
    array_t<int> ar = array_t<int>(5,5);
    cout << ar.first[4] << endl;
    ar = -1;
    cout << ar.first[4] << endl;
    return 0;
}