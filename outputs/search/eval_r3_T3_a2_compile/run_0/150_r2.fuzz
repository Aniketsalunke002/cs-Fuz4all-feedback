#include <iostream>

#include <cstdint>
using namespace std;

template <typename T>
void count_number_of_ones(T number) {
    cout << number;
}

template int count_number_of_ones<int64_t>(int64_t number);

int main(int argc, char **argv) {
    int64_t number = -1;
    cout << count_number_of_ones(number);
    return 0;
}
