#include <iostream>

#include <cstring>
#include <memory>
#include <vector>
#include <string>

constexpr size_t N = 96;
int main()
{
     std::vector<std::string> vec(N);
     std::string str = "abcdefghijklmnopqrstuvwxyz";
     for(size_t i = 0; i < N; ++i)
     {
          vec[i] = str + i;
     }
     for(auto p : vec)
     {
          std::cout << p << std::endl;
     }
     return 0;
