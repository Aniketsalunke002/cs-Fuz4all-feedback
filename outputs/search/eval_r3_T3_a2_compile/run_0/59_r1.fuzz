#include <iostream>

#include <memory>
using namespace std;
template<typename T>
unique_ptr<T**> get_array(int size)
{
     return unique_ptr<T**>(new T*[size]);
}
int main()
{
     auto arr = get_array<char>(96);
     char *str = "abcdefghijklmnopqrstuvwxyz";
     for(int j = 0; j < 96; ++j)
     {
          for(int i = 0; i < 96; ++i)
          {
               arr.get()[j][i] = &str[i];
               cout << arr.get()[j][i] << " ";
          }
          cout << endl;
     }
     return 0;
}