#include <iostream>

using namespace std;
template<typename T>
void foo()
{
    cout << "foo.cpp source code in foo" << endl;
    foo<T*>();
}
template<typename T>
void foo()
{
    cout << "foo.cpp source code in foo" << endl;
}
int main()
{
    cout << "foo.cpp source code in main" << endl;
    foo<int>();
    return 0;
}