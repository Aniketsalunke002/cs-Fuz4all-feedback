#include <iostream>
using namespace std;
#include <bits/stdc++.h>
using namespace std;
int main() {
	cout << (int)pow((3.141592653589793)/2.0, 2) << endl;
	cout << pow((3.141592653589793)/2.0, 2) << endl;
	cout << pow((6.283185307179586)/2.0, 2) << endl;
	cout << pow((2.0*3.141592653589793)/2.0, 2) << endl;
	return 0;
}
