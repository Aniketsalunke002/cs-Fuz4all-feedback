#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int a = 11, b = 3, c = 7;
	int d = 20, e = 25, f = 35;
	if (a > b) {
		if (b > c) {
			a = b;
		}
	}
	else {
		if (a > c) {
			a = c;
		}
	}
	cout << a << endl;
	if (a > b) {
		a++;
	}
	else {
		if (a > c) {
			c = 2;
		}
		e = f;
		d = 4;
	}
