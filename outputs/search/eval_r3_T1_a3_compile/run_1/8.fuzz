#include <iostream>
using namespace std;
int main(int argc, char *argv[]) {
	for (float f1 = -1E10f; f1 < 1E10; f1 *= 10) {
		for (float f2 = -1E10f; f2 < 1E10; f2 *= 10) {
			float a = f1 * 10;
			double b = f2 * 10;
			float c = a - b;
			cout << f1 << "   " << f2 << "   " << a << "   " << b << " " << c << endl;
		}
	}
}
 
#include <iostream>
using namespace std;
int main(int argc, char *argv[]) {
	for (float f1 = -1E10f; f1 < 1E10; f1 *= 10) {
		for (float f2 = -1E10f; f2 < 1E10; f2 *= 10) {
			float a = f1 + f2 * 10;
			float b = f1 - f2 / 10;
			float c = 0;
			cout << f1 << "   " << f2 << "   " << a << "   " << b << " " << c << endl;
		}
	}
}
