#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int x[2] = { 0 };
	cout << x[1] << endl;
	int y[2], tmp;
	y[0] = x[0];
	tmp = y[1];
	y[1] = x[1];
	x[0] = tmp;
	x[1] = 1;
	cout << y[0] << endl;
	cout << y[1] << endl;
	return 0;
}
```
# 2.
在一个简单的循环，打印 156 个 9。
```cpp
 
#include <stdio.h>
using namespace std;
int main(void) {
	int i = 0;
	for (i = 0; i < 156; i++) {
		printf("9\n");
	}
	return 0;
}
 
#include <stdio.h>
using namespace std;
int main(void) {
	int i = 0;
	while (i < 156) {
		printf("9\n");
		printf("9");
	}
	return 0;
}
```
# 3.
下列程序输出什么？
```cpp
 
#include <iostream>
using namespace std;
double x[10] = {};
double* y[10];
double** z[10];
int main() {
	for (int i = 0; i < 10; i++) {
		if (i == 0) {
			z[i] = x;
		}
		 
		 
		 
		*(*z[i]) = x[i];
	}
	for (int i = 0; i < 10; i++) {
		cout << *((*z[i])) << endl;
	}
	return 0;
}
 
#include <iostream>
using namespace std;
void fun(int* a, int* b) {
	int i;
	for (i = 0; i < 5; i++) {
		*(*a + i) + *(*b + i);
	}
}
int main() {
	int a[] = { 8, 4, 1, 2, 7 };
	int b[] = { 1, 4, 5, 6, 9 };
	int c[5];
	fun(&a[0], &b[0]);
	for (int i = 0; i < 5; i++) {
		c[i] = a[i] + b[i];
	}
	for (int i = 0; i < 5; i++) {
		cout << c[i] << endl;
	}
	return 0;
}
```