#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	while(i < 10) {
		++i;
	}
	cout << i;
	return 0;
}
 
#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	if(i < 10) {
		++i;
	}
	cout << i;
	return 0;
}
 
#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	for(int i = 10; i < 20; ++i) {
	}
	cout << i;
	return 0;
}
 
#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	if(i < 10) {
		++i;
	}
	else {
		--i;
	}
	cout << i;
	return 0;
}
 
