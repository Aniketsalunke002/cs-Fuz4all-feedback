#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int i;
	static int j;
	i = j;
	++j;
	cout << i << " " << j;
	return 0;
}
 
#define MY_MAX 20
int main() {
	int i=1, j=MY_MAX;
	while(j>0) {
		cout << j << " ";
		--j;
		int temp=i;
		i = j;
		j = temp-1;
	}
	cout << endl;
	return 0;
}
