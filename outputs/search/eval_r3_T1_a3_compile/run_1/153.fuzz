#include <iostream>
using namespace std;
#include <chrono>
int main(int argc, char* argv[]) {
	auto t1 = std::chrono::steady_clock::now();
    const int N = 2147483647;
    int res = 0;
    bool flip = false;
    for (int i = N; i >= 0; i--) {
        res += (i % 2) * N;
        flip =!flip;
    }
    auto t2 = std::chrono::steady_clock::now();
    cout << "duration of computation " << (t2 - t1).count() << endl;
    cout << res << endl;
	return 0;
}
