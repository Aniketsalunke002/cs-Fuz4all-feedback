#include <iostream>
using namespace std;
void fun(int * a, int * b) {
	int * tmp = a;
	a = b;
	b = tmp;
	return;
}
int main(int argc, char* argv[]) {
	int a = 5, b = 12;
	fun(&a, &b);
	cout << a << endl;
	cout << b << endl;
	return 0;
}
 
#include <iostream>
#include <climits>
using namespace std;
char a[50], b[50], c[50];
void fun(char * ca, char * cb, char * cc) {
	*cc = *ca;
	(*cb)++;
	++(*ca);
	return;
}
int main(int argc, char* argv[]) {
	int i = 0;
	cin >> a[i];
	cin >> b[i];
	cin >> c[i];
	while (cin >> a[i] && cin >> b[i] && cin >> c[i]) {
		fun(&a[i], &b[i], &c[i]);
		i++;
		if (i == 50) {
			cout << "Out of length!!!\n";
			break;
		}
		cin >> a[i];
		cin >> b[i];
		cin >> c[i];
	}
	i--;
	while (i > 0) {
		cout << a[i] << " ";
		i--;
	}
	while (i > 0) {
		cout << b[i] << " ";
		i--;
	}
	while (i > 0) {
		cout << c[i] << " ";
		i--;
	}
	return 0;
}
 
#include <iostream>
#include <cstdlib>
using namespace std;
int main() {
	srand(time(NULL));
	for (int k = 0; k < 3; k++) {
		int n = rand() % 10 + 1;
		int a = 1, b = 1;
		cout << "k = " << k << "\tn = " << n << endl;
		for (int i = 2; i <= n; i++) {
			int tmp = a;
			a = a + b;
			b = tmp;
			cout << a << " ";
		}
		cout << endl;
	}
	return 0;
}
 
 
