#include <iostream>
int main(int argc, char *argv[]) {
	for (int i = 0; i < 10; i++ ) {
		cout << i << endl;
	}
	return -1;
}
 
#include <iostream>
int main(int argc, char *argv[]) {
	for (float f1 = -1E10f; f1 < 1E10; f1 += (f1<0)?1:-1) {
		for (float f2 = -1E10f; f2 < 1E10; f2 += (f2<0)?1:-1) {
			cout << f1 << "   " << f2 << "   " << f1 + f2 << "   " << f1 - f2 << "   " << (f1*10) << endl;
		}
		cout << endl;
	}
}
