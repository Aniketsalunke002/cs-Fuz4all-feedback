#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int a = 5, b = 12;
	cout << a << endl;
	cout << b << endl;
	int anew = a, bnew = b;
	anonew = 45;
	bnew = 30;
	cout << anew << endl;
	cout << bnew << endl;
	return 0;
}
 
 
#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int *p1, *p2;
	int num[10], sum;
	p1 = p2 = num;
	for (int i = 0; i < 10; i++) {
		cout << "enter the number: ";
		cin >> *p1;
		p1++;
	}
	p1 = num;
	sum = 0;
	while (p1 < p2) {
		sum = sum + *p1;
		p1++;
	}
	cout << "sum is: " << sum << endl;
	return 0;
}
 
#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int num[10], *p1[10], sum = 0;
	for (int i = 0; i < 10; i++) {
		cout << "enter the number: ";
		cin >> num[i];
		p1[i] = &num[i];
	}
	for (int i = 0; i < 10; i++) {
		sum = sum + *p1[i];
	}
	cout << "sum is: " << sum <<endl;
	return 0;
}
 
#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int a, *p1;
	p1 = &a;
	for (int i = 0; i < 10; i++) {
		cout << "enter the number: ";
		cin >> *p1;
		p1++;
	}
	for (int i = 0; i < 10; i++) {
		cout << a[i] << " ";
	}
	p1 = &a[0];
	a = 0;
	while (p1 < &a[10]) {
		cout << (*p1) << " ";
		p1++;
	}
	return 0;
}
 
 
