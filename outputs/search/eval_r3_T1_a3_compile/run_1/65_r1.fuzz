#include <iostream>

using namespace std;
int main(int argc, char* argv[]) {
	int x = 5;
	while (x > 0) {
		if (x % 2 == 1) {
			x += 2;
		}
		else if (x % 3 == 0) {
			x /= 3;
		}
		else {
			x /= 2;
		}
	}
	cout << x;
	return 0;
}
