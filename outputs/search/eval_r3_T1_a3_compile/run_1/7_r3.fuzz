#include <iostream>

#include <algorithm>
#include <map>
#include <vector>
using namespace std;
struct A {
   vector<int> vec;
   map<int,int> m;
};
int main(int argc, char *argv[])
{
   using AA = A;
   A a;
   sort(a.vec.begin(),a.vec.end());
   sort(a.m.begin(),a.m.end());
   A b(a);
   b.vec.erase(remove(b.vec.begin(), b.vec.end(), -1), b.vec.end());
   b.m.erase(remove(b.m.begin(), b.m.end(), -1), b.m.end());
}