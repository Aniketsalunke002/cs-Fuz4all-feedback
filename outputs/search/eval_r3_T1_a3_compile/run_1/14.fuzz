#include <iostream>
using namespace std;
void printLine(float f) {
	if (f == 1E10f) {
		cout << "  ";
	}
	else {
		cout << f << " ";
	}
	cout << endl;
}
int main(int argc, char *argv[]) {
	for (float f = -1E10f; f < 1E10; f *= 10) {
		printLine(f);
	}
}
 
 
#include <iostream>
using namespace std;
int main() {
	for (int pNo = 2; pNo < 99; pNo++) {
		int count = 1;
		for (int j = 2; j < pNo; j++) {
			if (pNo % j == 0) {
				count++;
			}
		}
		if (count == 1) {
			cout << pNo << endl;
		}
	}
}
 
#include <iostream>
using namespace std;
int main(int argc, char *argv[]) {
	cout << "Enter matrix size: " << endl;
	int size = 0;
	cin >> size;
	int matrix[size][size];
	for (int i = 0; i < size; i++) {
		for (int k = 0; k < size; k++) {
			matrix[i][k] = i + k;
			cout << "[" << i;
			cout << "][" << k;
			cout << "] = " << matrix[i][k] << endl;
		}
	}
	return 0;
}
 