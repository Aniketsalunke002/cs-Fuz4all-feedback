#include <list>
#include <vector>
using namespace std;

int main () {
    vector<int> v;
    list<vector<int>> l;

    for (int i = 0; i < 10; i++)
    {
        vector<int> vi {i};
        l.push_back(vi);
        v.push_back(i);
    }

    return 0;
}
 
#include <list>
#include <vector>
using namespace std;

int main () {
    vector<int> v;
    list<int> l;
    for (int i = 0; i < 10; i++)
    {
        v.push_back(i);
        l.push_back(5);
    }
    return 0;
}
 
