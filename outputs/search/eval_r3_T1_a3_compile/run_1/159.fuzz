#include <vector>

#include <algorithm>

#include <iostream>
using namespace std;
int main () {
    vector<int> vi {0,2,3,1,4};

    auto sorted = vi;

    sort(sorted.begin(), sorted.end());

    vector<int>::iterator it = std::prev(sorted.end());


     
       

    for_each(sorted.begin(), it, [&] (int value) { cout << value << endl; });

    std::for_each(sorted.begin(), it, [&] (int value) { cout << value << endl; });

    sort(vi.begin(), vi.end(), [] (int x, int y) { return y > x; });

    auto result = std::is_sorted(vi.begin(), vi.end());

    return 0;
}
 
