#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int i = 0;
	while(i < 10) {
		++i;
	}
	cout << i;
	return 0;
}

#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int i = 0;
	if(i < 10) {
		++i;
	}
	cout << i;
	return 0;
}

#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int i = 10;
	for(int i = 10; i < 20; ++i) {
	}
	cout << i;
	return 0;
}

#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int i = 0;
	if(i < 10) {
		++i;
	}
	else {
		--i;
	}
	cout << i;
	return 0;
}

#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int i = 0;
	if(i < 10) {
		++i;
	}
	else {
		--i;
	}
	cout << i;
	return 0;
}