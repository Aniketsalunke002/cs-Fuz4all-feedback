#include <iostream>
using namespace std;
void swap(int& num1, int& num2) {
	int tmp;
	tmp = num1;
	num1 = num2;
	num2 = tmp;
}
int main(int argc, char* argv[]) {
	int a = 5, b = 12;
	swap(a, b);
	cout << a << endl;
	cout << b << endl;
	return 0;
}
 
#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int a = 5, b = 12;
	cout << a + b << endl;
	cout << __gcd(a, b) << endl;
	cout << 1e9 * 1e6 * 1e3 * 1e3 * 10 << endl;
	cout << 1.2e30 * 3 << endl;
	cout << b << a << endl;
	return 0;
}
