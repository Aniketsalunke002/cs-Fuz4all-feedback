#include <iostream>
using namespace std;
#include <utility>
int main(int argc, char* argv[]) {
  int a = 0, b = 0;
  swap(a, b);
  cout << a << endl;
  cout << b << endl;
  return 0;
}
 
template<int v1, int v2, int n>
struct fib{
  static int const value = v1 + v2;
  static const long long result = fib<v2, value, n - 1>::value;
};
template<int v1, int v2>
struct fib<v1, v2, 1>{
  static int const value = v2;
  static const long long result = fib<v1, v2, 0>::value;
};
template<int v1, int v2, int N>
struct fib_generator{
  typedef typename fib<v1, v2, N>::result type;
  static int const start = fib<v1, v2, 0>::value;
  static int const stop = fib<v1, v2, N>::value;
};
int main(int argc, char* argv[]){
  typedef decltype(fib_generator<0, 1, 1000>::type()) fib;
  cout << "result: " << fib_generator<0, 1, 1000>::type() << endl;
  return 0;
}

 
class A {
public:
  A(){}
};
class B {
private:
  A m_a;  

public:
  A fieldA;  

  B(){}  

  B(A a)  
        : fieldA(a), m_a(a){}   
  void print(void){
    cout << fieldA << ", " << m_a << endl;
  }
};
int main(){
  A x;
  B y{x};
  B z{x};
  y.print();
  z.print();
   
  
   
  y.fieldA = y;
  y.fieldA.print();
   
  z.fieldA = z;
  z.fieldA.print();
  return 0;
}
int addTwo(int num) {
  return num + 2;
}
void printNum() {
  cout << "this is function";
}
int main() {
  int a = 0;
  int result;
  result = a++;  
  result = ++a;  
  result = addTwo(10);  
  printNum();
  
  return 0;
}

