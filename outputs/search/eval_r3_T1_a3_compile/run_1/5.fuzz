#include <iostream>
using namespace std;
int main(int argc, char *argv[])
{
   for (float f1 = -1E10f; f1 < 1E10; f1 *= 10) {
      for (float f2 = -1E10f; f2 < 1E10; f2 *= 10) {
         float f3 = f1 + f2;
         float f4 = f1 - f2;
         if (f3 == 123456.787 && f4 == -123456.787) {
            f3 = -f3;
            f4 = -f4;
         }
         cout << f1 << "   " << f2 << "   " << f3 << "   " << f4 << endl;
      }
   }
}
