#include <iostream>
using namespace std;
void fun(int& a, int& b) {
	int tmp;
	 
	 
	 
	a += b;
	b += a;
	a -= b;
	a /= b;
	cout << a << endl;
	cout << b <<" " << &a << " " << &b << endl;
}
int main(int argc, char* argv[]) {
	int a = 5, b = 0;
	fun(a, b);
	return 0;
}
 
#include <iostream>
struct ListNode {
	int val;
	ListNode* next;
	ListNode(int x) : val(x), next(nullptr) {}
};


class Solution {
public:
	ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
		ListNode* dummy = new ListNode(0);
    ListNode* prehead = dummy;
    
		int carry = 0;
    while(l1 && l2) {
      carry += l1->val + l2->val;
      prehead->next = new ListNode(carry%10);
      carry /= 10;
      l1 = l1->next;
      l2 = l2->next;
      prehead = prehead->next;
    }
    while(l1)
    {
      carry += l1->val;
      prehead->next = new ListNode(carry%10);
      carry /= 10;
      l1 = l1->next;
      prehead = prehead->next; 
    }
    while(l2)
    {
      carry += l2->val;
      prehead->next = new ListNode(carry%10);
      carry /= 10;
      l2 = l2->next;
      prehead = prehead->next;
    }
    if (carry!= 0)
    {
      prehead->next = new ListNode(carry);
      prehead = prehead->next;
    }
    
	
	ListNode* ans = dummy->next;
  delete dummy;
  return ans;
	
	}
};

ListNode* AddTwoNumbers(ListNode* l1, ListNode* l2) {
	bool flag = false;
	ListNode* l3 = new ListNode();
	ListNode* l4 = l3;
	int carry = 0;
	while (l1 || l2 || carry) {
		int sum = 0;
		if (l1) {
			sum += l1->val;
			l1 = l1->next;
		}
		if (l2) {
			sum += l2->val;
			l2 = l2->next;
		}
		sum+=carry;
		carry = sum/10;
		l4->next = new ListNode(sum%10);
		l4 = l4->next;
	}
	l2 = l3;
	if (flag == 1)
		return nullptr;
	else return l2;
}
