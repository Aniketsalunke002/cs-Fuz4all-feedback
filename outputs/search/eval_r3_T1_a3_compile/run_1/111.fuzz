#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int a = 5, b = 12;
	cout << a << endl;
	cout << b << endl;
	int *p1 = &a, *p2 = &b;
	a = *(p1 + 1) + *(p2 - 1);
	*p1 = 45;
	*p2 = 30;
	cout << a << endl;
	cout << *p1 << endl;
	cout << b << endl;
	cout << *p2 << endl;
	return 0;
}