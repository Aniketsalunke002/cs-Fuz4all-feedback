#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
	int a,b;
	cout << "enter first int: \n";
	cin >> a;
	b = a << 10; 
	cout << "First int: " << b << endl; 
	float d;
	cout << "Enter int: \n";
	cin >> d;
	long l = d * 1000000;
	cout << "int * double: " << l << endl;
	uint32_t u32 = 5;
	u32 = u32 << 10;
	cout << u32 << endl; 
	return 0;
}

