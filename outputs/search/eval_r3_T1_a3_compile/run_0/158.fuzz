#include <iostream>
using std::endl;
class Base {};
class Derived : public Base {
public:
    Derived(int c = 0) : c(c) {}
    int c;
};
class AnotherDerived : public Derived {
private:
    int d;
public:
    AnotherDerived(int c, int d) : Derived(c), d(d) {}
};
int main(void) {
    Base *pb = new Derived();
    AnotherDerived *pa = new AnotherDerived();
    delete pb;
    pa->c = 10;
    pb = pa;
    pa->d = 20;
    delete pb;
    return 0;
}
 
void func() {
   struct some {
        some();
        int a;
   };
   struct some b = some();
   b.a = 3;
}