#include <iostream>
int main(int argc, char *argv[]) {
  char temp = 'a';
  char array = { 'a', 'b', 'c', 'd', 0 };
  do {
    std::cout << array[temp] << std::endl;
    temp++;
  } while (array[temp]!= 0);
  return 0;
}
 
#include <iostream>
int main(int argc, char *argv[]) {
  int x = 1;
loop:
  std::cout << x <<" ";
  x++;
  if (x < 4) goto loop;
  return 0;
}
