#include <iostream>
using namespace std;
int main() {
    string s;
    cout << "Enter a sentence:";
    cin >> s;
    cout << *next_permutation(s.begin(), s.end());
    sort(s.begin(), s.end(), [](char a, char b) { return b < a; });
    return 0;
}
 
#include <iostream>
#include <vector>
using namespace std;
int main() {
    vector<string> per;
    string str("ABCE");
    do per = str.substr(0, str.size() - 1); while (next_permutation(str.begin(), str.end()));
    for (int i = 0; i < per.size(); i++) cout << per[i] << endl;
    return 0;
}
 
#include <iostream>
#include <map>
#include <vector>
#include <string>
using namespace std;
int main() {
    map<string,int> m;
    string p1;
    while (cin >> p1) { 
        if (m.count(p1) == 0) m[p1] = 1;
        else m[p1] = m[p1] + 1;
    }
    for (map<string,int>::iterator begin1 = m.begin(); begin1!= m.end(); begin1++) 
        for (int i = 0; i < begin1->second; i++) cout << begin1->first << endl;
    return 0;
}
 
 
 
 
 