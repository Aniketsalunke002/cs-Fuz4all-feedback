#include <iostream>
using namespace std;
int main(int argc, char *argv[]) {
  int array[5], c, d;
  for (int i = 0; i < 5; i++) {
    c = 3 + 4;
    c += i * 10;
    array[i] = c;
  }
  for (int i = 0; i < 5; i++) {
    cout << array[i] << " ";
  }
  cout << endl;
  int a = 3, b = 4;
  c = a + b;
  d = c / 5;
  cout << a + b << endl;
  cout << d << endl;
  return 0;
}
