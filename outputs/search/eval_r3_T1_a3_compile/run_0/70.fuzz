#include <iostream>
using namespace std;
#if defined ANOTHER_CONST
const double pi = 4.0 / 3.0 * atan2((sqrt(5.0)), 1.0) + pi;
#endif
int main() {
#if defined ANOTHER_CONST
  cout << "2^(-5) = " << pow(1.0 / 5, -5.0) << endl;
  cout << "sin(" << 12 * pi / 3 << ") = " << sin(12 * pi / 3) << endl;
#endif
  return 0;
}

    
        
