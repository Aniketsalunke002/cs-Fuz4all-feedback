#include <iostream>
using namespace std;
#define C_CONST 1
int main() {
#if defined C_CONST
  int y = 5;
  cout << y << endl;
  while (cin >> y)
    ;
#elif defined C_CONST
  int z = 10;
  char c = 'a';
  cout << z << " " << c << endl;
  const char& p = c;
  p = 'b';
  cout << c << " " << &c << endl;
#endif
  return 0;
}
