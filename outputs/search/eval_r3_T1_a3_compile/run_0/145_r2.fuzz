#include <iostream>

int operator++(int)
{
    std::cout << "post++" << std::endl;
}
int operator++(int, int)
{
    std::cout << "pre++" << std::endl;
}
int main()
{
    int i;
    for(i=0; i<4500; i++) {
        std::cout << "1" << (i+1) << std::endl;
    }
    return 0;
}
