#include <iostream>
#include <list>
using std::list;
using std::endl;
class P {
public:
    virtual std::string &get_name() = 0;
    virtual void set_name(std::string s) = 0;
};
class Student : public P {
    std::string name;
public:
    std::string &get_name() override {
        return name;
    }
    void set_name(std::string s) override {
        name = s;
    }
};
class College : public P {
    std::list<P *> list;
public:
    void add(P *p) {
        list.push_back(p);
    }
    std::string &get_name() override {
        Student *stu = dynamic_cast<Student *>(list.back());
        return stu->get_name();
    }
    void set_name(std::string s) override {
        Student *stu = dynamic_cast<Student *>(list.back());
        stu->set_name(s);
    }
};
int main() {
    College c;
    c.add(new Student{"David"});
    c.set_name("Mia");
    std::cout << c.get_name() << std::endl;
}
 
