}
 
#include <iostream>
using std::cout;
using std::cin;
using std::endl;
using std::getline;
class ListItem {
public:
    int value;
    ListItem<T> *previous;
    ListItem<T> *next;
public:
    ListItem() {
        previous = next = nullptr;
    }
    ListItem<T>(const T &t, ListItem *prev) {
        value = t;
        previous = prev;
        next = prev->next;
        previous->next = next->previous = this;
    }
