#include <iostream>
using namespace std;
int main()
{
    int age {21};
    int height {162};
    int weight {67};
    int tdee {0};
    tdee = age * 162 / 365 * 67 * (162 * 0.703)/100;
    cout << "Age: " << age << endl
    << "Height: " << height << endl
    << "Weight: " << weight << endl
    << " TDEE: " << tdee << endl;
    return 0;
}