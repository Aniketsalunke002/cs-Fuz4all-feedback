#include <iostream>
using namespace std;
int main() {
  int array[][5] = { {1, 2, 3, 4, 5}, {4, 5, 6, 7, 8}, {9, 5, 3, 8, 1} };
  int sum = 0, i, j, a, b, c, d, e;
  for (i = 0; i < 3; i++)
    for (j = 0; j < 5; j++)
      sum += array[i][j];
  for (i = 0; i < 3; i++)
    for (j = 0; j < 5; j++)
      cout << " " << array[i][j];
  cout << " " << sum << endl;
  return 0;
}
