#include <iostream>
using namespace std;
#if defined C_CONST
constexpr double pi = 3.141592653589793238462643383279;
constexpr double e = 2.7182818284590452353602874713527;
#endif
int main() {
#if defined C_CONST
  using namespace std::literals::string_literals;
  if (0 > pi * (1 - cos((1 * pi) / 3)))
    cout << "1" << endl;
  else if (pi * (1 - cos((1 * pi) / 3)) < 0)
    cout << "-1" << endl;
  else
    cout << "0" << endl;
#endif
  return 0;
}
