#include <iostream>

using namespace std;

struct Foo {
    int bar(int);
};

int Bar::bar(int y) {return x*y;}

int Foo::bar(int y) {return x*y;}

int main() {
    int x = 1337;
    Foo f1;
    Bar b1;
    cout<< f1.bar(x)+b1.bar(x) << endl;
    
    return 0;
}

