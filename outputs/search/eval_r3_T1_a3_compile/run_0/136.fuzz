#include <iostream>
int main()
{
    int a;
    a = 3;
    std::cout << "a:" << a <<std::endl;
    return 0;
}
 
#include <iostream>
int main()
{
    int a[20];
    a[3] = 5;
    std::cout << a[3] << std::endl;
    return 0;
}
 
#include <iostream>
int main()
{
    int a = 3;
    int b = 4;
    std::cout << "a: " << a << " b: " << b << std::endl;
    return 0;
}
