#include <iostream>

#include <cmath>
using namespace std;
int main() {
  double a[4], b[4], c[4];
  cin >> a[0] >> a[1] >> a[2] >> a[3];
  cin >> b[0] >> b[1] >> b[2] >> b[3];
  for (int i = 0; i < 4; i++) {
    for (int j = 0; j < 4; j++) {
      c[i] = c[i] + a[i] * b[j];
    }
  }
  cout << c[0] << " " << c[1] << " " << c[2] << " " << c[3] << endl;
  return 0;
}
