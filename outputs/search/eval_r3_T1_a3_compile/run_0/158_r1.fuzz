#include <iostream>

using std::endl;
class Base {};
class Derived : public Base {
public:
    Derived(int c = 0) : c(c) {}
    int c;
};
class AnotherDerived : public Derived {
private:
    int d;
public:
    AnotherDerived(int c, int d) : Derived(c), d(d) {}
};
int main(void) {
    Base *pb = new Derived();
    AnotherDerived *pa = new AnotherDerived(10, 10);
    delete pb;
    pb = pa;
    pa->c = 20;
    pa->d = 30;
    delete pb;
    return 0;
}