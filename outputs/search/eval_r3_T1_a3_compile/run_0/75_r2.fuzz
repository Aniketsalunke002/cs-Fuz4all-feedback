#include <iostream>

using namespace std;
int main() {
  constexpr double pi = 4.0 / 3.0 * atan2((sqrt(5.0)), 1.0) + pi;
  int hypot(int x, int y){
    return sqrt(x * x + y * y);
  }
  cout << "hypot(1, 1) = " << hypot(1, 1) << endl;
  cout << "hypot(1, 1) ** 2 = " << pow(hypot(1, 1), 2) << endl;
  cout << "hypot 4/3 pi = " << hypot(4, 3) << endl;
  return 0;
}