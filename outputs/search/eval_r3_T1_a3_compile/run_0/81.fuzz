#include <iostream>
using namespace std;
 
 
void printId(double arr[])
{
    cout << arr[0] << " " << "1" << " " << "0" << endl;
    cout << "1" << " " << arr[1] << " " << "0" << endl;
    cout << "0" << " " << "0" << " " << arr[2] << endl;
}
 
int main()
{
    double mat[3][3];
 
     
    mat[0][0] = 1; mat[1][0] = 0; mat[2][0] = 0;
    mat[0][1] = 0; mat[1][1] = 1; mat[2][1] = 0;
    mat[0][2] = 0; mat[1][2] = 0; mat[2][2] = 1;
 
     
    printId(mat[0]);
 
    return 0;
}