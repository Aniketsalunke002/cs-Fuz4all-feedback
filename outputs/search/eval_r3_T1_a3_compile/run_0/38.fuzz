#include <iostream>
#include <memory>
#include <string>

using namespace std;

int main(int argc, char **argv) {
  auto ptr1 = make_unique<string>("Hello");
  string *ptr2 = new string("Goodbye");

  cout << *ptr1 << endl;
  cout << *ptr2 << endl;
  delete ptr2;

  int nums[10]{0,};
  for (int i = 0; i < 10; i++) {
    nums[i] = 2 * nums[i-1];
  }
  
  return 0;
}
