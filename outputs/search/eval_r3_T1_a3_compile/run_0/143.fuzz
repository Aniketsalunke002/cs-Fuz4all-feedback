#include <iostream>
using std::endl;
struct Base {
    int a;

    Base* operator++()
    {
        return this;
    }
};

struct Derived : public Base {
    int b;
};

int main()
{
    Derived d;
    Derived* pd = &d;
    Base* pb = pd++;
    pb->a = 20;
    std::cout << d.a << "\t" << d.b << endl;
    return 0;
}