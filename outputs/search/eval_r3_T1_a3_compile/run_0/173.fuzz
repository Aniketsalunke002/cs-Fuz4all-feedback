#include <iostream>
using namespace std;
#define M_PI 3.141592653589793

int main(int argc, char const *argv[])
{
    int x = 200;
    int y = 98;
    const double result = (pow(x,y)-x)/y;

    cout << result << endl;
    return 0;
}

