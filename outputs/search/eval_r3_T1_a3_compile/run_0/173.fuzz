#include <iostream>
using namespace std;
#include <cmath>
int main()
{
    using namespace std;
    const unsigned int x = 10;
    float f = 10;
    cout << "Hello, World!\n";
    cout << x / f << endl;
    return 0;
}

 
#include <iostream>
using namespace std;

#include <cmath>

int main()
{
    int x = 10, y = 10;
    cout << "Hello, World!";
    cout << x/y <<endl;
}

 
