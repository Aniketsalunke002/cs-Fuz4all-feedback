class MyGame {
    private:
        int x = 1;
    public:
        string enter(string move, string s) {
            if(move == "N") 
                x++;
            else x--;
            switch(x) {
            case 1: 
                s = "Entered the cave";
                break;
            case 2: {
                if(move == "S") s = "You slip and fall onto the ground";
                else s = "You cannot go that way";
                x--;
                break;
            }
            case 3: s = "You have been knocked into a chair";
                x = 1;
                break;
            default:
                s = "You have escaped the cave";
                break;
            }
            cout << "x = " << x << endl;
            return s;
        }
};

 

 

 
