#include <iostream>
using namespace std;
int main() {
  int array[10];
  array[0] =  1;
  array[1] = 2;
  array[2] = 3;
  array[3] =  4;
  array[4] =  5;
  array[5] =  6;
  array[6] =  7;
  array[7] =  8;
  array[8] =  9;
  array[9] = 10;
   
  int counter = 1;
  while (counter <= 5) {
    cout << array[counter] << " ";
    counter++;
  }
  cout << endl;
  while (counter <= 10) {
    cout << array[counter] << " ";
    counter++;
  }
  cout << endl;
  return 0;
}
