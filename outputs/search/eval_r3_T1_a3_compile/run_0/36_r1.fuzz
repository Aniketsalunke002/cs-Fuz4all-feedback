#include <iostream>

using namespace std;
int main() {
  int a[6] = {1,2,3,4};
  cout << "*";
  for (int i = 0; i < 5; ++i) {
    cout << a[i] << " ";
  }
  int b[2] = {5, 6};
  int c[4] = {2, 1, 3, 4};
  cout << "|" << b[0] << b[1] << "|" << c[0] << c[1] << 
        c[2] << c[3] << endl;
  return 0;
}
