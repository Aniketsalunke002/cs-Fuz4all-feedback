#include <iostream>

#include <vector>
#include <map>
#include <string>
using namespace std;
int main() {
    map<string,int> m;
    string p1;
    while (cin >> p1) { 
        if (m.count(p1) == 0) m[p1] = 1;
        else m[p1] = m[p1] + 1;
    }
    for (map<string,int>::iterator begin1 = m.begin(); begin1!= m.end(); begin1++) 
        for (int i = 0; i < begin1->second; i++) cout << begin1->first << endl;
    return 0;
}