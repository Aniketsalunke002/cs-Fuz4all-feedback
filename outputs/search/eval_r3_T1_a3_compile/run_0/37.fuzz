#include <iostream>
using namespace std;
int main() {
  int a[6] = {1,2,3,4};
  cout << "*";
  for (int i = 0; i < 6; ++i) {
    cout << a[i] << " ";
  }
  cout << "|" << a[5] << endl;
  return 0;
}
 
#include<iostream>
using namespace std;
int main() {
  int a[6] = {5,6,7,8,9,10};
  int *ptr = a;
  cout << *ptr << endl;
  --ptr;  
  --*ptr;  
   
  int array[] = {1,2,3};  
}