#include <iostream>

#include <vector>
using namespace std;
int main() {
    double x = 13.37;
    vector<double> v;
    for(int i = 0; i < 10; i++) {
        v.push_back(x++);
    }
    for(int i = 0; i < v.size(); i++) {
        cout << v[i] << " ";
    }
}

