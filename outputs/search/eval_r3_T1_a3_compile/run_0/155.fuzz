#include <iostream>
#include <cstdint>
#include <cmath>
bool isSumOfSquares(uint32_t n) {
    for (uint32_t i = 1; i <= n / 2; i++) {
        if (std::pow(i, 2) + std::pow(n - i, 2) == n) {
            return true;
        }
    }
    return false;
}
 
#include <iostream>
#include <cstdint>
#include <cmath>
void checkArray(uint32_t *array, size_t size) {
    for (uint32_t i = 0; i < size; i++) {
        for (uint32_t j = 1; j <= i / 2; j++) {
            if (array[i] == std::pow(j, 2) + std::pow(i - j, 2)) {
                std::cout << array[i] << std::endl;
                std::cout << "i: " << i << ", j: " << j << std::endl;
                return;
            }
        }
    }
    std::cout << "not found" << std::endl;
}