#include <iostream>
using std::endl;
class Base {
public:
    int a;
    virtual void print_a_plus(int i) {
        std::cout << "a: " << a + i << std::endl;
    }
};
int main() {
    Base b;
    b.a = 20;
    b.print_a_plus(10);
    return 0;
}
