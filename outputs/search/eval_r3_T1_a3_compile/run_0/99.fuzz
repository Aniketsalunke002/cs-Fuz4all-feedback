#include <iostream>
#include <string>

void print(std::string str, char chr) {
  for (char c = '0'; c <= chr; c++)
    std::cout << str << c << " ";
  std::cout << "\n";
}

int main() {
  std::cout << "Hello There!" << "\n";
  return 0;
}
 
#include <iostream>
using namespace std;

void print(int n) {
  switch (n) {
  case int i:
    std::cout << i << ", " << '\0';
    break;
  case int j:
    std::cout << j << ", " << '\0';
    break;
  }
}

int main(int argc, char *argv[]) {
  std::cout << "Hello There!" << "\n";
  print(100);
  return 0;
}
 
