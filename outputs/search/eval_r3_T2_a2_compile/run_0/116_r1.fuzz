#include <iostream>

#include <cstdlib>
int main() {
  int a,b,c,d,e,f;
  int num = rand()%100 ;
  std::cin>>a>>b>>c>>d;
  if( num%2==0 ) { std::cout<<b*f-a*d<<std::endl;}
  else std::cout<<c*d-b*f<<std::endl;
  return 0;
}
