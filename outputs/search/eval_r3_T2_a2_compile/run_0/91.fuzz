template <typename T>
void foo(T a, T b) {
    a = a + 1; 
    cout << "Template: " << a << " " << b << endl;
}
int main(int argc, char** argv) {
    int a1{0}, a2{0}, a3{0};
    foo(a1, a2);    
    foo(a3, a2);    
}
 
#include <iostream>
#include <stack>
#include <vector>
#include <math.h>
using namespace std;
#define PMAX 100
#define GOLDEN_RATIO 0.382
typedef unsigned int tGen;
typedef unsigned short tChromo;
float randomFloat(){
    return rand()/(float)RAND_MAX;
}
int randomInteger(const int a, const int b){
    return a + (b-a)*randomFloat();
}
float normal(float mean, float sd) {
    float x = randomFloat();
    while (x < GOLDEN_RATIO || x > 1 - GOLDEN_RATIO) {
        x = randomFloat();
    }
    return x*sd + mean;
}
float distance(const float& a, const float& b) {
    return (b - a)*(b - a);
}
float mutationRate(const float& a, const int& generation) {
    return 0.005 - (float)generation*0.008;
}
struct Candidate {
    float fitnessScore;
    float distanceToIndividualsAvgFitnessScore;
    tChromo* bestOffspring;
    tChromo parentalChromo;
};
float individualFitness(const tChromo& chromosome, const float& goal) {
    float sum = 0.0;
    for (int i = 0; i < PMAX; ++i) {
        float x1 = normal(1, 1);
        float x2 = normal(1, 1);
        float diff = fabs(sqrt(x1*x1+x2*x2)-goal);
        sum += diff*diff;
    }   
    sum = sum/PMAX;
    return sum;
}
