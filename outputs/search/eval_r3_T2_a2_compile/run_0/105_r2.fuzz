#include <iostream>

#include <cstdio>
using std::cin;
using std::cout;
using std::endl;
int foo(int a, int b)
{
    while ((a <= b) && (c!= 9))
    {
        b--;
    }
    return (b - a)/(b + a);
}
int main(int argc, char** argv)
{
    int a=1, b=7, c;
    while(scanf("%d", &c) == 1)
    {
        if (c!= b)
        {
            if (c!= a)
            {
                a = b = c;
            }
        }        
    }
    cout << foo(a, b) << endl;
}