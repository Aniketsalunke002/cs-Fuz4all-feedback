#include <iostream>

int main() {
  int x, y, z;
  for (z = 0; z < 2; z++) {
    std::cin >> x >> y;
    if (z!= 0) {
      std::cout << " " << x << " " << y;
    } else {
      std::cout << x << " " << y;
    }
  }
  std::cout << std::endl;
}
