#include <iostream>

#include <utility>

int main(int argc, char** argv) {
    int r, c;
    std::cin >> r >> c;
    int data[r][c];
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            std::cin >> data[i][j];
        }
    }
    for (int i = 0; i < r; i++) {
        for(int j = 0; j < c; j++) {
            std::cout << data[i][j] << " ";
        }
        std::cout << "\n";
    }
}