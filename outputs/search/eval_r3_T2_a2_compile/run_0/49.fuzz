#include <iostream>
int main(int argc, char** argv)
{
    int a, b, c;
    std::cin >> a >> b >> c;
    if (a == c)
    {
        if (a % c > 0 && a / c % b == 0)
            std::cout << "YES: " << a/c-b;
        else
            std::cout << "NO";
    }
    else
        std::cout << a + b * c % (2 * a) + c * (a / 2);
}
 
#include <iostream>
#include <utility>
int main(int argc, char** argv)
{
    int r(), c;
    std::cin >> r >> c;
    int data[r][c];
    for (int i = 0; i < r; i++)
    {
        for (int j = 0; j < c; j++)
        {
            std::cin >> data[i][j];
        }
    }
    for (int i = 0; i < r; i++)
    {
        for(int j = 0; j < c; j++)
        {
            std::cout << data[i][j] << " ";
        }
        std::cout << "\n";
    }
}
