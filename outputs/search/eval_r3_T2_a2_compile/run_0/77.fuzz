#include <iostream>
using namespace std;
int main(int argc, char** argv) {
    int x[100], a, b, i;

    for (i = 0; i < 100; i++)
        cin >> x[i];
    cin >> a;
    cin >> b;
    for (i = b + 1; i < 99; i++)
        if (x[i] == a)
            break;
    cout << a << " " << i;
}
 
#include <iostream>
using namespace std;
const int MAX = 100;
int main(int argc, char** argv) {
    int x[MAX], a, b, i;

    for (i = 0; i < 100; i++)
        cin >> x[i];
    cin >> a;
    cin >> b;
    for (i = b; i < 99; i++) {
        if (x[i + 1] == a) {
            x[i] = x[i + 1];
            i++;
        }
    }
    cout << x[b + 1] << " " << i;
}
