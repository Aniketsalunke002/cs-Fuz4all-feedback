#include <iostream>

#include <algorithm>
void main() {
  int n = 0;
  std::cin >> n;
  int number;
  std::cin >> number;
  int min = number;
  int max = number;
  if (min > max) {
    int tmp = min;
    min = max;
    max = tmp;
  }
  std::cout << "Max is " << max << std::endl;
  std::cout << "Min is " << min << std::endl;
}