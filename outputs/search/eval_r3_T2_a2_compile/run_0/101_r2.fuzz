#include <iostream>

#include <vector>
using std::cin;
using std::cout;
using std::endl;
using std::vector;
class A {
    int *x;
    int n;
    public:
    A(int a = 1, int b = 0) {
        cout << "construct A" << endl;
        x = new int[a];
        n = a;
        for(int i=0; i < a; i++) {
            x[i] = b;
        }
        cout << "A constructed" << endl;
    }
    ~A() {
        cout << "destruct A" << endl;
        delete[] x;
        x = NULL; n = 0;
    }
    void print() {
        for(int i=0; i < n; i++)
            cout << x[i] <<'';
        cout << endl;
    }
};
int main(int argc, char** argv)
{
    A a;
    a.print();
    a.x[1] = 2;
    a.print();
    A b(4, 9);
    b.print();
}