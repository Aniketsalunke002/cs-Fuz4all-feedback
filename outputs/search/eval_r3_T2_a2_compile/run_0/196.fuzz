* **(28) 512B+3B**
```c++
 
class Memoir {
public:
  int get(int cur, int target) {
    if (cur == target)
      return 1;
    if (cur < 0 || target == 0)
      return 0;
    if (memo[cur][target])
      return memo[cur][target];
    return memo[cur][target] = get(cur, target - cur) + get(cur - 1, target);
  }

private:
  int memo[205][205];
};
```

* **(29) 512B**
```c++
 
class Memoir {
public:
  int get(int cur, int target) {
    if (cur == target)
      return 1;
    if (cur < 0 || target == 0)
      return 0;
    if (memo[cur][target])
      return memo[cur][target];
    int tmp = get(cur, target - cur) + get(cur - 1, target);
    memo[cur][target] = tmp % 10;
    return memo[cur][target];
  }

private:
  int memo[205][205];
};
```

* **(30) 512B**
```c++
 
class Memoir {
public:
  int get(int cur, int target) {
    if (cur == target)
      return cur;
    if (cur < 0 || target == 0)
      return 0;
    if (memo[cur][target]) {
      return memo[cur][target];
    } else {
        int l = cur % target == 0
                  ? cur / target
                   : get(cur, target - (cur % target));
        memo[cur][target] = 10 * l + (cur / target);
        return memo[cur][target];
    }
  }

private:
  int memo[205][205];
};
```

