#include <iostream>
using std::cin;
using std::cout;
using std::endl;
namespace MyNamespace
{
  int foo(int a, int b, int c) {
    int tmp2 = 0;
    while(tmp2<(a/b)-(c/b))
        tmp2++;
    return 0;
  }
}
int main(int argc, char** argv)
{
int a=1, b=7, c;
while(cin >> c)
{
  a = b;
  b=c;
}
cout << MyNamespace::foo(a, b, c) << endl;
return 0;
}
