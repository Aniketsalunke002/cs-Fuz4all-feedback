#include <iostream>
#include <iomanip>
using namespace std;
int main() {
    int i = 0;
    int j = 0;
    if (i)
        cout << i << endl;
    if (i == j)
        cout << i;
    else
        cout << j;
    cout << j;
    return 0;
  };