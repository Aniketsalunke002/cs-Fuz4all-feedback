#include <iostream>
using std::cin;
using std::cout;
using std::endl;
int foo(int a, int b) {
    while(a <= b)
        b++;


    return (b - a)/(b + a);
}
int main(int argc, char** argv)
{
    int a=1, b=7, c;
    while(cin >> c)
        if (c!= b)
            if (c!= a)
                b = c;


    cout << foo(a, b) << endl;
}
 
