#include <iostream>
#include <vector>
int main() {
  std::vector<int> v = {};
  return 0;
}
 
#include <iostream>
int main() {
  int myInt = 1000;
  std::cout << "myInt = " << myInt << "\n";
  return 0;
}

 
#include <iostream>
int main() {
  int myInt {1000};
  std::vector<int> v {1,2,3,4,5};
  std::cout <<  "myInt = " << myInt << "\n";
  std::cout << "v = " ;
  for (int i : v) { std::cout << i << " "; }
  std::cout << "\n";
  return 0;
}
