#include <iostream>
#include <string>
using namespace std;

int main() {
    cout << "1234567890+";
    string plus;
    for(int i = 0; i < 10; i++) {
    int v = i%10;
	plus = v + plus;
    cout << plus + '\t';
	}
    return 0;
}

int main() {
string message;
cin >> message;
int n = message.length();
for(int i = 0; i < n/2; i++) {
    cout << message[i];
}
return 0;
}

#include <iostream>
#include <vector>
using namespace std;

int main() {
    float x;
    for(int i = 0; i < 20; i++) {
	if (i%2 == 0) {
		x = 2.0*i;
	}
	else {
		x = 3.5*i;
	}
	cout << x << endl;
    cout << x + 1 << endl;
    cout << x << "  " << x + 1 << endl;
    }
    return 0;
}