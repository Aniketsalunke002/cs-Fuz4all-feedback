#include <iostream>

#include <string>
 
using namespace std;

using MyType = int;

[[maybe_unused]] static inline MyType add(MyType a, MyType b)
{
  return a + b;
}

int main()
{
  MyType a = 3;
  MyType b = 4;
  MyType c = 0;
  
  std::cout << "1+1=" << add(a, b) << std::endl;
  std::cout << R"(add(a, b) = )" << add(a, b) << std::endl;  
  cout << "Hello" << endl;
  return 0;
}
