#include <iostream>

#include <vector>

using namespace std;

int get_sum(vector<int>& v)
{
    int sum = 0;
    for (unsigned int i=0; i < v.size(); ++i) {
        sum += v[i];
    }
    return sum;
}

int main()
{
    vector<int> v;
    v.push_back(1);
    v.push_back(2);
    v.push_back(3);
    int sum = get_sum(v);
    cout << "Sum of elements is " << sum << endl;
}
