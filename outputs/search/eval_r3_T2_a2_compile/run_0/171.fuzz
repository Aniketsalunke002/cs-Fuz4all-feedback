#include <iostream>
using namespace std;
class x {
  public:
    x(): n{new int} {}

    x(const x& y): n{new int} {
      *n = *y.n;
    }

    x(x&& y) {
      int* tmp = n; n = y.n; y.n = tmp;
    }


    ~x() {
      delete n;
    }

    x& operator=(const x& y) {
      if (this!= y) {
	*n = *y.n;
      }
      return *this;
    }

    x& operator=(x y) {
      *this = x();
      return *this;
    }
    int* n;
};
int main() {
  x a{1}, b{1}
  b = std::move(a);
}
