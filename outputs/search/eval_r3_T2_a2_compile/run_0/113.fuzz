#include <iostream>
int main() {
  int x, y, z;
  std::cin >> x >> y;
  if (x > y) {
    z = x;
    x = y;
    y = z + 1;
  }
  std::cout << x << " " << y;
}
 
#include <iostream>
const double Pi = 3.14;
int main() {
  int R;
  double A, s;
  std::cin >> R;
  A=2*Pi*R;
  s=4*Pi*R*R;
  std::cout << A << " " << s;
}
 
#include <iostream>
#define Pi 3.14
 
int main() {
  int r;
  double a, s;
  std::cin >> r;
  a=2*Pi*r;
  s=4*Pi*r*r;
  std::cout << a << " " << s << "\n";
};
