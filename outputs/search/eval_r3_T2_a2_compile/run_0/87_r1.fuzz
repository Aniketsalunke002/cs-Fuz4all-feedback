#include <iostream>

using namespace std;
const int MAX = 5;
struct BitVec {
    int n;
    BitVec(int x) : n(x) {}
    BitVec operator~() {
        return BitVec((~n) & (MAX - 1));
    }
    BitVec operator&(BitVec const y) {
        return BitVec((n & y.n) & (MAX - 1));
    }
    BitVec operator|(BitVec const y) {
        return BitVec((n | y.n) & (MAX - 1));
    }
    friend BitVec operator&(int const x, BitVec y) {
        return y & BitVec(x);
    }
    friend BitVec operator|(int const x, BitVec y) {
        return y | BitVec(x);
    }
    friend ostream &operator<<(ostream &os, BitVec x) {
        for (int i = 0; i < MAX; ++i) cout << x[i] <<'';
        return os;
    }
    friend BitVec operator>>(BitVec x, int y) {
        BitVec out = BitVec(0);
        for (int i = 0; i < MAX; ++i) {
            out[i] = x[y + i];
        }
        return out;
    }
    friend BitVec operator<<(BitVec x, int y) {
        BitVec out = BitVec(0);
        for (int i = 0; i < MAX; ++i) {
            out[i + y] = x[i];