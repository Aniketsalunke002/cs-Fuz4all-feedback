namespace {
int max(const std::vector<int>& v) {
  int m = *std::max_element(std::begin(v), std::end(v));
  auto t = std::find(std::begin(v), std::end(v), m);
  for (; m == *t; ++t)
    ;
  return std::distance(std::begin(v), t);
}
}
namespace {
template <const unsigned M>
class modint{
public:
  unsigned v;
  modint(const modint& x) = default;
  modint(const int s) : v(s >= 0? s % M : (s+M)% M) {}
  operator int() const { return v; }
  modint& operator=(const modint& x) {
    if (this == &x)
      return *this;
    v = x.v % M;
    if (v < 0)
      v += M;
    return *this;
  }
  modint& operator+=(const modint& x) {
    v += x.v;
    if (v >= M)
      v -= M;
    return *this;
  }
  modint& operator-=(const modint& x) {
    if (v < x.v)
      v += M;
    v -= x.v;
    return *this;
  }
  modint& operator*=(const modint& x) {
    v = int((long long)v * x.v % M);
    return *this;
  }
};
template <const unsigned M>
modint<M> inv(const modint<M>& x) {
  return modint<M>(M - x.v).power(M-2);
}
template <class T, const unsigned N, const unsigned M>
modint<M> operator+(const modint<M> x, const modint<N>(&y)[N]) {
  modint<M> t(x);
  std::copy(std::begin(y)+1, std::end(y), std::begin(y));
  std::transform(std::begin(y), std::end(y), std::begin(y), [&](const modint<N> z){return z + x;});
  return t;
}
template <const unsigned M>
modint<M> operator-(const modint<M>& x, const modint<M>& y) {
  return x + (-y);
}
constexpr static const int maxn = 500000;
modint<100000000> a[maxn];
}
