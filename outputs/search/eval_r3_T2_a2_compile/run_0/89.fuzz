#include <iostream>
using namespace std;
#define MAX 3
using std::cout;
using std::endl;
class Point {
    int x_;
    int y_;
#ifndef __APPLE__
    public:
    Point() : x_{0}, y_{0} {
    }
    Point(int x, int y) noexcept {
        x_ = x;
        y_ = y;
    }
#else
    public:
    Point()
        : x_{1}, y_{2} {
    }
    Point(int x, int y) noexcept
        : x_{x}, y_{y} {
    }
#endif  
    Point& operator+=(const Point& rhs) noexcept {
        x_ += rhs.x_;
        y_ += rhs.y_;
        return *this;
    }
    Point operator&(const Point& rhs) noexcept {
        return Point(x_ & rhs.x_, y_ & rhs.y_);
    }
    friend Point operator+(Point lhs, const Point& rhs) noexcept;
    friend void foo(Point& a,
                    Point& b) noexcept;
    friend int foo(int a, int b) noexcept;
};
Point foo(Point a, Point b) noexcept {
    a += b;
    return a;
}
Point operator+(Point lhs, const Point& rhs) noexcept {
    lhs += rhs;
    return lhs;
}
int foo(int a, int b) noexcept {
    return a * b;
}
int main(int argc, char** argv) {
    Point p1{1, 2};
    Point p2{5, 6};
    Point p3 = foo(p1, p2);
    std::cout << p3.x_ << "," << p3.y_ << "\n";
}
