#include <stdio.h>
#include <iostream>

int main(int argc, char* argv[]) {
    float floatX, floatY, floatZ;
    std::cin >> floatX;
    char character;
    std::cin >> character;
    std::cin >> floatY;
    std::cin >> floatZ;
    std::cout << floatX + floatY + floatZ + character << std::endl;
    return 0;
}
