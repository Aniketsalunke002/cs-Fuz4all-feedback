#include <iostream>

#include <cstdint>
#include <utility>

constexpr bool is_even(int n) { return n % 2 == 0; }
int main() {
  int32_t input;
  std::cin >> input;
  if constexpr (is_even(input)) {
    std::cout << (input << 1);
  } else if constexpr (!is_even(input)) {
    std::cout << input / 2;
  }
  return 0;
}