#include <iostream>

#include <vector>

namespace std {

typedef int size_type;

}

class Vector {
 public:
  std::vector<double> V;

  template<typename T>
  std::vector<T>
  operator[](std::size_type idx) {
    idx++;
    return {V[idx]};
  };
  std::size_type
  size() {
    return this->V.size();
  };
  int
  get(std::size_type idx) {
    return this->V[idx];
  };
};

int main(int argc, char *argv[], char *envp[]) {
  if (argc > 2) {
    std::cout << argv[0] << " [option]\n";
    std::cout << argv[0] << " a\n";
    std::cout << argv[0] << " a b\n";
  }
  return 0;
}