#include <iostream>
int main() {
    int i = 0, sum = 0, n = 0;
    std::cin >> n;
    for (; i < n; ++i) {
        int num;
        std::cin >> num;
        if (num % 5 == 0 || num == 5) {
            sum += num;
        }
    }
    std::cout << sum;
    return 0;
}
int main2() {
    std::cout << 0;
    return 0;
}
