#include <iostream>

using namespace std;
void swap(int* a, int* b) {
    int t = *a; *a = *b; *b = t;
}
void move_in(int a[10], int* p) {
    for (int i = 9; i >= 0; i--)
        p[i+1] = a[i];
}
void move_out(int a[10], int* p){
    for (int i = 1; i < 3; i++)
        a[i-1] = p[i];
}
int main(void) {
    int arr[10] = {1, 3, 4, 5, 6, 7, 8, 9, 10, 6};
    int* p = arr;
    do {
        cout << *p << " ";
    } while (++p < arr + 10);
    arr[3] = 4;
    arr[1] = 2;
    p = arr + 1;
    while (*p < 9)++p;
    p = arr + *p;
    move_out(arr, p);
    p = p - 1;
    move_in(arr, p);
    cout << " ";
    do {
        cout << *p << " ";
    } while (++p < arr + 10);
    return 0;
}