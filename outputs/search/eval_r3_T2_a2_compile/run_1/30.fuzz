#include <iostream>
int main(int argc, char *argv[], char *envp[]) {
  if (argc > 2) {
    std::cout << argv[0] << " [option]\n";
    std::cout << argv[0] << " a\n";
    std::cout << argv[0] << " a b\n";
  }
  return 0;
}
 
#include <iostream>
#include <vector>
class Vector {
  public:
  typedef int size_type;
  private:
  std::vector<double> V;
  public:
  template<typename T>
  std::vector<T>
  operator[](size_type idx) {
    idx++;  
    return {V[idx]};
  };
  size_type
  size() {
    return this->V.size();
  };
  int
  get(size_type idx) {
    return this->V[idx];
  };
};
int main(int argc, char *argv[], char *envp[]) {
  if (argc > 2) {
    std::cout << argv[0] << " [option]\n";
    std::cout << argv[0] << " a\n";
    std::cout << argv[0] << " a b\n";
  }
  return 0;
}
