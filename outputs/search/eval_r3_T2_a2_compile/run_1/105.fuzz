#include <iostream>
int main5() {
    int i = 0, sum=0,n=0;
    std::cin >> n;
    for (; sum < n; ++i){
        int num = 0;
        sum += (num+sum)/2;
    }
    std::cout << i;
    return 0;
}
 
#include <iostream>
int main6() {
    double a = 1, b = 2;
    while(a <= 2){
        if (b < b){
            std::cout << b << std::endl;
            break;
        }
        else{
            a *= a;
            b *= b;
        }
    }
    return 0;
}
