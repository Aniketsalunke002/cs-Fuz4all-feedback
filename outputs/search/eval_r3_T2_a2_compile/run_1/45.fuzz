#include <vector>
#include <iostream>
int main() {
  std::vector<int> vec1;
  std::vector<int> vec2;
  std::vector<int> vec;

  auto counter1 = 1;
  auto counter2 = 10;

  while (counter1 <= 10) {
    if (counter2 == 20) {
      vec1.push_back(counter1);
      counter2 = 10;
    }
    else {
      vec1.push_back(counter1);
      counter2++;
    }
    counter1++;
  }
  counter1 = 1;
  counter2 = 10;

  while (counter2 <= 100) {
    if (counter1 == 20) {
      vec2.push_back(counter2);
      counter1 = 10;
    }
    else {
      vec2.push_back(counter2);
      counter1++;
    }
    counter2++;
  }

   
  for (auto index = 0; index < vec1.size(); index++) {
    vec.push_back(vec1[index]);
    vec.push_back(vec2[index]);
  }
  
   
  vec.erase(vec.begin());
  vec.erase(vec.end() - 2);

  std::cout << "Result: ";
  for (const auto& item : vec) {
    std::cout << item << ", ";
  }
}
  
