#include <iostream>

namespace fuzz {
void matrix_multiply(double A[4][4]);
}
void mutate_function_1() {
    std::bitset<FUZZ_TARGET_SIZE> mem_area;
    for (int i = 0; i < FUZZ_TARGET_SIZE; i++) {
        int bit = rand() % 8;
        mem_area[i] = 1 << bit;
        bool fuzz_bool = ((rand() % 2) == 1);
        FUZZ_TEST(fuzz_bool, FUZZ_TARGET(mem_area));
    }
}
namespace fuzz {
void matrix_multiply(double A[4][4]) { }
}
namespace {
char* mem_area = NULL;
}
void mutate_function_2() {
    if (mem_area == NULL) mem_area = (char*)malloc(FUZZ_TARGET_SIZE);
    for (int i = 0; i < FUZZ_TARGET_SIZE; i++) {
        int bit = rand() % 8;
        mem_area[i] = 1 << bit;
        bool fuzz_bool = ((rand() % 2) == 1);
        FUZZ_TEST(fuzz_bool, FUZZ_TARGET(mem_area));
    }
}
void generate_random_input_file() {
    std::ofstream outfile("rand_data.txt");
    for (int i = 0; i < 200; i++) {
        std::bitset<FUZZ_TARGET_SIZE> mem_area;
        for (int j = 0; j < FUZZ_TARGET_SIZE; j++) {
            int bit = rand() % 8;
            mem_area[j] = 1 << bit;
        }
        outfile << mem_area << std::endl;
    }
}