#include <iostream>
#include <vector>
using namespace std;
int main() {
  vector<double> input;
  double sum = 0;
  for (int i = 0; i < 10; i++) {
   cin >> input[i];
   sum += input[i];
  }
  cout << sum << endl;  
  return 0;
}
 
#include <iostream>
int main(){
    int a[20],n,i,j,t;
      cout<<"Enter the number of elements: ";
      cin>>n;
      for(i=0;i<n;i++){
        cout<<"Enter element "<<i + 1<< ": ";
          cin>>a[i];
      }
      for(j=0;j<n;j++){
        for(i=j+1;i<n;i++){
          if(a[j]>a[i]){
            t=a[j];
            a[j]=a[i];
            a[i]=t;
          }
        }
      }
        for(i=0;i<n;i++){
        cout<<a[i]<<" ";
     }
            cout<<endl;
      return 0;
        }       
 
