#include <iostream>
int main() {
    int n = 10, c[10];
    int i = 0;
    while (i < n) {
        c[i] = 2 * i;
        i++;
    }
    i = 0;
    while (i < n) {
        c[i] = c[i] * 3;
        i++;
    }
    i = 0;
    while (i < n) {
        c[i] = 2 * c[i];
        i++;
    }
    i = 0;
    while (i < n) {
        std::cout << c[i] << " ";
        i++;
    }
    std::cout << std::endl;
    return 0;
}
