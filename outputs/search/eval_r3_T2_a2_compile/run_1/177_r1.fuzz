#include <iostream>

using namespace std;
float myfunc (float *a, int b) {
    float sum=0.0;
    for (int i=0; i< b; i++){
        sum=sum+a[i];
    }
    return sum;
}
int main()
{
    float listNum1[7]={1.3,1.7,2.2,3.3,5.5,7.1,13.4};
    int listNum2[7]={1,1,8,36,9,25,2};
    cout << "Test myfunc: " << myfunc(listNum1, 7) << "\n";
    cout << "Test myfunc: " << myfunc(listNum2, 7) << "\n";
    return 0;
}