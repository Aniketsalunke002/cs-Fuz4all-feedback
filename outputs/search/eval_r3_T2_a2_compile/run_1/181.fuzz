#include <iostream>
using namespace std;
class Shape
{
protected:
    int base;
    int length;
public:
    int area();
    Shape(int newbase, int newlength);
};
Shape::Shape(int newbase, int newlength):
    base(newbase), length(newlength){}
int Shape::area(){
    if(base>0 && length>0){
        return base*base;
    }
    else{
        return 0;
    }
}
