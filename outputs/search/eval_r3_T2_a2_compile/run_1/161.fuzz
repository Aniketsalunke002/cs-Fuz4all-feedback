#include <iostream>
int main() {
    double a [16];
        for (int i = 0; i < 16; i++)
        {
            a[16 - i - 1] = -1 * (i * i);
            if (a[16 - i - 1] == -1.0 * (i * i))
            {
                std::cout << "OK" << '\n';
            }
        }
        return 0;
    }

#endif