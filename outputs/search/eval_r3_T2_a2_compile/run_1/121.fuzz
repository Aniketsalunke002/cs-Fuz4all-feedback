#include <iostream>
using std::cin;
using std::cout;
using std::endl;
int main() {
    cout << "Enter at most 5 numbers: " << endl;
    int sum = 0, number = 0, max = 0;
    while ((cin >> number) && (sum < 5)) {
        sum += 2;
        if (sum > max) {
            max = sum;
        }
    }
    cout << sum << endl;
    cout << "Maximum sum in this example was " << max << endl;
}

