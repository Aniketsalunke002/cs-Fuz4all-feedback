#include <iostream>
#include <list>
using namespace std;

int main()
{
   list <string> mylist;

   mylist.push_back("First element");
   mylist.push_back("Second element");
   mylist.push_back("Third element");
    
   for(list <string>::iterator it=mylist.begin(); it!=mylist.end(); it++)
   {
      cout << *it << "\n";
   }
   return 0;
}
