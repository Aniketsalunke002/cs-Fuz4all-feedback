#include <iostream>

#include <cstdlib>
#include <bitset>

namespace fuzz {
void matrix_multiply(double A[4][4]);
}

char* mem_area = NULL;

void mutate_function_2() {
    if (mem_area == NULL) mem_area = (char*)malloc(FUZZ_TARGET_SIZE);
    for (int i = 0; i < FUZZ_TARGET_SIZE; i++) {
        int bit = rand() % 8;
        mem_area[i] = 1 << bit;
        bool fuzz_bool = ((rand() % 2) == 1);
        FUZZ_TEST(fuzz_bool, FUZZ_TARGET(mem_area));
    }
}

void generate_random_input_file() {
    FILE* fp;
    fp = fopen("input.txt", "w");
    for (int i = 0; i < 4; i++) {
        for (int j = 0; j < 4; j++) {
            float random_float = rand() / (float)RAND_MAX;
            fprintf(fp, "%f ", random_float);
        }
        fprintf(fp, "\n");
    }
    fclose(fp);
}