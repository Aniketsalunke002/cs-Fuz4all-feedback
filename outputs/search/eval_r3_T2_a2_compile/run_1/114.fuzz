#include <iostream>
int main2() {
    int i = 0, sum=0,n=0,mutated=0;
    std::cin >> n;
    for (; i < n; ++i){
        int num;
        std::cin >> num;
        sum += num;
    }
    for (int i = 0; i < n; ++i)
        if (sum < 140)
                mutated = 1;
    std::cout << mutated;
    return 0;
}
int main() {
    std::cout << 1;
    return 0;
}

