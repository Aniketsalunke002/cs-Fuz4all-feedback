#include <iostream>


namespace fuzz {
  template <typename T>
  void mutate(T& str, int i) {
    // str[i] = fuzz::get_mutated_byte();
  }
}

namespace mutator {
  void mutate(char* &str) {
    for (int i = 0; i < str->length(); ++i) {
      fuzz::mutate(str, i);
    }
  }
}

int main() {
  char* str = new char[15];
  strcpy(str, "I am an ordinary string");
  mutator::mutate(str);
  std::cout << *str << std::endl;
  delete[] str;
  return 0;
}
