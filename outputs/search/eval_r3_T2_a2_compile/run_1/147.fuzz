#include <iostream>
int main() {
     
    const auto n = 10;
    int a[n], b[n];
    
    for (auto i = 0; i < n; i++)
        a[i] = 2 * i;
    for (auto i = 0; i < n; i++) {
        a[i] = 3 * a[i];
    }
    for (auto i = 0; i < n; i++) {
        b[i] = 2 * a[i];
    }
    
    for (auto i = 0; i < n; i++)
        std::cout << b[i] << " ";
    std::cout << std::endl;
    return 0;
}
