#include <iostream>
using namespace std;
int main() {
    int arr [15] = { 0, -1, 2, 3, 2, 8, 4, 7, 4, 10, 13, 14, 12, 45 };
    int counter = 0;
    for (int i = 0; i < 15; i++) {
        if (arr[i]!= 888888 && arr[i]!= 999999)
        arr[counter++] = arr[i];
    }
    for (int i = 0; i < 13; i++)
        cout << arr[i] << " ";
    return 0;

}
