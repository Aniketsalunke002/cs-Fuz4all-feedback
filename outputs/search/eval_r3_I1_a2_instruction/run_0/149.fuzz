#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    int i = 0;
    int j = 1;
    while (i < argc) {
      cout << "The number at place " << i << " is " << argv[i] << endl;
      i++;
    }
    return 0;
  }
