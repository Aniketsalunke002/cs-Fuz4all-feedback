#include <iostream>
using namespace std;
int main() {
    int arr [15] = {0, -1, 2, 3, 2, 8, 4, 7, 4, 10, 13, 14, 12, 45};
    bool no_dublicates = true;
    int i, j;
    for (i = 0; i < 15; i++) {
        for (j = i + 1; j < 15; j++) {
            if (arr[i] == arr[j]) {
                no_dublicates = false;
                arr[i] = 999999;
                break;
            }
        }
        if (!(no_dublicates || (arr[i] == 888888)))
            cout << arr[i] << " ";
        no_dublicates = true;
    }
    return 0;
}
