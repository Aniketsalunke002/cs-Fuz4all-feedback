#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    string message;
    while (cin >> message){
    cout << "Mutated " << message << endl;
  }
    return 0;
  }
 
#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    int n;
    cin >> n;
  for (int cnt = 0; cnt < n; ++cnt)
    for (int j = 0; j < n; ++j){
      cout << " " ;
    }
  cout  << endl;
    return 0;
  }
