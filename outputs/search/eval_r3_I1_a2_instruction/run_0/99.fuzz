#include <iostream>
    using namespace std;
    int main() {
        string name [] = {"Fred","Georgie","Perry"};

        switch (0) {
            case 0:
                cout << name[0] <<"\n";
                cout << name[1] <<"\n";
                cout << name[2];
                break;
            case 1:
                cout << name[2] <<"\n";
                cout << name[0] <<"\n";
                cout << name[1];
                break;
            case 2:
                cout << name[1] +"\n";
                cout << name[0] +"\n";
                cout << name[2];
                break;
            default:
                cout << "The default!";
                break;

        }

        return 0;
    }

