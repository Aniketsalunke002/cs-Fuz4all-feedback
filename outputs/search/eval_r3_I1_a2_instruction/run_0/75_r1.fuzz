#include <iostream>
using namespace std;
int main() {
    string name;
    char *ptr = name.c_str();
    cin >> name;
    int len = name.length();
    for (int i = 0; i < len; i++) {
        if (isalpha(name[i])) {
            ptr[i] = (char)toupper((int)ptr[i]);
        }
        cout << name  << endl;
    }
    return 0;
}