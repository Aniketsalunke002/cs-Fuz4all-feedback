#include <iostream>
using namespace std;
int main() {
    int arr [10] = {0};
    int *index = arr;
    int n = 10;
    for (int i = 1; i < n; i *= 2 ) {
        index = &( arr[(i - 1)  << 1]);
        for (int j = 0; j < n; j += i) {
            for (int k = 0; k < 2; k++) {
                *index = i -1;
            }
        }
    }
    arr[0] = 1; arr[1] = 2;
    return 0;
}
