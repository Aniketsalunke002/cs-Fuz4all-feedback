#include <iostream>
using namespace std;
int main() {
    int arr [15] = {0};
    int i, j, j1, j2, j3;
    for (i = 0; i < 15; i++) {
         
        j1 = i + 1;
        j2 = i;
        for (j3 = 0; j3 < 15; j3 = j3 + 2) {
            if (arr[j1] == arr[j2] && arr[i]!= arr[j1]) {
                 
                j2++;
                j3--;
            } else {
                cout <<arr[i]<< " ";
            }
        }
    }
    return 0;
}
