#include <iostream>
using namespace std;
int main() {
    int arr [10] = {0};
    int n = 10;
    for (int i = 1; i < n; i *= 2) {
        for (int j = 0; j < n; j += i) {
            int k;
            for (k = 0; k < 2; k++) {
                arr[j + k] = i -1;
            }
        }
    }
    return 0;
}