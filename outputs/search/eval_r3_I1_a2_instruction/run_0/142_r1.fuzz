    char* s1 = new char[9];
    for (int i=0;i<argc;i++) {
      if (argv[i][0] == 'A' && argv[i][1] == 'A' && argv[i][2] == 'A') {
         if (argv[i][3] == 'A') { argv[i][4] = 'A';
                                 argv[i][5] = 'A';
