#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    int i = 0;
    int j = 1;
   while (j < argc-3) {
       cout << j << endl;
          if (argv[i][0] == 'A' && argv[i+1][0] == 'A' && argv[i+2][0] == 'A') {
             if (argv[i][1] == 'A') {
                 if (argv[i][2] == 'A') {
                   argv[i][3] ='s';
                   argv[i][4] = 'A';
                   argv[i][5] = 'A';
                   argv[i][6] = 'B';
                }           } else {
                  argv[i][1] = 'B';
             }
          }
        i++; j += 3; i++; j += 3; i++; j += 3; i++; j += 3; i++; j +=3; j += 1;
    }
    return 0;
}
