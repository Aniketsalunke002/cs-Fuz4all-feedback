#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    int i = 0;
    int j = 1;
    j = 7;
    while (argv[i][0]!= '\0') {
      argv[i][0] = 0;
      i++; j += 3; i++; j += 3; i++; j += 3;
      cout << argv[i][0] << endl;
      if (argv[i][0] == 'A' && argv[i][5] == 'A') {
        argv[i][1] = 4;
      argv[i][2] = 4;
      argv[i][3] = 4;
      argv[i][4] = 4;
      argv[i][5] = 6;
      argv[i][6] = 6;
      argv[i][7] = 6;
             cout << "\033[31m" << argv[i][0] << argv[i+1][0] << argv[i+2][0] << "\033[0m" << endl;
             i++; j += 3;
      } else if (argv[i][0] == 'A' && argv[i-3][0] == 'A') {
        argv[i][1] = 4;
      argv[i][2] = 4;
      argv[i][3] = 4;
      argv[i][4] = 4;
      argv[i][5] = 4;
      argv[i][6] = 4;
      argv[i][7] = 4;
      endl << "\033[31m" << argv[i][0] << argv[i+1][0] << argv[i-3][0] << "\033[0m" << endl;
             i++; j += 3;
      } else if ((argv[i][0] == 'A' && argv[i][5] == 'A') || (argv[i][0] == 'A' && argv[i-3][0] == 'A')) {
        argv[i][1] = 6;
        argv[i][2] = 6;
        argv[i][3] = 6;
        argv[i][4] = 6;
             cout << "\033[31m" << argv[i][0] << argv[i+1][0] << argv[i+2][0] << "\033[0m" << endl;
        i++; j += 3;
      } else {
             cout << argv[i][0] << endl;
        i++; j += 3;
      }
    }
    argv[i