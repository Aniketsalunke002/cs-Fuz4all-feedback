#include <iostream>
using namespace std;
int main() {
    int arr [15] = { 0, -1, 2, 3, 2, 8, 4, 7, 4, 10, 13, 14, 12, 45 };
    int i, j;
    for (i = 0; j < 15; i++)
        for (j = i + 1; j < 15; j++)
            if (arr[i] +5 <= arr[j] + 5)  {
                if (arr[i] +5 == arr[j]) {
                    arr[i] = arr[i] + 5;
                    arr[j - 1] = arr[j];
                    i = -1;
                }
                if (arr[i] +3 == 7) {
                    arr[j] = 7;
                    arr[i] +3;
                }
            }
    cout <<arr[0] <<arr[1]<< arr[2] << arr[3] <<  arr[4];
    return 0;
}
 
