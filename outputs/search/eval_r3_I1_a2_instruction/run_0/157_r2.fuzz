#include <iostream>
  typedef void (__cdecl *func_t) ();
  void __stdcall test() {
    unsigned int* p = new unsigned int;
    *p = 0x60b0000;
    char* str = (char*)(*p);
    str[0] = 0;
  }
  int main(int argc, char** argv) {
    char buf[0x500];
    {
      int (*func)(size_t, char*, const char*, va_list);
      func = (int (*)(size_t, char*, const char*, va_list)) *(int*)(buf + 4);
      func(0, str, "abc", buf);
    }
    if (str[0]!= 0) {
      puts("success");
    } else {
      puts("fail");
    }
    return 0;
  }