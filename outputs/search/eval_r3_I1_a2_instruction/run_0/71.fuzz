#include <iostream>
#include <list>
using namespace std;
int main() { 
    list <int> li;
    int cnt=0;
    int n, a;
    cin >> n;
    for (size_t i = 0; i < n; i++) { 
        cin >> a;
        if (a) { 
            li. push_back (a);
            cnt++;
        }
    }
}
 
