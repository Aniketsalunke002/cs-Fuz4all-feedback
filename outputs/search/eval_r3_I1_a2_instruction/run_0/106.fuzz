#include <iostream>
    using namespace std;
    int main() {
        int i;
        for (i=0; i>1; i--)
        {
            if (i % 2 == 0)
            {
                cout << "Even: " << i << "\n";
            }
            else
            {
                cout << "Odd: " << i << "\n";
            }
        }
        return 0;
    }