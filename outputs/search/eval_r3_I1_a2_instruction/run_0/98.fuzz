#include <iostream>
using namespace std;
int main() {
    int count = 0;
    int numbers[3] = {0,0,0};
    do {
        cout << "Enter "<< ++count <<" number\n";
            cin >> numbers[count % 3];
    } while (count < 3);
    cout << "numbers: ";
    int * index = numbers;
    for (int i = 0; i < 3; i++) {
          cout << *index++ << " ";
    }
    cout << "\n";
    return 0;
}
