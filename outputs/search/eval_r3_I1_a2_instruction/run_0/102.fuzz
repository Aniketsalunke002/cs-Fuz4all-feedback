#include <iostream>
    using namespace std;
    int main() {
        int arr1[4] = {1,2,3,4};
        int arr2[4] = {5,6,7,8};
        for (int i = 0; i < 2; ++i)
        {
            arr2[i]=arr2[i]+arr1[i];
            arr1[i]=arr2[i]-arr1[i];
            arr2[i]=arr2[i]-arr1[i];
        }
        for (int i = 0; i < 4; ++i)
        {
            cout <<arr2[i] <<"\n";
        }
        return 0;
        
    }