#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    for (int i = 0; i < argc; ++i) {
      if (i % 2 == 1) {
        cout << argv[i][0];
      }
    }
    return 0;
  }

 
#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    for(int i=0; i<argc; i++){
      cout << argv[i][0];
    }
    return 0;
  }

  