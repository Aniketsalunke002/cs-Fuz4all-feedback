#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    int i = 0;
    int j = 1;
    while (i < argc) {
      cout << argv[i][0] << " ";
      i++;
    }
    cout << endl;
    return 0;
  }

 
 
 
class Foo {
 private:
  int i_;

 public:
  Foo(int i): i_(i) { }

  int GetValue() {
     
    for (int j = 0; j < i_; ++j) {
      i_ *= 2;
    }
    return i_;
  }
};

#include <iostream>
using namespace std;

int main(int argc, char** argv) {
  Foo foo(5);
  std::cout << foo.GetValue() << std::endl;
   
   
}
