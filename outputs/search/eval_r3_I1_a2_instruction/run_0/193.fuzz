#include <iostream>
#include <utility>
#include <vector>
void f() { }
int main(int argc, char *argv[])
{
  std::cout << "a";
  try {
    int a = std::stoi(argv[1]);
    std::vector<int> vec(a);
    std::ostream_iterator<int, char> outit(std::cout, " ");
    std::copy(vec.cbegin(), vec.cend(), outit);
    std::cout << std::endl;
  }
  catch(std::exception &e)
  {
    std::cout << e.what() << std::endl;
  }
  return 0;
}
