#include <iostream>
  using namespace std;
  int main(int argc, char **argv) {
int i = 1;
  while (i < argc) {
    cout << i;
    if (i % 2 == 0)
      cout << argv[i] << " is even\n";
    else
      cout << argv[i] << " is odd\n";
    i++;
  }
  return 0;
}
 
#include <iostream>
using namespace std;
int  main(int argc, char* argv[]){
  int i = 1;
  char *p;
  while (i < argc) {
    printf("%d", i+1);
    p = argv[i];
    printf(":%s\n", (i%2 == 0)?"is even":"is odd");
  i++;
  }
  return 0;
}
