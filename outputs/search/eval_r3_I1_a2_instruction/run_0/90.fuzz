#include <iostream>
using namespace std;
int main() {
    int arr [10] = {0};
    int n = 10;
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            if (i == j) {
                arr[j] = i;
            }
            else {
                arr[j] = -1;
            }
        }
    }
    return 0;
}
