#include <iostream>
  using namespace std;
  int main(int argc, char** argv) {
    int i = 0;
    int j = 1;
   while (i < argc) {
       cout << j << endl;
          if (argv[i][0] == 'A') {
             if (argv[i][1] == 'A') {
                 if (argv[i][2] == 'A') {
                   argv[i][3] ='s';
                   if (argv[i][4] == 'A') {
                     argv[i][5] = 'A';
                     argv[i][6] = 'B';
                   }
                } else {
                   argv[i][2] == 'C';
                }

             } else {
                  argv[i][1] = 'B';
             }
          }
          i++;
      }

    return 0;
}
