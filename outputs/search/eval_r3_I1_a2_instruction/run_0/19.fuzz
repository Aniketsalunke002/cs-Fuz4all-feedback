#include <iostream>
using namespace std;
int main(int argc, char**argv) {
    int a = 100, b = 20, c = 210, d = 21;
    int z;
    char *p = (char*)&a;
    z = (*p + b) + c - d;
    cout << &a << endl;
    cout << *p << endl;
    cout << z << endl;
    return 0;
}
 
