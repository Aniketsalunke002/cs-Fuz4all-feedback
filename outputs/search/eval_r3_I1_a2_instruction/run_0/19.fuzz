#include <iostream>
using namespace std;
int main(int argc, char**argv) {
    int a = 1, b, c = 2;
    char *p = nullptr;
    if(a) {
        p = (char *)&b;
        b = 0;
    }
    cout << (p)? *p : -100 << endl;
    return 0;
}
 
#include<iostream>

int main(int argc, char**argv)
{
    int a = 5, b = 3;

    cout << (~a & ~b) << endl;
    return 0;

}
 
#include<iostream>

int main(int argc, char**argv)
{
    int a, b, res;
    a = ~(b * 10 + 5);
    cout << a << endl;
    cout << (a ^ res) << endl;
    return 0;

}
 
