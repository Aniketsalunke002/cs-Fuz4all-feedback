#include <iostream>
using namespace std;
int main(int argc, char**argv) {
    int d,t; cin>>d>>t;
    int arr1[8]={1,2,3,4,5,1,7,8};
    cout<<"A:"<<endl;
    for(int i=0; i<t; i++){
        for(int j=0; j<d; j++){
            if(arr1[j]%2==0){
                cout<<"even ";
            }
            else{
                cout<<"odd ";
            }
        }
        cout<<endl;
    }
    return 0;
}
