#include <iostream>
class MyClass3
{
private:
    int data[10]{};
public:
    MyClass3()
    {
        for(int i{0}; i<10; i++)
        {
            data[i]=-1;
        }
    }
    void say(){std::cout<<"Hi!\n";}
    void print()
    {
        for(int i{0}; i<10; i++)
        {
            std::cout<<data[i]<<std::endl;
        }
    }
    ~MyClass3(){for(int i{0}; i<10; i++)data[i]=data[0];print();}
};
int main()
{
    MyClass3 obj[10];
    for(int i{0}; i<10; i++)
    {
        obj[i].say();
        obj[i].print();
    }
    return 0;
}