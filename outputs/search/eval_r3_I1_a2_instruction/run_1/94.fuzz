#include <iostream>
int main()
{
    int arr[10]={};
    for(int i{0}; i<10; i++)
    {
        arr[i]=-1;
    }
    for(int i{0}; i<10; i++){
        std::cout<<arr[i]<<std::endl;
    }
    return 0;
}
 
#include <iostream>
int main()
{
    int* arr[10];
    int j=0;
    for(int i=0; i<10; i++)
    {
        arr[i] = new int;
        *arr[i]=j;
        j+=3;
    }
    j=0;
    for(int i=0; i<2; i++){
        std::cout<<*(arr[i])<<" "<<*(arr[i]+1)<<" ";
    }
    return 0;
}
 
#include <iostream>
int main() 
{
    int arr1[10]{};
    double arr2[10]{};
    for(int i{0}; i<10; i++)
    {
        arr1[i]=i;
        arr2[i]=i+i;
    }
    double sum = 0;
    for(int i{0}; i<10; i++)
    {
        sum +=arr2[i];
    }
    std::cout<<sum/6.0<<std::endl;
    std::cout<<1.0/6.0<<std::endl;
    std::cout<<(int)(1.0/6.0)<<std::endl;
    return 0;
}
 
#include <iostream>
double float_sum(int, int, int, int, int, int);
int main()
{
    int arr1[10]{};
    double arr2[10]{};
    for(int i{0}; i<10; i++)
    {
        arr1[i]=i;
        arr2[i]=i+2;
    }
    double sum = float_sum(*(arr2),*(arr2+1),*(arr2+2),*(arr2+3),*(arr2+4),*(arr2+5));
    std::cout<<(int)(sum/6.0)<<std::endl;
    std::cout<<(int)(1.0/6.0)<<std::endl;
    std::cout<<(int)(sum/6.0)<<std::endl;
    return 0;
}
double float_sum(int x, int y, int z, int x1, int y1, int z1)
{
    return ((double)x*((double)y+6.25)) + ((double)y1*((double)z)) + (double)z + (double)x1;
}
