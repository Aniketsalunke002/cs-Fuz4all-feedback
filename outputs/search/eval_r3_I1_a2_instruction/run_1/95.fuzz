#include <iostream>
class MyClass1
{
    private:
        int data[10]{};
    public:
    void method()
    {
        print("This won't work");
    }
    void print(std::string m)
    {
        for(int i{0}; i<10; i++)
        {
            std::cout<<m<<data[i]<<std::endl;
        }
    }
    void say()
    {
        std::cout<<"Hi!\n";
    }
    ~MyClass1()
    {
        get_data();
    }
};
int main()
{
    MyClass1* m1 = new MyClass1;
    m1->say();
    m1->print("Hi there.\n");
    return 0;
}
