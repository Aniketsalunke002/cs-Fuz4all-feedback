#include <iostream>
class MyClass2
{
    private:
        int data[10]{};
    public:
    MyClass2()
    {
        for(int i{0}; i<10; i++)
        {
            data[i]=-1;
        }
    }
    void say(){std::cout<<"Hi!\n";}
    void print()
    {
        for(int i{0}; i<10; i++)
        {
            std::cout<<data[i]<<std::endl;
        }
    }
};
void changeIt2(MyClass2 obj[12])
{
    std::cout<<"changed the number of objects\n";
    for(int i{0}; i<12; i++)
    {
        obj[i].say();
        obj[i].print();
    }
}
int main()
{
    MyClass2 obj[10];
    changeIt2(obj);
    return 0;
}
 
#include <iostream>
#include <vector>
#include <algorithm>
#include <functional>
#include <iterator>
int main()
{
    std::vector<int> vec{1,2,3,5};
    std::sort(vec.begin(),vec.end(),[](int x,int y){return (x>=y);} );

    for(auto i: vec)
    {
        std::cout<<i<<" ";
    }
    return 0;
}

