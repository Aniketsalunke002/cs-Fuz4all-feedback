#include <iostream>
using namespace std;
int main()
{
    int a = 5;
    cout << a++ <<'' << a-- << '\n';
    a += 1;
    cout << a << '\n';
}

 
#include <iostream>
using namespace std;
int main()
{
    int a, b, c, d, e;
    cout << "Enter 2 integers: ";
    cin >> a >> b;
    c = a + b;
    d = a - b;
    e = a * b;
    cout << c <<'' << d <<'' << e <<'' << c / e << '\n';
    return 0;
}

 
 
#include <iostream>
using namespace std;
int main()
{
    char Name[] = "<NAME>";
    int i, n;
    cout << "Length: " << strlen(Name) << '\n';  
    for (i = 0; Name[i]!= '\0'; i++)    
      n += Name[i] * Name[i];
    cout << "Square of length: " << n << '\n';
    n = 0;
    for (i = 0; Name[i]!= '\0'; i++)    
      n += i * i * Name[i];
    cout << "Sum of squares of the 10 digits: " << n << '\n';
    return 0;
}

 
 
#include <iostream>
using namespace std;
int main()
{
    char ch1;
    cout << "Enter a character: ";
    scanf("%c", &ch1);
    if ((ch1 < 97) && (ch1 > 64))
    {
        ch1 = ch1 + 32;
    }
    cout << "The new character is: " << ch1 << '\n';
    return 0;
}
 
#include <iostream>
using namespace std;
int main()
{
    char ch1;
    cout << "Enter a character: ";
    scanf("%c", &ch1);
    if ((ch1 > 64) && (ch1 < 91))
    {
        ch1 = ch1 - 32;
    }
    cout << "The new character is: " << ch1 << '\n';
    return 0;
}