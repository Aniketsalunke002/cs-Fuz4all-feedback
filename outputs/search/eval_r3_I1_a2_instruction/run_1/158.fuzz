#include <iostream>
using namespace std;
int main()
{
    int i=0;
    do
    {
        cout<<'S';
        i+=1;
    }
    while(i<5);
    cout<<'\n';
     do
    {
        cout<<'S';
        i+=1;
    }
    while(i<10);
    return 0;
}
 
