class A
{
    public:
    int add(int i, int j)
    {
        return i + j;
    }
    int subtract(int i, int j)
    {
        return i - j;
    }
};
#include <iostream>

class AdditionSub
{
    private:
    A a;
    public:
    int add(int i, int j)
    {
        return a.add(i,j);
    }
    int subtract(int i, int j)
    {
        return a.subtract(i,j);
    }
};
 
 
 
 

