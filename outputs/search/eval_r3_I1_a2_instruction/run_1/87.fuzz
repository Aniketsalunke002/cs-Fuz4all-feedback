class Civilian 
{
public:
  Civilian();
  Civilian(const Civilian&) = default;
  Civilian(Civilian&&);
  Civilian& operator=(const Civilian&) = default;
  Civilian& operator=(Civilian&&) = default;
  virtual ~Civilian() = default;
};
 
