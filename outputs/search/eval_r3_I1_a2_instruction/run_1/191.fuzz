#include <iostream>
#include <string>
class foo {
private:
   foo() {
   }

   struct bar;
   bar* get_ptr_to_bar_struct() {
    return static_cast<bar*>(this);
   }

public:
    bar* get_ptr_to_bar() {
        return get_ptr_to_bar_struct();
    
  }

   ~foo() {
   }
};
struct bar {
    ~bar() {
    }
};
    int main() {
        foo a;
        a.get_ptr_to_bar()->~bar();
    }
 
