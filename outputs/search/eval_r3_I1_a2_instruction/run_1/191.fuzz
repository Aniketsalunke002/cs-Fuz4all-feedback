#include <iostream>
#include <string>
class foo {
private:
   foo() {
   }

   struct bar {
   };
public:
    bar& get_bar() {
        return bar();
   }

   ~foo() {
   }
};

int main()
{
    foo().get_bar().~bar(); 
}
 
#include <iostream>
#include <string>
class foo {
private:
   int a_num;

public:
    int get_num() const {
        return a_num;
   }

   foo(int num) : a_num(num) {
   }

   ~foo() {
   }
};

int main()
{
    foo(5).get_num();  
}
 
#include <iostream>
#include <string>
class foo {
   int a_num;
public:
    foo(int num) : a_num(num) {
    }
    int get_num() const {
        return a_num;
   }

   class bar :  public foo {
   public:
    bar(int num) : foo(num) {
    }
    ~bar() {
    }
   };
};

int main()
{
    foo::bar b(5);
    b.get_num