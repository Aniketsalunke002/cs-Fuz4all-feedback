         int a = 42;
        MyClass2() : a(42) { a = 13; }
};



 
class Animal {
public:
    Animal(std::string name) : mName(name), mFoodCount(0) {}
    std::string mName;
    int mFoodCount;
};

int main(void) {
    Animal myAnimal{"Bob"};
