#include <iostream>
class A1 {
        public:
            virtual void print() {}
            void say() { std::cout << "hi" <<std::endl; }
};


class B1 : public A1 {
        private:
            int a;
        public:
            void print()  { std::cout << "hi" <<std::endl; }

};
int main(void) {
    A1 a;
    a.say();
 
    B1 b;
    b.say();
     
    return 0;
}
