struct PointInLine : public point, public virtual Line {
    PointInLine(const Point& pt, const Line& l) { }
    PointInLine(const x_point& x_pt, const y_point& y_pt) : point(x_pt, y_pt) { }
    PointInLine(const Point& pt) = default;
    PointInLine(const int& xcoord, const int& ycoord) : point(xcoord, ycoord) { }
};

 
