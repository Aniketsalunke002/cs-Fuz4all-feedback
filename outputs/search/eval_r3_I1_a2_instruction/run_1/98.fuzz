#include <iostream>
class MyClass
{
    private:
        int data[10]{};
    public:
        void get_data()
        {
            for(int i{0}; i<10; i++)
            {
                data[i]=-1;
            }
        }
        void print()
        {
            for(int i{0}; i<10; i++)
            {
                std::cout<<data[i]<<std::endl;
            }
        }
        void say()
        {
            std::cout<<"Hi!\n";
        }
    MyClass()
    {
        get_data();
    }
    ~MyClass()
    {
        print();
    }
};
int main()
{
    MyClass** m1 = new MyClass*[10];
    for(int i{0}; i<10; i++)
    {
        m1[i] = new MyClass;
        m1[i]->say();
        m1[i]->print();
    }
    return 0;
}
 
 