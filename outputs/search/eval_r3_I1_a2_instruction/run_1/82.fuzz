#include <iostream>
#include<functional>
class MyClass2 : public MyClass1
{
    public:
    MyClass2()
        {}
    std::function<void()> f = [] () {};
    void say() { std::cout<<"Goodbye!"<<"\n"; }
};
 
#include <iostream>
struct MyTemplate
{
    template<typename T>
    void print(T &element)
    {
        std::cout<<element<<"\n";
    }
};
int main()
{
    int number1 = 43;
    char letter1 = 'a';
    std::string String1 = "Hell";
    MyTemplate T;
    T.print(number1);
    T.print(letter1);
    T.print(String1);
    return 0;
}
