#include <iostream>
using namespace std;
int main()
{
    int x = 5;
    x++;
    if (x >= x)
    {
        x = -x;
    }
    cout << x << '\n';
    while (x-- > 10)
    {
        x = -x;
    }
    return 0;
}
 
#include <iostream>
int main()
{
    int x = 5;
    ++x;
    if (x >= long(x))
    {
        x = -x;
    }
    cout << x << '\n';
    while (x > 10)
    {
        x = -x;
    }
    return 0;
}
 
#include <iostream>
using namespace std;
int main()
{
    int x = 5;
    int y = 0;
    x = int(x / 10 + 0.5);
    y = int(y / 10 + 0.5) + 1;
    if (y < x)
    {
        y = (y + 10) >= x? x * x : y * y;
    }
    x++;
    y--;
    cout << x << " " << y << '\n';
    while (x > 10)
    {
        x = -x;
    }
    return 0;
}
 
#include <iostream>
using namespace std;
int main()
{
    int a = 5, b = 0;
    a /= 10 + 0.5;
    b /= 10 + 0.5;
    if (a >= b)
    {
        b = a * a;
    }
    ++a;
    --b;
    cout << a << " " << b << '\n';
    while (a <= 10)
    {
        a = -a;
    }
    return 0;
}
