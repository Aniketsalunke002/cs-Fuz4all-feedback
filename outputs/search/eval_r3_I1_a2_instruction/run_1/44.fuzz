#include <iostream>
#include <string>
#include <string_view>
#include <vector>
#include <algorithm>
int main (int argc, char **argv)
{
	int x = 4;
	std::vector<std::string> vect{ "first", "second", "third" };
	std::sort(vect.begin (), vect.end (), [](bool cond, const std::string &a, const std::string &b){  
		cond = false;
		if (a.size() < b.size()) cond = true;
		return cond;
	});
	for (auto &w : vect) std::cout << w << " ";
	std::cin >> x;
	std::cout << x;
	return 0;
}