#include <iostream>
int a=4;
int function(){};
int main ()
{
	std::cin >> a;
	for (int i= 1; i< a; ++i)
		{
			for(int j=1; j<=a;j++)
			{
				if (i==j)
					std::cout << a << " " << j <<" " << i;
				else
				std::cout << i <<" "<< j <<" " << a;
			};
		};
		std::cout <<i << "," << j;
}
