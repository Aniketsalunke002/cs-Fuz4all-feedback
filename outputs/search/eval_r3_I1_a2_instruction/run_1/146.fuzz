#include <iostream>
using namespace std;
int main()
{
    int a = 6, i = 12;
    if (a * i >= 0)
    {
        a = -a;
    }
    else
    {
        i = -i;
    }
    a += i;
    cout << a << '\n';
    return 0;
}
 
#include <iostream>
#include <string>
using namespace std;
int main()
{
    string str;
    for (int i = 0; i < 20; i++)
    {
        str +='m';
    }
    cout << str << '\n';
    return 0;
}
 
#include <iostream>
#include <string>
using namespace std;
int main()
{
    string str;
    for (int i = 0; i < 20; i++)
    {
        str +='m';
    }
    cout << str << '\n';
    while (str!= "mmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmm")
    {
        str = str.substr(1, str.size() - 1);
         
    }
    cout << str << '\n';
    return 0;
}