#include <iostream>
using namespace std;
int main()
{
    int x = 5;
    x++;
    if (x >= x)
    {
        x = -x;
    }
    cout << x << '\n';
    while (x-- > 10)
    {
        x = -x;
    }
    return 0;
}
 
