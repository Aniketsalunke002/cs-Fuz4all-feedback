#include <iostream>
class MyClass2
{
    private:
        int data[10]{};
    public:
    MyClass2()
    {
        for(int i{0}; i<10; i++)
        {
            data[i]=-1;
        }
    }
    void say(){std::cout<<"Hi!\n";}
    void print()
    {
        for(int i{0}; i<10; i++)
        {
            std::cout<<data[i]<<std::endl;
        }
    }
    ~MyClass2(){print();}
};
int main()
{
    MyClass2 obj[10];
    for(int i{0}; i<10; i++)
    {
        obj[i].say();
        obj[i].print();
    }
    return 0;
}
