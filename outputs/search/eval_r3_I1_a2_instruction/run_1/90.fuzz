#include <iostream>
class MyClass1
{
    private:
        int data[10]{};
    public:
    void get_data()
    {
        for(int i{0}; i<10; i++)
        {
            data[i]=-1;
        }
    }
    void print()
    {
        for(int i{0}; i<10; i++)
        {
            std::cout<<data[i]<<std::endl;
        }
    }
    void say()
    {
        std::cout<<"Hi!\n";
    }
    ~MyClass1()
    {
        get_data();
    }
};
int main()
{
    MyClass1* m1 = new MyClass1;
    m1->say();
    m1->print();
    return 0;
}