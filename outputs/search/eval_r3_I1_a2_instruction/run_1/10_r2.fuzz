#include <iostream>
#include <queue>   

int main () {
	const int NUM_QUEUES = 10;   
	for (int i = 0; i < NUM_QUEUES; i++) {
		std::queue<int> *q = new std::queue<int>;  
		delete q;	 
	}
	return 0;
}
 
