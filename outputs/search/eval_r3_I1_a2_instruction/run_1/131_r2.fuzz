#include <iostream>
int main()
{
    int num1{ 7 };
    int& num2 = num1;
    ++num2;
    std::cout << "num1 = " << num1 << '\n';
    std::cout << "num2 = " << num2 << '\n';
    num1 = static_cast<decltype(num1)>(num2);
    ++num1;
    num2 = static_cast<decltype(num2)>(num1);
    std::cout << "num1 = " << num1 << '\n';
    std::cout << "num2 = " << num2 << '\n';
    return 0;
}

