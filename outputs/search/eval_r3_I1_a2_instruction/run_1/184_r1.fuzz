#include <iostream">

/**
 * This is the start of a new C++11 feature
 */
struct MyClass
{
    int a;
    MyClass()
    {
        std::cout << "MyClass constructor called" << std::endl;
    }
}

int main()
{
    MyClass obj;
    return 0;
}

