#include <iostream>
using namespace std;
int main()
{
    int j = 1000;
    while (j!= 0)
    {
        cout << 'L';
        j--;
    }
    cout << '\n';
    while (j!= 0)
    {
        cout << 'O';
        j--;
    }
    return 0;
}
 
#include <iostream>
using namespace std;
int main()
{
    for (int i = 10; i <= 1; i-=5)
    {
        cout << 'O';
    }
    cout << '\n';
    int i = 10;
    while (i >= 1)
    {
        cout << 'L';
        i-=5;
    }
    cout << "And once in while\n";
    int j = 0;
    while (j <= 5)
    {
        cout << 'O';
        j++;
    }
    cout << '\n';
}
 
 
#include <iostream>
using namespace std;
int main()
{
    while (true)
    {
        if (true)
        {
            break;
        }
        while (true)
        {
            break;
        }
    }
    cout << "I've found you!\n";
}