#include <iostream>
using namespace std;
int main()
{
    int arr[50];
    int i = 0, n1, n2;
    arr[0] = 0;
    cout << arr[i] << endl;
    for (int i = 1; i < 50; ++i)
    {
        n1 = arr[i-1];
        n2 = arr[i-2];
        arr[i] = n1 + n2;
        cout << arr[i] << endl;
    }
    return 0;
}