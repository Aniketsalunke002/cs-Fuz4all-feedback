#include <iostream>
using namespace std;

int main()
{ 
    int a = 10;
    cout << a << " "; 
    a *= a - 1;
    
    cout << a << endl;
}
 
#include <iostream>
#include <string>
#include <sstream>
using namespace std;

int main(){
    string s;
    stringstream ss;
    int x;

    cout << "Enter a sentence: " << flush;
    getline (cin, s);

    ss.str(s);
    ss >> x;

    for(int i=0; i<s.length(); ++i){
        s = s + s[i];
    }

    if(x == stoi(s)){
        cout << "Entered number is a palindrome" << endl;
    } else {
        cout << "Entered number isn't a palindrome" << endl;
    }
}
