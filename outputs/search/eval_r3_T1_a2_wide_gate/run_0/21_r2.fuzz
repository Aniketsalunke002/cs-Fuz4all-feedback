#include <iostream>

#include <thread>
using namespace std;
int main() { 
  int foo=1;

    std::thread th1(foo++, foo++);   
    cout<<foo<<endl;
    std::thread th2([](int foo1,int foo3,int& foo4)-> void{ 
        
        cout<<foo4++<<endl;
        foo1=0;
        foo3=1;
    });   
    cout<<std::this_thread::get_id()<<endl;
    std::thread th3(foo++, foo++);
    cout<<foo++<<endl;
}

// The above code compiles and prints the following output:
// 2
// 4
// 0
// 3
// 1