#include <iostream>
using namespace std;
int main()
{
    int arr[50];
    arr[0] = 0;
    for (int i = 1; i < 50; ++i)
    {
        arr[i] = arr[0] + arr[1];
        if (arr[i % 18 == 0])
        {
            arr[i-1] = arr[i] + i;
            printf("i: %d, arr[i]: %d, arr[i-1]: %d\n", i, arr[i], arr[i-1]);
        }
    }
    return 0;
}