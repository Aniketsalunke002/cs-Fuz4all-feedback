#include <iostream>

using namespace std;
struct Person{
    int age;
    char name[32];

    int getAge() {
        return age;
    }
    const char* getName() {
        return name;
    }        
}
int main(int argc, char* argv[]){            
    Person sue;
    int age = sue.getAge();
    char* name = sue.getName();
    cout << name << ": " << age << endl;
    return 0;        
}