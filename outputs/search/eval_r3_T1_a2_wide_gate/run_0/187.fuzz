#include <iostream>
using namespace std;
int main(){
  char* mycar="volvo xC200";
  int value=5;
  mycar= "volvo xc";
  value=10;
  cout<<"my car is "<<mycar<<" and my value is "<<value<<endl;
  cout<<*((char*)&mycar+20)<<"x"<<endl;
}
void* malloc(unsigned long int size){
	extern "C" void* __builtin_malloc(unsigned long int);
	return __builtin_malloc(size);
}
void free(void *ptr){
	extern "C" void __builtin_free(void*);
	__builtin_free(ptr);
	
}
template<class T>
class myclass{
public:
	T a;
	T b;
	T c;
	T d;
	myclass(T a,T b,T c,T d){
		this->a=a;
		this->b=b;
		this->c=c;
		this->d=d;
	
	}
	T read(){
		return a;
	}

};template<class T>
T mysum(T a,T b,T c,T d){
	myclass<T> ob(a,b,c,d);
	return ob.read();
}int main(){
	int a = 1,b=2,c=3,d=4;
	int sum=0;
	sum=mysum(a,b,c,d);
	cout<<sum<<endl;
}
void a(){
	for(int i=0;i<5;i++){
		 
		cout<<i;
		cout<<endl;
	}

}
void b(){
for(int i=0;i<5;i++){
	a();
	cout<<"-";
}

}
int main(){
	a();
	return 0;
	 
	int a=8,b=4,c=5,d=6;
	cout<<mysum(a,b,c,d)<<endl;
	myclass<int> ob(a,b,c,d);
	cout<<ob.a<<endl;
	cout<<sum1<int>(a,b,c,d,4,4,4,4)<<endl;
	 
	return 0;
	 
	int a=8,b=4,c=5,d=6;
	cout<<mysum<int>(a,b,c,d)<<endl;
	myclass<int> ob(a,b,c,d);
	cout<<ob.read()<<endl;
}
template<class V>
V sum1(V a,V b,V c,V d,V k,V l,V m,V n){
	return a+b+c+d+k+l+m+n;
}
