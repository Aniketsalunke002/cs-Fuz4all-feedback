#include <iostream>
using namespace std;
int main()
{
    int arr[50];
    arr[0] = 0;
    arr[1] = 1;
    arr[2] = 1;
    for (int i = 3; i < 50; ++i)
    {
        arr[i] = arr[i - 1] + arr[i - 2];
    }
    for (int i = 1; i < 50; ++i){
        cout << "value at index ";
        
        cout << i << arr[i] << endl;
    }
    return 0;
}
