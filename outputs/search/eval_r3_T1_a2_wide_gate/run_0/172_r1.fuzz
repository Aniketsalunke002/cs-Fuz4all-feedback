#include <iostream>

using namespace std;
int main(){
    cout << sizeof(char) << '\n';
    cout << sizeof(int) << '\n';
    cout << sizeof(short) << '\n';
    cout << sizeof(long) << '\n';
    cout << sizeof(long long) << '\n';
    return 0;
}
