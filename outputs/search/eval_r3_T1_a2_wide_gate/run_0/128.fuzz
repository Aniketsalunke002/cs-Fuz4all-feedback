#include <iostream>
using namespace std;
int f(int n)    
{
    for (;;)    
    {
        cout<<"Hello World"<<endl;
        if (n == 0)    
            return 0;    
        n--;        
    }
}    
int main(int argc, char* argv[])    
{
    cout<<argv[0]<<"Hello ";    
    f(atoi(argv[1]));
    return 0;    
}
 
#include <iostream>
using namespace std;
int b = 1;
int main(int argc, char* argv[])    
{
    cout<<argv[0];    
    cin>>b;     
    return 0;    
}
