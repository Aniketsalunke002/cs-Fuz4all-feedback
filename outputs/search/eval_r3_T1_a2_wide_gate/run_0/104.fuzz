#include <iostream>
using namespace std;
int main()
{
    int arr[50];
    for (int i = 0; i < 50; i++)
    {
        arr[i] = 1;
        for (int j = 0; j < 50; j++)
        {
            arr[i] = arr[i] * (i+1);
        }
    }
    for (int z in arr)
    {
        cout << z << endl;
    }
    return 0;
}
 
#include <iostream>
#include <ctime>
using namespace std;
int main()
{
    srand(time(0));
    int arr[50];
    int sum = 0;
    for (int i = 0; i < 50; i++)
    {
        arr[i] = rand()%256;
        if (sum!= 0)
        {
            sum = sum + arr[i];
        }
        cout << arr[i] << endl;
    }
    cout << sum << endl;
    return 0;
}
 
#include <iostream>
#include <ctime>
#include <cstdlib>
using namespace std;
int main()
{
    srand(time(0));
    int arr[250];
    int sum = 0;
    for (int i = 0; i < 250; i++)
    {
        arr[i] = rand()%3000;
        arr[i] = arr[i] - 1250;
        cout << arr[i] << endl;
        if (sum!= 0)
        {
            sum += arr[i];
        }
    }
    cout << sum << endl;
    return 0;
}
