}
 
#include <iostream>
int my_char(char c){
    if(c == '_' || 'a' <= c && c <= 'z' || 'A' <= c && c <= 'Z'){
        cout << c << ": it is a alphanumeric character" << endl;
    }else if(c >= '0' && c <= '9'){
        cout << c << ": it is a digit character" << endl;
    }else if(c ==''){
        cout << c << ": it is a whitespece character" << endl;
    }else{
        cout << c << ": it is a special character" << endl;
    }
    return 0;
}
int main(){
    char c;
    cout << "Enter a character: ";
    cin >> c;
    my_char(c);
    return 0;
}
 
