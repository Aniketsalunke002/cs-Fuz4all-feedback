#include <iostream>
using namespace std;
struct bar
{
   int w = 10;			 
};
bar b = { 5 };
int main() {
   int foo=1;
   cout<<foo<<endl;
   b.w = b.w + 5;
   cout<<foo<<endl;
   bar c=b;		 
   cout<<c.w<<endl;
   bar& x = b;
   cout<<x.w<<endl;
   int bar::* mem = &bar::w;
   cout<<b.*mem<<endl;
	bar* y=&b;
}
 
#include <iostream>
using namespace std;
using s = int;
void f (s& x) {
	cout<<x<<endl;
	x=20;
}
int main() {
	int x=10;
	cout<<x++;
	f(x);
}