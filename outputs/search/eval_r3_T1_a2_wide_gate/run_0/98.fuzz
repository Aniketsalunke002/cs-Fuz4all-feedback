#include <iostream>
using namespace std;
int main()
{
    int arr[50];
    arr[0] = 0;
    for (int i = 1; i < 50; ++i)
    {
        arr[i] = arr[0];
        cout << arr[i] << endl;
    }
    return 0;
}
 
