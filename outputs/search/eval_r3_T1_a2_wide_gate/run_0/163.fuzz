#include <iostream>
using namespace std;
int main(){
    int arr[] = {1,2,3,5,6,7,8,10,20,30};
   for(int i = 0; i < sizeof(arr)/sizeof(*arr); i++){
        if(i == sizeof(arr)/sizeof(*arr)-1){
            cout << arr[i] << endl;
        }
        else{
            cout << arr[i] << " ";
        }
    }
}
 
#include <iostream>
using namespace std;
int main(){
    double *p;
    double a[] = {1,2,3,5.5,6,7,8,10,20,30};
     
    for(auto i = 0; i < sizeof(a)/sizeof(*a); i++){
        p = new double;
        *p = a[i];
        cout << *p << endl;
         
        delete[] p;
    }
}








