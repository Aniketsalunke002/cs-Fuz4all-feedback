#include <iostream>

using namespace std;
int main(){
    char* mycar="volvo xC200";
    int value=5;
    mycar= "volvo xc";
    value=10;
    cout<<"my car is "<<mycar<<" and my value is "<<value<<endl;
}

#include <iostream>
using namespace std;
int main(){
    char mycar;
    cin>>mycar;
    cout<<"my car is "<<mycar<<endl;
}

#include <iostream>
using namespace std;
int main(){
    string mycar;
    cout<<"Enter your name"<<endl;
    cin>>mycar;
    if(mycar==reverse(mycar)){
        cout<<mycar<<" is palindrome"<<endl;
    }else{
     cout<<mycar<<" is not palindrome"<<endl;   
    } 
}

