#include <iostream>
#include <string>
#include <vector>
int main( int argc, char **argv ){
std::vector < std::string > vect;
vect.push_back( "one");
vect.push_back( "two");
vect.push_back( "three");
std::cout << "\n\t  This is the fourth program.\n\n";
std::cout << "Print the values ";
for ( auto i: vect) std::cout << i << ":" <<std::endl;
std::cin.get();
}