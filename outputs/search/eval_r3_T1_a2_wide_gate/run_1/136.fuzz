#include <iostream>
#include <vector>
#include <algorithm>
#define M_PI 3.14159265358979323846264338328
int main( int argc, char **argv ){
  std::vector<int> v(100);
  for (int i = 0; i < 100; ++i) v[i] = 7;
  std::stable_sort(v.begin(), v.end());
  for (auto it=v.begin(); it!=v.end(); ++it) std::cout << *it << " ";
  std::cout << "\n";
}
