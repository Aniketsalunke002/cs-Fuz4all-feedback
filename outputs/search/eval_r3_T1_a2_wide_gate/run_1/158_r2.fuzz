#include <iostream>
using namespace std;
int main( int argc, char **argv ){
 int a[8];
 int b[8];
 for( int i = 0 ; i < 8 ; ++i )
  b[i] = 2 % a[i] / 11 << ( a[i] - b[i] );
 cout << *(b+0) << endl << *(b+1) << endl;
}