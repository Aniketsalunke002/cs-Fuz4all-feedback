#include <iostream>

using namespace std;
int main( int argc, char **argv ){
 double a[8];
 double b[8];
 for( int i = 0 ; i < 8 ; ++i )
  b[i] = 2.5 % a[i] / 1.1e2 << ( a[i] - b[i] );
 cout << *(b+0) << endl << *(b+1) << endl;
}
