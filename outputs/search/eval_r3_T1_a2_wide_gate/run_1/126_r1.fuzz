#include <iostream>

#include <vector>
#include <algorithm>

int main( int argc, char **argv ){
  std::vector<int> v1 ( 5, 3);
  std::vector<int> v2 ( 10, 2);
  std::stable_sort( v1.begin(), v1.end() );
  std::stable_sort( v2.begin(), v2.end() );
  std::cout << "\t    This program makes a lot of copies.\n\n";
}