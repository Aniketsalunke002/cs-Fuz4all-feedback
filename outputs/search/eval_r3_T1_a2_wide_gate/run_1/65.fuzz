#include <iostream>
class Complex {
public:
  Complex() {}
  Complex(int i) : value(i) {}
  Complex(int i, int j) { }
  int value;
};
int main() {
  Complex c(1, 2);
  std::cout << 2 << std::endl;
}
 
#include <iostream>
int counter = 0;
void f(int i) {
  if (++counter < i) f(counter);
  else std::cout << "Goodbye" << std::endl;
}
int main() {
  f(11);
}
