#include <iostream>

#include <list>
int main ()
{
  std::clog << 1;
  std::list<int> numbers { 1, 3, 5, 7 };
  for (auto iter = numbers.begin(); iter!= numbers.end(); ++iter)  
    for(int i = *iter; i> 0; --i) {
      if (i % 2 == 0) {
        change(*iter);
      } else {
        *iter += 2;
      }
    }
  for (auto iter = numbers.begin(); iter!= numbers.end(); ++iter)
    std::clog <<  *iter;;
  std::clog << std::endl;
}
void change(int& p)
{
  p += 3;
}
void doubl(int& p)
{
  p *= 2;
}

// ## C++20
// 
// - C++20 removed the `auto` keyword.
// - `auto` is used only for type deduction.
// - `auto` is used only to deduct types from variables.
// - `auto` is used only to deduce types from iterators.
// 
// ## C++20 for loops
// 
// - C++20 introduces two new ways to write for loops.
// - The old way of writing for loops is still valid.
// - The old for loop can be used only for containers which have `begin` and `end` methods.
// 
