#include <iostream>
using namespace std;
void doTest() {
	std::cout << "Hello world!" << std::endl;
}
int main() {
        doTest();
	return 0;
}
 
#include <iostream>
using namespace std;
int doTest() {
	std::cout << "Hello world!" << std::endl;
	return 0;
}
int main() {
        doTest();
	return 0;
}

