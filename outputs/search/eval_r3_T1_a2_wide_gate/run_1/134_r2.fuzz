#include <iostream>

#include <vector>
#include <algorithm>

int function(int val){
  return val;
}
int main( int argc, char **argv ){
  std::vector<int> v1;
  for (int i = 0; i< 5; ++i) v1.push_back(3);
  std::for_each(v1.begin(), v1.end(), function);
  std::vector<int> v2;
  for(int i = 0; i < 10; ++i) v2.push_back(2);
  std::vector<int>::iterator it = std::remove(v2.begin(), v2.end(), function);
  if(it!= v2.end()){
    v2.erase(std::remove(it, v2.end(), function), v2.end());
  }
  std::cout << "\t    This program has many redundant copy/destroy operations\n\n";
}