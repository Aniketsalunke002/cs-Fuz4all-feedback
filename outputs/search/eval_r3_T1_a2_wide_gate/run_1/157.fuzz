#include <iostream>
using namespace std;
int main( int argc, char **argv ){
  int a[10] = {0};
  int b[10] = {0};
  for( int i = 0; i < 10; a[i] += 1, i++ ) b[i] = 1;
  int c = 0;
  for( int i = 0, z = 0; i < 10; i++ ){
    c += a[i] >= 0? a[i] : b[z++];
    cout << c << ", ";
  }
  for( int i = 0; i < 10; b[i] /= 2, i++ );
  cout << c;
}
