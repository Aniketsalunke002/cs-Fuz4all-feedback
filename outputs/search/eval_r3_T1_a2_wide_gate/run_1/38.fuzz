#include <iostream>
using namespace std;
void doTest() {
	int x = 10;
	int y = 10;
	int &z = x;
	if (y == ++x) {
		z++;
	} else std::cout << "Hello world!" << std::endl;
}
int main() {
	doTest();
	return 0;
}
 
