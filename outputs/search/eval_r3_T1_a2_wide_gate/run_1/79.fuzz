#include <iostream>
int main (int argc, char **argv)
{
  int j = 0;
  if (argc > 1){ 
       j = atoi (argv[1]);
  }
  for (int i = 1; i < j; i++){
    std::cout << i << std::endl;
    if (i < j/2 ){
      i++;
    }
  }
}
 
#include <iostream>

int getInput(int *x, int length)
{
   
  int numbers[length];
  int counter = 0;
  while (counter!= length){
    numbers[counter] = std::cin.get ();
    counter++;
  }
  bool done = false;
  for (int i = 0; i < length; i++){
    if (numbers[i] == '\n'){
      done = true;
    }
  }
  return done;
}

void quickSort(int *arr, int low, int high){
  int pivot;
  if(low < high){
    pivot = partition(arr, low, high);
    quickSort(arr, low, pivot-1);
    quickSort(arr, pivot+1, high);
  }
}

int partition(int *arr, int low, int high){
  int i=low-1;
  pivot = arr[high];
  for (int j = low; j < high; j++){
    if (arr[j] <= pivot){
      i++;
      if (i > j)
        break;
        int temp = arr[j];
        arr[j] = arr[i];
        arr[i] = temp;
    }
  }
  i++;
  int temp2;
  temp = arr[i];
  arr[i] = pivot;
  pivot = temp;
  return i;
}

int main (int argc, char **argv)
{
  int arrayLength = 0;
  std::string userInput;
  std::cin >> userInput;
  arrayLength = atoi(userInput.c_str());
  int numbers[arrayLength];
  if (getInput(numbers,arrayLength)){
    quickSort(numbers,0,arrayLength-1);
  }
  else{
        std::cout << "Wrong syntax" << std::endl;
  }
}