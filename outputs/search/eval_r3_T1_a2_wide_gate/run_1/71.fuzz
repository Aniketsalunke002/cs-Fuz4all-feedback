#include <iostream>
#include <list>
void change(int& p);
void doubl(int& p);
int main (int argc, char **argv)
{
  int a = 42;
  for (auto iter = numbers.begin(); iter!= numbers.end(); ++iter)  
    for(int i = *iter; i> 0; --i) {
      doubl(a);
    }
  for (auto iter = numbers.begin(); iter!= numbers.end(); ++iter)
    std::clog <<  a;
  std::clog << std::endl;
}
```

## C++17

- C++17 changed the way for-loop has to operate.

```cpp
 
#include <iostream>
#include <list>
int main ()
{
  std::clog << 1;
  std::list<int> numbers { 1, 3, 5, 7 };
  for (auto iter = numbers.begin(); iter!= numbers.end(); ++iter)  
    for(int i = *iter; i> 0; --i) {
      if (i % 2 == 0) {
        change(*iter);
      } else {
        *iter += 2;
      }
    }
  for (auto iter = numbers.begin(); iter!= numbers.end(); ++iter)
    std::clog <<  *iter;;
  std::clog << std::endl;
}
void change(int& p)
{
  p += 3;
}
void doubl(int& p)
{
  p *= 2;
}
```
