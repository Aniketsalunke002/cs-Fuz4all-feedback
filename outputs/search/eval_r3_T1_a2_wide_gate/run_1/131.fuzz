#include <iostream>
#include <vector>
#include <algorithm>
int main( int argc, char **argv ){
  std::vector<int> v1;
  for (int i = 0; i< 5; ++i) v1.push_back(3);
  std::vector<int> v2;
  for(int i = 0; i < 10; ++i) v2.push_back(2);
  std::sort(v1.begin(), v1.end());
  std::stable_sort(v2.begin(), v2.end());
  std::cout << "\t    This program has many redundant copy/destroy operations\n\n";
}
 
