#include <iostream>

class SomeClass {
	int * array;
};

int main() {
	SomeClass obj;
	obj.array = new int[ 5 ];
	delete[] obj.array;
}

#include <iostream>
 
class ExoticType {};
 
class SomeClass {
	ExoticType* obj;
public:
	void set_object(ExoticType* obj_) {
		obj = obj_;
	}
};
 
int main() {
	 
	 
	ExoticType exoticType;
	SomeClass obj;
	obj.set_object(&exoticType);
}