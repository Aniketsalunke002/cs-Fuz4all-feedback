#include <iostream>
#include <vector>
#include <algorithm>
int main( int argc, char **argv ){
  std::vector<int> v;
  for (int i = 0; i < 100; ++i) v.push_back(3);
  std::partial_sort(v.begin(), v.begin() + (v.size()/2), v.end());
  if (v.size() > 0)
    std::swap(v.at(0), v.at(v.size() / 2));
  std::cout << "\t\t\t  This program has many redundant copy/destroy operations\n\n";
}







 