#include <iostream>
using namespace std;
int main(int argc, char** argv)
{
    cout << argc << " ";
    struct Data
    {
        ~Data()
        {
            cout << "~Data\n";
        }
        void doSomething()
        {
            cout << "Data::doSomething\n";
        }
    };
    struct Data2
        : Data
    {
        ~Data2()
        {
            cout << "~Data2\n";
        }
        void doSomething()
        {
            cout << "Data2::doSomething\n";
        }
    };
    Data2 dt;
    dt.doSomething();
    Data2 cdt(dt);
    dt.doSomething();
    cdt.doSomething();
    cdt = dt;
    cdt.doSomething();
    cout << "end of main\n";
    return 0;
}
