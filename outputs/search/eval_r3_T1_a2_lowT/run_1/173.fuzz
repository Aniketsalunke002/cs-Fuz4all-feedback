#include <iostream>
using namespace std;
int main() {
	double * * d = new double * [25];
	for (int i = 0; i<25;i++) {
		d[i] = new double[20];
		for (int j = 0; j<20;j++) {
			d[i][j] = 3.14;
		}
	}
	cout << d[18][9] << endl;
	for (int i = 0; i<25;i++) {
		for (int j = 0; j<20;j++) {
			d[i][j] = 100;
		}
	}
	cout << d[18][8] << endl;
	for (int i = 0; i<25;i++) {
		for (int j = 0; j<20;j++) {
			d[i][j] = d[i][j] * 100;
		}
	}
	cout << d[18][8] << endl;
	for (int i = 0; i<25;i++) {
		for (int j = 0; j<20;j++) {
			d[i][j] = d[i][j] + d[i][j];
		}
	}
	for (int i = 0; i<25;i++) {
		delete []d[i];
	}
	delete []d;
}
