#include <iostream>
using namespace std;
int main(int argc, char **argv)
{
    char s;
    while(s!= 'e')
    {
        cin >> s;
        if(s == 'd')
        {
            cout << "done";
            break;
        }
    }
    return 0;
}
 
#include <algorithm>
#include <iostream>
using namespace std;
bool cmp(int a, int b)
{
    return a > b;
}
int main(int argc, char **argv)
{
    int array[20];
    for  (int i = 0; i < 20; i++)
    {
        array[i] = i;
    }
    sort(array, array + 20, cmp);
    for (int i = 0; i < 20; i++)
    {
        cout << array[i] << endl;
    }
    return 0;
}
