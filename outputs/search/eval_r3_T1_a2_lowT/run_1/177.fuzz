#include <iostream>
using namespace std;
int x[10] = {1, 2, 3, 4, 5, 6, 7, 8, 9, 0};
class Point {
	double xValue, yValue;
	public:
	Point (double xV, double yV) {
		xValue = xV;
		yValue = yV;
		cout << "in the ctor" << endl;
	}
};
int main() {
	Point p (9, 8);
	x[7] = 42;
	return 0;
}
 
#include <iostream>
using namespace std;
class Point {
	double xValue, yValue;
	public:
	Point (double xV, double yV) {
		xValue = xV;
		yValue = yV;
	}
};
int x[10] = {1, 2, 3, 4, 5, 6, 7, 8, 9, 0};
int main() {
	Point p (9, 8);
	p.xValue = 42;
	return 0;
}
