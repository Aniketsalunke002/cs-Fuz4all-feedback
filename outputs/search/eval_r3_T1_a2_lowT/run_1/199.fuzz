#include <iostream>
using namespace std;
int main () {
	int summation[10];
	for (int a = 0; a < 10; a++) {
		summation[a] = a * 2;
	}
	for (int e = 0; e < 10; e++) {
		summation[e] = summation[e] *8;
	}
	for (int p = 3; p < 70; p++) {
		summation[p] = summation[p] / 4;
	}
	for (int x = 0; x < 10; x++) {
			cout << summation[x] << endl;
	}
}
