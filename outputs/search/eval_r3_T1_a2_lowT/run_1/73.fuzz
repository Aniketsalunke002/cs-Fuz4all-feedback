#include <iostream>
using namespace std;
void mutate(int* arr)
{
    arr[0]++;
    arr[1]++;
}
int main(int argc, char** argv)
{
    using namespace std;
    int a;


    __asm__ __volatile__(
"mov %0, %%rax\n\t"
"movq $0x100, %%rcx\n\t"
"mov $0x1, 8(%%rax)\n\t"
"movq %%rax, %%rdi\n\t"
".align 16\n\t"
"1:\n\t"
"movq 8(%%rax), %%rdx\n\t"
"incq %%rdx\n\t"
"mov $1, %%rax\n\t"
"cmpq %%rcx, %%rdx\n\t"
"movq %%rdx, 8(%%rbx)\n\t"
"jg 1b\n\t"
:
: "i"(a)
:"%rax", "%rdx", "%rdi", "%rcx", "%rsi", "memory" );
    cout << a << endl;
     


    return 0;
}
