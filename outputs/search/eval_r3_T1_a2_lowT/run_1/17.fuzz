#include <iostream>
struct myclass
{
  myclass(void)
  : _i(0)
  {
    std::cout << "default constructor called" << std::endl;
  }
  myclass(myclass const &t)
  : _i(t._i)
  {
    std::cout << "copy constructor called " << std::endl; 
  }
  int _i;
};
int main(int argc, char **argv)
{
  myclass x;
  myclass y( x);
  x._i = 10;
}
 

class Rectangle1
{
  std::vector<double> _vertices;
  double _area;

public:
  Rectangle1(std::vector<double> vertices);
  static double compute_area(std::vector<double> vertices);
};

Rectangle1::Rectangle1(std::vector<double> vertices)
{
  _vertices = vertices;
  _area = 0;
  for (size_t i = 0; i < 4; i++)
    for (size_t j = 0; j < 2; j++)
      _area += _vertices[i+j*_area];
}

double Rectangle1::compute_area(std::vector<double> vertices)
{
  Rectangle1 rectangle1(vertices);
  return rectangle1._area;
}

std::vector<int> indices = {};

struct Rectangle2
{
  std::vector<double> _vertices;
  double _area;

  Rectangle2(std::vector<double> vertices)
  {
    _vertices = vertices;
    _area = 0;
    for (size_t i = 0; i < 4; i++)
      for (size_t j = 0; j < 2; j++)
        _area += _vertices[i+j*_area];
  }

  static double compute_area(std::vector<double> vertices)
  {
    Rectangle2 rc1;
    rc1._vertices = std::move(vertices);
    return rc1._area;
  }
};

int main(int argc, char **argv)
{
  std::vector<double> v = {1,2,3,4,5,6,7,8};
  int i = indices.size();
  const double d = Rectangle1::compute_area(v);
}


