#include <iostream>
class myclass
{
public:
  myclass(int i)
  {
    std::cout << "Constructor called with value: " << i << std::endl;
  }
  void useMe(void) { std::cout << "Use me" << std::endl; }
};
int main(int argc, char *argv[])
{
  std::cout << "sizeof myclass = "<< sizeof(myclass) << std::endl;
  myclass c(123);
  c.useMe();
  myclass *p = new myclass(10);
  delete p;
  p->useMe();
}
