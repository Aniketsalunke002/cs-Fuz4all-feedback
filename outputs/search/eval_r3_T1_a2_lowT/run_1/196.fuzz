#include <iostream>
using namespace std;
int main() {
	int original[5] = {1,2,3,4,5};
	int modified_list[5] = {1,2,3,4,5};
	for (int a = 0; a < 5; a++) {
		if (modified_list[a] > 3) {
			modified_list[a] += 1;
		} else if (modified_list[a] < 3) {
			modified_list[a] -= 1;
		}
	}
	for (int b = 0; b < 5; b++) {
		cout << modified_list[b] + original[b] << endl;
	}
}
