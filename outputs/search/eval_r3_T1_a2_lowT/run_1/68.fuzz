#include <iostream>
using namespace std;
main()
{
    cout << __FILE__ << " ";
    cout << "end of main";
}
 
#include <iostream>
#include <cassert>
using namespace std;
int main(int argc, char** argv)
{
    cout << argc << " ";
#ifdef TEST_COMPILER
    int a;
    (void)argc;
    assert(a == 0);
    cout << "end of main";
#else
    int a[] = {1, 2, 3, 4};
    cout << "end of main";
#endif
    return 0;
}
