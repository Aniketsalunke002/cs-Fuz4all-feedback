#include <iostream>
class myclass{
public :
     myclass(void):_i(0){}
     myclass(const myclass& t):_i(t._i){
        std::cout << "copy constructor called" <<std::endl;
    }
    virtual myclass& operator=(const myclass& t){
        _i = t._i ;
        return *this;
    }
    int _i;
};
int main(int argc, char** argv){
    myclass x;
    myclass y(x);
    x._i = 10;
    
    y=x;
}
