#include <iostream>

template<class T>
void printArray(T* array, const int& arraylength)
{
    for(int i=0;i<arraylength;++i)
        std::cout<<array[i]<<",";
    std::cout<<std::endl;
}
int main(int argc, char** argv)
{
    int myarray[]={1,3,4,5,88,89,90,91};
    int length=sizeof(myarray)/sizeof(myarray[0]);
    printArray(myarray,length);
    char mychararray[]={"asdsd"};
    printArray(mychararray,sizeof(mychararray)/sizeof(mychararray[0]));
}
