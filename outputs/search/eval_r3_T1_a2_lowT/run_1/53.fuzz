#include <iostream>
using namespace std;
int main(int argc, char** argv)
{
    cout << argc << " ";
    struct Number
    {
        int num;
        Number(int n) : num(n)
        {
        }
        int& operator ()(int y)
        {
            cout << "calling operator()\n";
            return num;
        }
    };
    Number num = 10;
    cout << *(&num(2)) << " ";
    return 0;
}