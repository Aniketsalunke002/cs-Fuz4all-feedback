#include <iostream>
using namespace std;

int deobfuscate(string& str) {
    char temp = str[1];
    str[1] = str[0];
    str[0] = temp;
    return 0;
}
int main(int argc, char *argv[]) {
    string str = "0123456789abcdef";
    deobfuscate(str);
    cout << str << endl;
}
 
#include <iostream>
using namespace std;

void deobfuscate(const string& str) {
    if (str.length() < 3) {
        return;
    }
    char temp = str[1];
    str[1] = str[0];
    str[0] = temp;
}
int main(int argc, char *argv[]) {
    string str = "0123456789abcdef";
    deobfuscate(str);
    cout << str << endl;
    return 0;
}
 
#include <iostream>
#include <vector>
using namespace std;

void test(int &a, int *b, vector<int> c) {
    vector<int> *v = new vector<int>;
    delete v;
}
int main(int argc, char *argv[]) {
    int a = -1;
    int *b;
    vector<int> &c;
    int d=0;
    test(a, &d, c);
    return 0;
}
 
#include <iostream>
#include <vector>
using namespace std;

void test(int &a, int *b, vector<int> &c) {
    vector<int>* v = new vector<int>;
    vector<int>& t = *v;
}
int main() {
    int a = -1;
    int *b;
    vector<int> &c;
    int d;
    d = 0;
    test(a, &d, c);
    return 0;
}
 
#include <iostream>
#include <vector>
using namespace std;

void test(int &a, int *b, vector<int> &c) {
    vector<int>* v = new vector<int>;
    vector<int>& f = *v;
    f = c;
    delete v;
}

int main() {
    int a = -1;
    int *b;
    vector<int> &c;
    test(a, &b, c);
    return 0;
}
