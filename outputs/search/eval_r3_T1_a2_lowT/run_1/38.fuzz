#include <iostream>
using namespace std;
int main(int argc, char** argv)
{
    int i = 2, k;
    while (1)
    {
        k = 1;
        cout << i << "... ";
        if (i%4 == 0)
        {
            cout << i << " *** ";
            while (1)
            {
                cout << k << " ";
                k--;
                if (!k)
                {
                    break;
                }
            }
            break;
        }
        cout << i << endl;
        i++;
    }
    cout << "Finished";
    return 0;
}

 
