#include <iostream>


class myclass
{
public:
  myclass(void)
  {
    std::cout << "Default constructor called" << std::endl; 
  }
  myclass(const short b)
  { 
    std::cout << "Value constructor called with value: " << b << std::endl; 
  }
};

int main(int argc, char **argv)
{
  std::cout << "sizeof myclass = "<< sizeof(myclass) << std::endl;
  myclass x;
  myclass y(123);
}

