#include <iostream>
class A
{
  public:
    A(float t) { time = t; }
    virtual ~A() {}
    void print() { cout << "The " << getClassID() << " started at " << time << endl; }
    inline const char* getClassID() { return "Base of the Class A"; }
  private:
    float time;
} ;
class B : public A
{
  public:
    B(float t) : A(t) {}
    void print() { cout << "The " << getClassID() << " started at " << time << endl; }
    inline const char* getClassID(){ return "Implementation of the Class B"; }
    
} ;
int main(int argc, char **argv)
{
  B obj_b(0.5f);
  obj_b.print();
}

 
#include <iostream>

template<typename S>
class MyStack
{
public:
  void push(const S& aVal)
  {
    S* new_item = new S;
    *new_item = aVal;
    top_item->next = new_item;
    top_item = new_item;
  }
  S& pop()
  {
    delete top_item;
    top_item = top_item->next;
    return *top_item;
  }
  bool empty() { return top_item==0; }
  MyStack() { top_item = 0; }
  ~MyStack() { while (!empty()) pop(); }
private:
  S* top_item;
};

class Data
{
public:
  Data(char * c) { this->c = *c; cout << this->c << endl; }
  char* getChar() { return &c; }
private:
  char c;
};

int main(int argc, char **argv)
{
  Data d("hola");
  MyStack <Data> s;
  s.push(d);
  cout << *s.pop().getChar() << endl;
}

