#include <iostream>
using namespace std;
int main()
{
    cout << "Please enter 4 digits";
    char s[4];
    cin >> s;
    cout << "The entered digits are";
    for (int i = 0; i < 4; i++)
    {
        cout << " " << s[i];
    }
    cout << "=" << int(s[0]) * 1000 + int(s[1]) * 100 + int(s[2]) * 10 + int(s[3]);
    return 0;
}