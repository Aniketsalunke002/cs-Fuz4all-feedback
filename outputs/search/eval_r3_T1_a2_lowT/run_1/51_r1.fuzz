#include <iostream>

using namespace std;
int main(int argc, char** argv)
{
    cout << argc << " ";

    struct Person
    {
        int age;
        int height;
        int weight;

        Person() : age(0), height(0), weight(0)
        {
            cout << "person constructor\n";
        }
    };
    Person david{5, 88, 0};
    Person jason{5, 88, 0};
    cout << "end of main\n";
    return 0;
}