#include <type_traits>
#include <iostream>
#include <vector>
using namespace std;
 
template<typename T> void printType() {
 int x;
 if(T is_pointer<T>::value)
    cout << "T is pointer type" << endl;
 if(T is_const<T>::value)
    cout << "T is const type" << endl;
 if(T is_integral<T>::value)
    cout << "T is integral type" << endl;
 if(T is_floating_point<T>::value)
    cout << "T is floating point type" << endl;
 if(T is_class<T>::value)
    cout << "T is class type" << endl;
 if(T is_void<T>::value)
    cout << "T is void type" << endl;
  if(T is_reference<T>::value)
    cout << "T is reference type" << endl;
}
int main() {
cout << "int" << endl;
printType<int>();
cout << "double" << endl;
printType<double>();
cout << "float" << endl;
printType<float>();
cout << "char" << endl;
printType<char>();
cout << "void" << endl;
printType<void>();
}
