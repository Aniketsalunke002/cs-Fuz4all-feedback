#include <iostream>

#include <vector>
using namespace std;
class Foo {

public:
double x;
vector<Foo*> arr;
Foo(double x):x(x)
{}
};

Foo* CreateArray(double x){
Foo* array = new Foo[100];
int idx = 0;
Foo f(x);
for(int i = 0; i < 100; i++)
array[i] = f;
return array;
}
int main()
{
    double d = 0.0;
    CreateArray(d);
    printf("Hello, World!\n");
}