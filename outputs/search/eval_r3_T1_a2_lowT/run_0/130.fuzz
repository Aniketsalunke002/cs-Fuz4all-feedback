#include <iostream>
using namespace std;
int main()
{
     
    int n, k;
     
    cin >> n >> k;
     
    string input1[]={"0 01", "0 10", "1 00", "0 11", "1 01", "1 10", "1 11"};  
    string input2[]={"1000100010000", "0111011101110", "0001111111100", "0000101010100", "0000010101010", "0000001010101", "0000000101010"};  
     
    int first_generation[8]={0,0,1,0,1,0,1,0};
    int second_generation[8]={0,1,1,1,0,0,0,0};
     
    int i, j;
    int count=0;

     
    for(i=0; i<8; i++)
    {
        for(j=0; j<8; j++)
        {
            if(input1[i][j]==input2[i][j])  
                count = count + k;
            else
                count = count;     
        }
    }

     
    for(i=0; i<8; i++)
    {
        for(j=0; j<8; j++)
        {
            if(first_generation[i]==1&&second_generation[j]==1)  
            count =count + 2;
            else
                count = count;    
        }
    }

     
    cout<<count<<endl;

}
