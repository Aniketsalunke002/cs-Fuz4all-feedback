#include <iostream>
#include <algorithm>
using namespace std;
int main()
{
    int n;
    float a[100], b[100];
    cout<<"Enter number of elements=";
    cin>>n;
    cout<<"Enter elements:\n";
    for(int i=0; i<n; i++)
    {
        cin>>a[i];
    }
    for(int i=0; i<n; i++)
    {
        cin>>b[i];
    }
    for(int i=0; i<n; i++)
    {
        if(a[i]>b[i])
        {
            cout<<b[i]<<" "<< a[i]<<endl;
        }
        else
        {
            cout<<a[i]<<" "<<b[i]<<endl;
        }
    }
}
