#include <iostream>

int main() {
    int a,b,c=10;
    a=b=14-2*c;
    c=c%10;
    std::cout<<a<<std::endl;
    std::cout<<b<<std::endl;
    std::cout<<c<<std::endl;
    int d,e,f=20;
    d=e=23-2*f;
    f=f%10;
    std::cout<<d<<std::endl;
    std::cout<<e<<std::endl;
    std::cout<<f<<std::endl;
}