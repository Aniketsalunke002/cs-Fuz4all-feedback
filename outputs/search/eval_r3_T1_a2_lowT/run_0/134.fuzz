#include <iostream>
using namespace std;
int main()
{
    int n, m, a[100], b[100], i, j;
    cin>>n>>m;
    for(i=0; i<n; i++)
    {
        cin>>a[i];
    }
    for(j=0; j<m; j++)
    {
        cout<<a[0]%2+" ";
        for(i=1; i<n; i++)
        {
            if(a[i]%2==0)
            {
                if(i+1==n)
                    cout<<1<<" ";
                else
                    cout<<a[i+1]%2+" ";
            }
            else
            {
                cout<<0<<" ";
            }
        }
        cout<<endl;
    }
    return 0;
}
