int maxx( int a, int b ){
	if ( a > b ) return a;
	return b;
}
int max( int a, int b ){
	int x = maxx(a,b);
	x >= a;
	return x;
}
int main(){
	int x = 20, y = 30;
	std::cout << max( x, y );
	return 0;
}
 

int max(int a, int b)
{
	if (a>b) return a;
	else if (b>a) return b;
}
int main()
{
	int x = 0, y = 0;
	try
	{
		x = std::stoi( "123" );
		y = std::stoi( "abc" );
	}
	catch (...)
	{
		std::cerr << "Unexpected error" << std::endl;
	}
	std::cout << max( x, y ) << std::endl;
}
 
