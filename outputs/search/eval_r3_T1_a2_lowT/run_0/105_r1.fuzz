#include <iostream>
using namespace std;
int main(int argc, char const *argv[])
{
    double a[] = {2,1,4,3};
    for (int i = 0; i < 4; i++)
        cout << "a["<< i<<"] = "<< a[i] << endl;
    return 0;
}