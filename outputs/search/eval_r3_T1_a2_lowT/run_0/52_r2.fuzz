#include <iostream>

void do_it()
{
    std::ios_base::sync_with_stdio(false);
    std::cout << std::cout.sync_with_stdio(1);
}
int main()
{
    do_it();
    std::cout << std::cout.sync_with_stdio(0) << std::endl;
}
