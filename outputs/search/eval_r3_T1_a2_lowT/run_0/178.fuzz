#include <iostream>
typedef struct {
    int e,f;
} st;
int main() {
    st a,b;
    std::cin>>a.e>>a.f>>b.e>>b.f;
    std::cout<<a.e+b.e<<'\n';
    if(a.e<b.e) {
    	if(a.e%2==0) {
    		std::cout<<a.e<<'\n';
    		std::cout<<b.e<<'\n';
    		std::cout<<a.f<<'\n';
    	}
    	else {
    		std::cout<<0<<'\n';
    		std::cout<<b.e<<'\n';
    		std::cout<<a.f<<'\n';
    	}
    }
    else {
    	if(a.e%2==0) {
    		std::cout<<a.e<<'\n';
    		std::cout<<0<<'\n';
    		std::cout<<a.f<<'\n';
    	}
    	else {
    		std::cout<<0<<'\n';
    		std::cout<<a.e<<'\n';
    		std::cout<<a.f<<'\n';
    	}
    }
    return 0;
}