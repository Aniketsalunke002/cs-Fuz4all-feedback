#include <iostream>
using namespace std;
int main()
{
    int n, m;
    int a[1000],b[1000],c[1000];
    cin>>n;
    cin>>m;
    if((m>n) && (n>=1) )
    {
        cout<<1<<" "<<n<<endl;
    }
    
    else 
    {
        for(int i = 0; i<n;i++)
        {
            cin>>a[i];
        }
        while(1)
        {
            if(m==n)
            {
                for(int i =0;i<n;i++)
                {
                    b[i]=a[i];
                }
                for(int i =0;i<n;i++)
                {
                    c[i]=b[i]/m;
                    cout<<" "<<c[i];
                }
                cout<<endl;
                break;
            }
            else
            {
                for(int i =0;i<n;i++)
                {
                    b[i]=a[i];
                }
                b[n]=a[n];
                for(int i =0;i<n;i++)
                {
                    c[i]=b[i]/m;
                    cout<<" "<<c[i];
                }
                cout<<endl;
                for(int j =0;j<n;j++)
                {
                    a[j]=c[j];
                }
                m=m-1;
            }            
        }
    }
    return 0;
}

 
#include <iostream>
#include <string>
#include <fstream>
using namespace std;
int main()
{
     
    fstream file;
    string filename1="data.dat";
    string file2="data1.dat";
     
    file.open(filename1,ios::app);
    if(file.is_open())
    {
    	string str;
    	cout<<"\nFile is Opened";
    	cout<<"\nWrite anything or ENTER";
    	
    	 
    	cin>>str;
    	 
    	file<<str<<endl<<endl;
    }

    fstream file1;
    file1.open(file2,ios::out | ios::in );
    
    if(file1.is_open())
    {
    	cout<<"File is opened in read only mode"<<endl;
    	string word;
    	while(file1>>word)
    	{
    		cout<<word<<endl;
    	}
    }
    return 0;
}
 
