#include <iostream>
int main()
{
    std::cout << std::cout.tie(0) << std::endl;
    std::cout << std::cout.tie() << std::endl;
}
#pragma clang version reset
#include <iostream>
int main()
{
    std::cout << std::tie(std::cout) << std::endl;
    std::cout << std::tie() << std::endl;
}
#pragma clang version reset
