#include <iostream>

class Base
{
public:
    virtual ~Base() = default;
    virtual void fun() { std::cout << "void"; }
    virtual void fun1() { std::cout << "fun1"; }
};
 
class Derived : public Base
{
public:
    void fun() override { std::cout << "fun"; }
 
    void fun1() override { std::cout << ":" << "fun1" << ":" << Base::fun << ":" << Base::fun1; }
};
 
int main()
{
    Derived d;
    d.fun();
    d.fun1();
}