#include <iostream>
#include <algorithm>
using namespace std;
int main()
{
    int n, a[100];
    cin>>n;
    for(int i=0; i<n; i++)
    {
        cin>>a[i];
    }
    for(int i=0; i<n; i++)
    {
        while(a[i]!=-1)
        {
            a[i]++;
            if(i==n)
            {
                break;
            }
        }
    }
    cout<<a[n-1];
}