#include <iostream>
int main()
{
    std::cout << std::cin.tie(0) << std::endl;
    std::cout << std::cin.tie(0, 0) << std::endl;
    std::cout << std::cin.tie(0, std::cout) << std::endl;
}
#pragma clang version reset
 
#include <iostream>
int main()
{
    std::cout << std::ios::tie() << std::endl;
}
#pragma clang version reset
 
#include <iostream>
int main()
{
    std::cout << std::ios::tie(nullptr) << std::endl;
}
#pragma clang version reset
 
#include <iostream>
int main()
{
    std::cout << std::ios::tie(std::cout) << std::endl;
}
#pragma clang version reset
