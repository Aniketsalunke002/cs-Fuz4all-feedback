#include <iostream>
int main()
{
    std::string str("hello, world");
    char p;
    bool b1=str.empty();
    bool b2;
    b2=str.size();
    p=str[0];
    std::cout<<(int)p<<std::endl;
    if(b1==true and b2<=60)
    {
        std::cout<<"is OK"<<std::endl;
    }
    if(b2>60)
    {
        std::cout<<"too many digits";
    }

}