{
    std::cout << std::cin.tie(0) << std::endl;
    std::cout << std::cin.tie() << std::endl;
}
 
#include <iostream>
int main()
{
    std::cout << std::cin << std::get<0>((int)(std::cin % 4)) << std::endl;
}
 
#include <iostream>
#include <memory>
using std::tuple_size;

class Type {
  public:
    bool validate(tuple_size<tuple_size>) {
        return false;
    }
    bool validate(tuple_size<tuple_size - 1> = tuple_size<tuple_size - 1>()) {
        return true;
    }
};

class Base {
  public:
    Type foo() { return Type{}; }
};

int main() {
    Base foo;
    foo.foo().validate(tuple_size<decltype(foo.foo())>{});
}
