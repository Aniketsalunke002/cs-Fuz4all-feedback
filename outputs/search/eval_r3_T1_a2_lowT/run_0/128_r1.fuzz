#include <iostream>

using namespace std;
int main()
{
    int n, a[100];
    cin>>n;
    for(int i=0; i<n; i++)
    {
        cin>>a[i];
    }
      
    for(int i=0; i<n; i++)
    {
        if(a[i]==0)
            a[i]=-1;
        else
            if(a[i]==1)
                a[i] = -1;
            else
                a[i] = 1;
    }
    for(int i=0; i<n; i++)
    {
        cout<<a[i]<<" ";
    }
    return 0;
}