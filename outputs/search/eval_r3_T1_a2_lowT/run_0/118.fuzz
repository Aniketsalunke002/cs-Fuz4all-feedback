#include <iostream>
#include <list>
#include <algorithm>
#include <memory>
using namespace std;
int main()
{
    std::allocator<int> alloc{};
    auto p = std::allocator_traits<decltype(alloc)>::allocate(alloc, 5);
    std::allocator_traits<decltype(alloc)>::deallocate(alloc, p, 5);
}
 
#include <iostream>
