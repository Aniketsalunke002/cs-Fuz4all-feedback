#include <iostream>


namespace foo
{

    class bar
    {
    public:
        bar() {};
        bar(int x) : m_x(x) {}
        int m_x;

    };

}


int main(void) {

    foo::bar a(12);
    std::cout << a.m_x << std::endl;
    foo::bar b(5);
    std::cout << b.m_x << std::endl;

    foo::bar a1;
    std::cout << a1.m_x << std::endl;

    return 0;
}