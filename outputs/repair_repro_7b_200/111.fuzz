#include <iostream>
int main(void) {
    int a=1,b=2,c=3,d=4,e=5,f=6;
    std::thread[7] t;
    for (int i=0;i<7;i++)
        t[i]=new std::thread([](){
            if (i==1) {
                a=a+d;
            } else if (i==3) {
                b=c+b;
            } else {
                c=a+a+a+c;
            }
            f=1;
        });
    t[1]->join();
    t[0]->join();
    t[2]->join();
    t[3]->join();
    t[4]->join();
    t[5]->join();
    t[6]->join();
    if (f==1)
        std::cout<<a << " " << b << " " << c << std::endl;
    foo();
    return 0;
}
 
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <pthread.h>
#include <sys/wait.h>
#include <sched.h>
#include <semaphore.h>
#include "semaphore.h"
