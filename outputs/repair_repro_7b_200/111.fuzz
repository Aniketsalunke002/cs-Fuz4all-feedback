                m=&mtx[i];
                break;
            }
        if (flag==FALSE)
            break;
        if (i==1) {
            psem->sem_wait(m);
        } else {
            m->pthread_mutex_lock();
        }
    }
    pthread_mutex_unlock(m);
    for (i=0;i<2;i++)
        pthread_mutex_unlock(&mtx[i]);
    pthread_mutex_init(&mtx[1], NULL);
    for (i=0;i<2;i++)
        if (t[i].m=TREAD_FINISHED) {
            tt=&t[i];
            sem_post(&end);
        } else {
            m = &mtx[i];
        }
    int n,sum=1,cnt=0;
    foo();
