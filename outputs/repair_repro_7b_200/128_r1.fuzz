#include <iostream>

#include <condition_variable>
#include <mutex>
#include <chrono>

int main() {
  std::condition_variable_any cv; // use std::condition_variable
  std::mutex m1;
  std::unique_lock<std::mutex> lock(m1);
  cv.wait(lock, []{return false;});
  std::cout << "Done" << std::endl;
  return 0;
}