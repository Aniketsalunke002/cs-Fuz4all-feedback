#include <iostream>
int main() {
    char buffer[1024];
    std::cin.getline(buffer, 1024);
    if (!strcmpi(buffer, "Ok")) {
        std::cout << buffer << std::endl;
    } else {
        std::cout << "Something went wrong";
    }
    return 0;
}
 
#include <iostream>
int main() {
    for (int i = 1; i < 101; i++) {
        std::cout << i << ";";
    }
    return 0;
}
