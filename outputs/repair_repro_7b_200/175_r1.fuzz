#include <iostream>

using namespace std;

int main(int argc, const char** argv)
{
    Node* head = new Node();
    head->val = 10;
    head->next = new Node();
    head->next->val = 20;
    head->next->next = new Node();
    head->next->next->val = 30;

    Node* secondHead = head;  
    secondHead->val == 50;  
    head = secondHead;  
    cout<<"The new head value is "<<head->val<<endl;
    return 0;
}