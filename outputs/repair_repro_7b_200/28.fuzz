#include <iostream>
using namespace std;
int main() {
	if (true) {
		int x = int{ 10 };
		return x;
	}
	return 0;
}
 
#include <iostream>
using namespace std;
int main() {
	cout << "Hello World! (Type Not Forget)" << endl;  
}
 
#include <iostream>
using namespace std;
