#include <iostream>
using namespace std;
int main() {
  int a;
  cin >> a;
  cout << a - 1;
}
 
#include <iostream>
using namespace std;
int main() {
  int a, b;
  cin >> a >> b;
  cout << a + b;
}
 
#include <iostream>
using namespace std;
int main() {
  int a[2][2];
  for (int i = 0; i < 2; i++)
    for (int j = 0; j < 2; j++)
      cin >> a[i][j];
  cout << a[0][0] + a[0][1] << " " << a[0][1] + a[1][0] << " " << a[1][0] + a[1][1] << " " << a[1][1] + a[0][0];
}
